{% extends 'base.html.twig' %}

{% block title %}My Complaints{% endblock %}

{% block body %}

{# ── Page Hero ── #}
<div class="complaint-page-hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-scanline"></div>
    <div class="container position-relative">
        <div class="hero-inner">
            <span class="hero-tag"><i class="fas fa-ticket-alt"></i> Support</span>
            <h1 class="hero-title">My <span class="hero-accent">Complaints</span></h1>
            <p class="hero-sub">Track and manage all your support tickets in one place.</p>
        </div>
    </div>
</div>

<section class="complaint-section py-5">
    <div class="container">

        {# ── Header Row ── #}
        <div class="list-header mb-4">
            <div class="list-header-left">
                <span class="list-count">{{ complaints|length }} ticket{{ complaints|length != 1 ? 's' : '' }}</span>
            </div>
            <a href="{{ path('app_complaints_new') }}" class="btn-fire">
                <span class="btn-fire-bg"></span>
                <i class="fas fa-plus"></i>
                <span>New Complaint</span>
            </a>
        </div>

        {% if complaints|length > 0 %}

        <div class="tickets-list">
            {% for complaint in complaints %}
            <div class="ticket-card mb-3">
                <div class="ticket-glow"></div>
                <div class="ticket-corner tl"></div>
                <div class="ticket-corner tr"></div>
                <div class="ticket-corner bl"></div>
                <div class="ticket-corner br"></div>

                <div class="ticket-body">
                    {# Icon #}
                    <div class="ticket-icon-wrap">
                        <i class="{{ complaint.category.icon }}"></i>
                    </div>

                    {# Main content #}
                    <div class="ticket-main">
                        <div class="ticket-top">
                            <a href="{{ path('app_complaints_show', {id: complaint.id}) }}" class="ticket-subject">
                                {{ complaint.subject }}
                            </a>
                            <span class="ticket-id">#{{ complaint.id }}</span>
                        </div>

                        <p class="ticket-desc">
                            {{ complaint.description|length > 140 ? complaint.description|slice(0, 140) ~ '…' : complaint.description }}
                        </p>

                        <div class="ticket-badges">
                            <span class="tbadge tbadge-{{ complaint.status.badgeClass }}">
                                <i class="{{ complaint.status.icon }}"></i>
                                {{ complaint.status.label }}
                            </span>
                            <span class="tbadge tbadge-priority-{{ complaint.priority.badgeClass }}">
                                <i class="{{ complaint.priority.icon }}"></i>
                                {{ complaint.priority.label }}
                            </span>
                            <span class="tbadge tbadge-cat">
                                <i class="{{ complaint.category.icon }}"></i>
                                {{ complaint.category.label }}
                            </span>
                        </div>
                    </div>

                    {# Meta + action #}
                    <div class="ticket-meta">
                        <div class="meta-item">
                            <i class="fas fa-calendar-alt"></i>
                            {{ complaint.createdAt|date('d/m/Y') }}
                        </div>
                        {% if complaint.updatedAt %}
                        <div class="meta-item">
                            <i class="fas fa-sync-alt"></i>
                            {{ complaint.updatedAt|date('d/m/Y') }}
                        </div>
                        {% endif %}
                        <a href="{{ path('app_complaints_show', {id: complaint.id}) }}" class="btn-view mt-2">
                            <i class="fas fa-eye"></i> View
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        {% else %}

        {# ── Empty State ── #}
        <div class="empty-state">
            <div class="empty-grid-overlay"></div>
            <div class="empty-icon"><i class="fas fa-inbox"></i></div>
            <h4 class="empty-title">No Tickets Yet</h4>
            <p class="empty-sub">You haven't submitted any complaints. If you're experiencing any issues, feel free to open a ticket.</p>
            <a href="{{ path('app_complaints_new') }}" class="btn-fire mt-3">
                <span class="btn-fire-bg"></span>
                <i class="fas fa-plus"></i>
                <span>Submit Your First Complaint</span>
            </a>
        </div>

        {% endif %}

    </div>
</section>

<style>
/* ═══════════════════════════════════════════
   EYE2WIN — COMPLAINTS INDEX
═══════════════════════════════════════════ */
:root {
    --red:      #e8372a;
    --red-glow: rgba(232,55,42,0.35);
    --red-dim:  rgba(232,55,42,0.12);
    --dark:     #0d0d0f;
    --panel:    rgba(255,255,255,0.03);
    --border:   rgba(255,255,255,0.07);
    --border-r: rgba(232,55,42,0.35);
    --text:     rgba(255,255,255,0.9);
    --muted:    rgba(255,255,255,0.4);
    --r:        12px;
}

/* ── HERO ── */
.complaint-page-hero {
    position: relative;
    background: linear-gradient(160deg, #1a0505 0%, #0d0d0f 60%);
    border-bottom: 1px solid rgba(232,55,42,0.2);
    padding: 3.5rem 0 3rem;
    overflow: hidden;
}
.hero-grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(232,55,42,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.06) 1px, transparent 1px);
    background-size: 40px 40px;
}
.hero-scanline {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.07) 2px, rgba(0,0,0,0.07) 4px);
    pointer-events: none;
}
.hero-inner { position: relative; z-index: 1; }
.hero-tag {
    display: inline-flex; align-items: center; gap: .45rem;
    background: var(--red-dim); border: 1px solid var(--border-r); color: var(--red);
    font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    padding: .3rem .8rem; border-radius: 4px; margin-bottom: 1rem;
}
.hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; letter-spacing: -.01em;
    color: #fff; margin: 0 0 .6rem; line-height: 1.1;
    text-shadow: 0 0 40px rgba(232,55,42,0.3);
}
.hero-accent { color: var(--red); }
.hero-sub { color: var(--muted); font-size: .92rem; max-width: 480px; margin: 0; }

/* ── SECTION ── */
.complaint-section { background: var(--dark); min-height: 60vh; }

/* ── LIST HEADER ── */
.list-header {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
}
.list-header-left { display: flex; align-items: center; gap: .75rem; }
.list-count {
    font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--muted); background: var(--panel); border: 1px solid var(--border);
    padding: .3rem .75rem; border-radius: 20px;
}

/* ── TICKET CARD ── */
.ticket-card {
    position: relative; overflow: hidden;
    background: rgba(255,255,255,0.025);
    border: 1.5px solid rgba(255,255,255,0.07);
    border-radius: var(--r); padding: 1.4rem 1.6rem;
    transition: border-color .2s, background .2s, transform .18s, box-shadow .2s;
}
.ticket-card:hover {
    border-color: rgba(232,55,42,0.35);
    background: rgba(232,55,42,0.05);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.4);
}
.ticket-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, rgba(232,55,42,0.5), transparent);
    opacity: 0; transition: opacity .3s;
}
.ticket-card:hover::before { opacity: 1; }

/* Corners */
.ticket-corner {
    position: absolute; width: 8px; height: 8px;
    border-color: rgba(232,55,42,0.3); border-style: solid;
    opacity: 0; transition: opacity .2s;
}
.ticket-corner.tl { top: 5px; left: 5px;  border-width: 1.5px 0 0 1.5px; }
.ticket-corner.tr { top: 5px; right: 5px; border-width: 1.5px 1.5px 0 0; }
.ticket-corner.bl { bottom: 5px; left: 5px;  border-width: 0 0 1.5px 1.5px; }
.ticket-corner.br { bottom: 5px; right: 5px; border-width: 0 1.5px 1.5px 0; }
.ticket-card:hover .ticket-corner { opacity: 1; }

/* Glow */
.ticket-glow {
    position: absolute; width: 120px; height: 120px; border-radius: 50%;
    background: radial-gradient(circle, rgba(232,55,42,0.2), transparent 70%);
    top: -30px; right: -30px;
    opacity: 0; transition: opacity .3s; pointer-events: none;
}
.ticket-card:hover .ticket-glow { opacity: 1; }

/* Body layout */
.ticket-body {
    display: flex; align-items: flex-start; gap: 1.2rem; position: relative; z-index: 1;
}
.ticket-icon-wrap {
    flex-shrink: 0; width: 48px; height: 48px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 11px; display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; color: rgba(255,255,255,0.35);
    transition: all .22s;
}
.ticket-card:hover .ticket-icon-wrap {
    background: rgba(232,55,42,0.12); border-color: rgba(232,55,42,0.3); color: #ff6b4a;
}

.ticket-main { flex: 1; min-width: 0; }
.ticket-top {
    display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap; margin-bottom: .4rem;
}
.ticket-subject {
    font-size: 1rem; font-weight: 700; color: var(--text); text-decoration: none;
    transition: color .2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;
}
.ticket-subject:hover { color: #ff6b4a; }
.ticket-id {
    flex-shrink: 0; font-size: .7rem; font-weight: 700; color: var(--muted);
    background: rgba(255,255,255,0.05); padding: .15rem .5rem; border-radius: 4px;
    letter-spacing: .05em;
}
.ticket-desc {
    font-size: .82rem; color: var(--muted); margin: 0 0 .75rem; line-height: 1.55;
}
.ticket-badges { display: flex; gap: .4rem; flex-wrap: wrap; }

/* Badges */
.tbadge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .68rem; font-weight: 700; letter-spacing: .04em;
    padding: .25rem .6rem; border-radius: 4px; text-transform: uppercase;
}
.tbadge i { font-size: .6rem; }

/* Status badges mapped from Bootstrap classes */
.tbadge-warning  { background: rgba(255,193,7,0.15);  border: 1px solid rgba(255,193,7,0.3);  color: #ffc107; }
.tbadge-info     { background: rgba(13,202,240,0.12); border: 1px solid rgba(13,202,240,0.3); color: #0dcaf0; }
.tbadge-success  { background: rgba(25,135,84,0.15);  border: 1px solid rgba(25,135,84,0.35); color: #3dd68c; }
.tbadge-danger   { background: rgba(232,55,42,0.15);  border: 1px solid rgba(232,55,42,0.35); color: #ff6b4a; }
.tbadge-secondary{ background: rgba(255,255,255,0.06);border: 1px solid rgba(255,255,255,0.1);color: var(--muted); }
.tbadge-primary  { background: rgba(13,110,253,0.15); border: 1px solid rgba(13,110,253,0.3); color: #6ea8fe; }

/* Priority badges */
.tbadge-priority-danger  { background: rgba(232,55,42,0.12);  border: 1px solid rgba(232,55,42,0.25);  color: #ff6b4a; }
.tbadge-priority-warning { background: rgba(255,193,7,0.1);   border: 1px solid rgba(255,193,7,0.2);   color: #ffc107; }
.tbadge-priority-success { background: rgba(25,135,84,0.1);   border: 1px solid rgba(25,135,84,0.2);   color: #3dd68c; }
.tbadge-priority-secondary{background: rgba(255,255,255,0.04);border: 1px solid rgba(255,255,255,0.08);color: var(--muted); }
.tbadge-priority-info    { background: rgba(13,202,240,0.1);  border: 1px solid rgba(13,202,240,0.2);  color: #0dcaf0; }

.tbadge-cat { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.45); }

/* Meta */
.ticket-meta {
    flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end;
    gap: .3rem; min-width: 90px;
}
.meta-item {
    display: flex; align-items: center; gap: .35rem;
    font-size: .72rem; color: var(--muted); white-space: nowrap;
}
.meta-item i { font-size: .65rem; }

/* View button */
.btn-view {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .4rem .9rem; background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 7px;
    color: rgba(255,255,255,0.65); font-size: .78rem; font-weight: 600;
    text-decoration: none; transition: all .2s;
}
.btn-view:hover {
    background: rgba(232,55,42,0.12); border-color: rgba(232,55,42,0.35);
    color: #fff; transform: translateX(2px);
}

/* Fire button */
.btn-fire {
    position: relative; overflow: hidden;
    display: inline-flex; align-items: center; gap: .6rem; padding: .65rem 1.5rem;
    background: linear-gradient(135deg, #c0392b, #e8372a, #ff5533);
    border: none; border-radius: 9px; color: #fff;
    font-size: .88rem; font-weight: 700; letter-spacing: .03em; cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 20px rgba(232,55,42,0.4); transition: transform .18s, box-shadow .18s;
}
.btn-fire:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(232,55,42,0.55); color: #fff; }
.btn-fire:active { transform: translateY(0); }
.btn-fire-bg { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent); pointer-events: none; }

/* ── EMPTY STATE ── */
.empty-state {
    position: relative; overflow: hidden;
    background: var(--panel); border: 1px dashed rgba(255,255,255,0.08);
    border-radius: var(--r); padding: 5rem 2rem;
    text-align: center; display: flex; flex-direction: column; align-items: center;
}
.empty-grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(232,55,42,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
}
.empty-icon {
    position: relative; font-size: 4rem; color: rgba(255,255,255,0.12);
    margin-bottom: 1.5rem;
}
.empty-title { font-size: 1.4rem; font-weight: 800; color: var(--text); margin-bottom: .5rem; position: relative; }
.empty-sub { font-size: .88rem; color: var(--muted); max-width: 380px; line-height: 1.6; position: relative; }

/* ── RESPONSIVE ── */
@media (max-width: 640px) {
    .ticket-body { flex-wrap: wrap; }
    .ticket-meta { flex-direction: row; flex-wrap: wrap; align-items: center; width: 100%; justify-content: flex-start; }
    .ticket-icon-wrap { width: 38px; height: 38px; font-size: 1rem; }
    .list-header { flex-direction: column; align-items: flex-start; }
    .btn-fire { width: 100%; justify-content: center; }
}
</style>

{% endblock %}
