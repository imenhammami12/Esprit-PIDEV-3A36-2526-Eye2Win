{% extends 'base.html.twig' %}

{% block title %}Submit Complaint{% endblock %}

{% block body %}

{# ── Page Hero ── #}
<div class="complaint-page-hero">
    <canvas id="heroCanvas"></canvas>
    <div class="hero-grid-overlay"></div>
    <div class="hero-scanline"></div>
    <div class="hero-vignette"></div>
    <div class="container position-relative">
        <div class="hero-inner">

            <span class="hero-tag">
                <span class="hero-tag-dot"></span>
                <i class="fas fa-shield-alt"></i> Support Terminal
            </span>

            <h1 class="hero-title">
                <span class="title-row1">Submit</span>
                <span class="title-row2">Complaint</span>
            </h1>
            <p class="hero-sub">Our team is standing by — describe your issue and we'll handle it fast.</p>

        </div>
    </div>
</div>

<section class="complaint-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <form method="post" enctype="multipart/form-data" id="complaint-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('new-complaint') }}">

                    {# ══ STEP 1 : CATEGORY ══ #}
                    <div class="gcard mb-4" style="--ci:1">
                        <div class="card-topline"></div>
                        <div class="gcard-head">
                            <span class="gstep">01</span>
                            <div>
                                <div class="gcard-title">Choose a Category</div>
                                <div class="gcard-sub">Select the type that best describes your issue</div>
                            </div>
                        </div>

                        <div class="category-grid mt-4">
                            {% for category in categories %}
                            <div class="cat-item">
                                <input type="radio"
                                       class="cat-radio"
                                       name="category"
                                       id="cat_{{ category.value }}"
                                       value="{{ category.value }}"
                                       required>
                                <label class="cat-card" for="cat_{{ category.value }}">
                                    <div class="cat-glow"></div>
                                    <div class="cat-corner tl"></div>
                                    <div class="cat-corner tr"></div>
                                    <div class="cat-corner bl"></div>
                                    <div class="cat-corner br"></div>
                                    <div class="cat-icon-wrap">
                                        {% set _cat = category.label|lower %}
                                        {% set _iconMap = {
                                            'network':              'fas fa-wifi',
                                            'réseau':               'fas fa-wifi',
                                            'billing':              'fas fa-file-invoice-dollar',
                                            'facturation':          'fas fa-file-invoice-dollar',
                                            'account':              'fas fa-user-circle',
                                            'compte':               'fas fa-user-circle',
                                            'account problem':      'fas fa-user-shield',
                                            'problème de compte':   'fas fa-user-shield',
                                            'gameplay':             'fas fa-gamepad',
                                            'jeu':                  'fas fa-gamepad',
                                            'game':                 'fas fa-dice',
                                            'tournament':           'fas fa-trophy',
                                            'tournoi':              'fas fa-trophy',
                                            'technical':            'fas fa-tools',
                                            'technique':            'fas fa-tools',
                                            'technical issue':      'fas fa-wrench',
                                            'bug':                  'fas fa-bug',
                                            'payment':              'fas fa-credit-card',
                                            'paiement':             'fas fa-credit-card',
                                            'chat':                 'fas fa-comments',
                                            'messagerie':           'fas fa-comment-dots',
                                            'performance':          'fas fa-tachometer-alt',
                                            'security':             'fas fa-shield-virus',
                                            'sécurité':             'fas fa-shield-virus',
                                            'connection':           'fas fa-plug',
                                            'connexion':            'fas fa-satellite-dish',
                                            'server':               'fas fa-server',
                                            'serveur':              'fas fa-server',
                                            'ban':                  'fas fa-ban',
                                            'suspension':           'fas fa-gavel',
                                            'cheating':             'fas fa-user-secret',
                                            'triche':               'fas fa-user-secret',
                                            'report':               'fas fa-flag',
                                            'signalement':          'fas fa-flag',
                                            'refund':               'fas fa-undo-alt',
                                            'remboursement':        'fas fa-undo-alt',
                                            'update':               'fas fa-sync-alt',
                                            'mise à jour':          'fas fa-sync-alt',
                                            'login':                'fas fa-sign-in-alt',
                                            'crash':                'fas fa-bomb',
                                            'lag':                  'fas fa-hourglass-half',
                                            'latence':              'fas fa-hourglass-half',
                                            'audio':                'fas fa-volume-mute',
                                            'son':                  'fas fa-volume-mute',
                                            'graphics':             'fas fa-photo-video',
                                            'graphismes':           'fas fa-photo-video',
                                            'purchase':             'fas fa-shopping-cart',
                                            'achat':                'fas fa-shopping-cart',
                                            'harassment':           'fas fa-hand-paper',
                                            'harcèlement':          'fas fa-hand-paper',
                                            'content violation':    'fas fa-exclamation-triangle',
                                            'violation':            'fas fa-exclamation-triangle',
                                            'inappropriate':        'fas fa-exclamation-triangle',
                                            'abuse':                'fas fa-skull-crossbones',
                                            'spam':                 'fas fa-envelope-open-text',
                                            'fraud':                'fas fa-user-slash',
                                            'fraude':               'fas fa-user-slash',
                                            'other':                'fas fa-question-circle',
                                            'autre':                'fas fa-question-circle',
                                        } %}
                                        {# Priorité : icône définie sur l'entité > correspondance exacte > correspondance partielle > fallback #}
                                        {% set catIcon = 'fas fa-tag' %}
                                        {% if category.icon is defined and category.icon starts with 'fa' %}
                                            {% set catIcon = category.icon %}
                                        {% elseif _iconMap[_cat] is defined %}
                                            {% set catIcon = _iconMap[_cat] %}
                                        {% else %}
                                            {% for key, icon in _iconMap %}
                                                {% if key in _cat and catIcon == 'fas fa-tag' %}
                                                    {% set catIcon = icon %}
                                                {% endif %}
                                            {% endfor %}
                                        {% endif %}
                                        <i class="{{ catIcon }}"></i>
                                    </div>
                                    <div class="cat-info">
                                        <strong class="cat-label">{{ category.label }}</strong>
                                        <span class="cat-desc">{{ category.description }}</span>
                                    </div>
                                    <div class="cat-badge">
                                        <i class="fas fa-check"></i>
                                    </div>
                                </label>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    {# ══ STEP 2 : SUBJECT ══ #}
                    <div class="gcard mb-4" style="--ci:2">
                        <div class="card-topline"></div>
                        <div class="gcard-head">
                            <span class="gstep">02</span>
                            <div>
                                <div class="gcard-title">Subject</div>
                                <div class="gcard-sub">Brief summary — 5 to 200 characters</div>
                            </div>
                        </div>
                        <div class="input-mic-wrapper mt-3">
                            <input type="text"
                                   class="g-input"
                                   id="subject"
                                   name="subject"
                                   placeholder="e.g. Cannot access my tournament page…"
                                   minlength="5" maxlength="200" required>
                            <button type="button" class="mic-btn" data-target="subject" title="Dictate">
                                <i class="fas fa-microphone"></i>
                            </button>
                        </div>
                        <div class="stt-feedback d-none" id="stt-feedback-subject">
                            <span class="stt-pulse"></span>
                            <span class="stt-label">Recording… click again to stop</span>
                        </div>
                    </div>

                    {# ══ STEP 3 : DESCRIPTION ══ #}
                    <div class="gcard mb-4" style="--ci:3">
                        <div class="card-topline"></div>
                        <div class="gcard-head">
                            <span class="gstep">03</span>
                            <div>
                                <div class="gcard-title">Description</div>
                                <div class="gcard-sub">Be as detailed as possible — helps us resolve faster</div>
                            </div>
                        </div>
                        <div class="input-mic-wrapper textarea-mic-wrapper mt-3">
                            <textarea class="g-input"
                                      id="description"
                                      name="description"
                                      rows="6"
                                      placeholder="Describe exactly what happened, when, and any steps you already tried…"
                                      minlength="10" required></textarea>
                            <button type="button" class="mic-btn mic-btn-textarea" data-target="description" title="Dictate">
                                <i class="fas fa-microphone"></i>
                            </button>
                        </div>
                        <div class="stt-feedback d-none" id="stt-feedback-description">
                            <span class="stt-pulse"></span>
                            <span class="stt-label">Recording… click again to stop</span>
                        </div>
                    </div>

                    {# ══ STEP 4 : ATTACHMENT ══ #}
                    <div class="gcard mb-4" style="--ci:4">
                        <div class="card-topline"></div>
                        <div class="gcard-head">
                            <span class="gstep">04</span>
                            <div>
                                <div class="gcard-title">Attachment <span class="opt-pill">Optional</span></div>
                                <div class="gcard-sub">Image, PDF or Word — max 5 MB</div>
                            </div>
                        </div>
                        <label class="drop-zone mt-3" for="attachment" id="drop-zone">
                            <div class="drop-zone-grid"></div>
                            <i class="fas fa-cloud-upload-alt drop-icon"></i>
                            <span class="drop-text">Drop file here or <u>browse</u></span>
                            <span class="drop-hint">PNG · JPG · PDF · DOC · DOCX</span>
                            <input type="file" class="d-none" id="attachment" name="attachment"
                                   accept="image/*,.pdf,.doc,.docx">
                        </label>
                        <div class="file-preview d-none" id="file-preview">
                            <i class="fas fa-file-alt"></i>
                            <span id="file-name"></span>
                            <button type="button" class="file-rm" id="file-remove"><i class="fas fa-times"></i></button>
                        </div>
                    </div>

                    {# ══ ACTIONS ══ #}
                    <div class="form-actions">
                        <a href="{{ path('app_complaints_index') }}" class="btn-ghost">
                            <i class="fas fa-arrow-left"></i> Back
                        </a>
                        <button type="submit" class="btn-fire">
                            <span class="btn-fire-bg"></span>
                            <span class="btn-fire-spark"></span>
                            <i class="fas fa-paper-plane"></i>
                            <span>Submit Complaint</span>
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

/* ═══════════════════════════════════════════
   EYE2WIN — SUBMIT COMPLAINT  [RED MAX]
═══════════════════════════════════════════ */
:root {
    --red:       #e8372a;
    --red-hot:   #ff4d3d;
    --red-glow:  rgba(232,55,42,0.4);
    --red-dim:   rgba(232,55,42,0.12);
    --orange:    #ff6b2b;
    --pink:      #ff2060;
    --dark:      #080810;
    --panel:     rgba(255,255,255,0.025);
    --border:    rgba(255,255,255,0.07);
    --border-r:  rgba(232,55,42,0.35);
    --text:      rgba(255,255,255,0.93);
    --muted:     rgba(255,255,255,0.38);
    --r:         10px;
    --font-hud:  'Orbitron', sans-serif;
    --font-body: 'Rajdhani', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;
}

body { background: var(--dark); font-family: var(--font-body); }

/* ══ HERO ══ */
.complaint-page-hero {
    position: relative;
    background: linear-gradient(165deg, #1a0308 0%, #0c0b18 50%, #080810 100%);
    border-bottom: 1px solid transparent;
    padding: 4rem 0 3.5rem;
    overflow: hidden;
}
.complaint-page-hero::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
    background-size: 300% 100%;
    animation: border-shimmer 4s linear infinite;
}
@keyframes border-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

#heroCanvas {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    width: 100%; height: 100%;
}
.hero-grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(232,55,42,0.055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.055) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: grid-pulse 6s ease-in-out infinite;
}
@keyframes grid-pulse { 0%,100%{opacity:1} 50%{opacity:0.45} }

.hero-scanline {
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.055) 2px, rgba(0,0,0,0.055) 4px);
    animation: scanline-move 8s linear infinite;
}
@keyframes scanline-move { from{background-position:0 0} to{background-position:0 100px} }

.hero-vignette {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 35%, rgba(0,0,0,0.65) 100%);
}

.hero-inner { position: relative; z-index: 3; }

/* Badge */
.hero-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(232,55,42,0.09); border: 1px solid rgba(232,55,42,0.28);
    color: var(--red-hot); font-family: var(--font-hud);
    font-size: .62rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
    padding: .32rem .9rem; border-radius: 3px; margin-bottom: 1.4rem;
    animation: badge-in .5s .1s both;
}
@keyframes badge-in { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:none} }

.hero-tag-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #3dff8a; box-shadow: 0 0 8px #3dff8a;
    animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

/* Title */
.hero-title {
    font-family: var(--font-hud); font-weight: 900;
    font-size: clamp(2.6rem, 5.5vw, 4.5rem);
    line-height: .95; letter-spacing: .05em; margin-bottom: 1rem;
    animation: title-in .6s .2s both cubic-bezier(.22,1,.36,1);
}
@keyframes title-in { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }

.title-row1 { display: block; color: rgba(255,255,255,0.93); }
.title-row2 {
    display: block;
    background: linear-gradient(90deg, var(--red) 0%, var(--orange) 50%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    background-size: 200% 100%;
    animation: gradient-pan 5s ease-in-out infinite alternate, title-in .6s .2s both cubic-bezier(.22,1,.36,1);
    filter: drop-shadow(0 0 30px rgba(232,55,42,0.4));
}
@keyframes gradient-pan { from{background-position:0%} to{background-position:100%} }

.hero-sub {
    color: var(--muted); font-size: 1rem; max-width: 480px; line-height: 1.65; margin-bottom: 0;
    animation: sub-in .5s .4s both;
}
@keyframes sub-in { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }

/* ══ SECTION ══ */
.complaint-section { background: var(--dark); min-height: 60vh; }

/* ══ GLASS CARD ══ */
.gcard {
    background: rgba(6,5,16,0.85);
    border: 1px solid rgba(255,255,255,0.065);
    border-radius: var(--r);
    padding: 1.75rem 2rem;
    position: relative; overflow: hidden;
    backdrop-filter: blur(10px);
    transition: border-color .3s, box-shadow .3s;

    opacity: 0; transform: translateY(20px);
    animation: card-enter .5s calc(var(--ci,1) * 100ms) forwards cubic-bezier(.22,1,.36,1);
}
@keyframes card-enter { to { opacity:1; transform:none; } }

.gcard:focus-within {
    border-color: rgba(232,55,42,0.3);
    box-shadow: 0 0 0 1px rgba(232,55,42,0.08), 0 16px 48px rgba(0,0,0,0.4);
}

/* Racing top line */
.card-topline {
    position: absolute; top: 0; left: 0; right: 0; height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
    background-size: 200% 100%;
    opacity: 0; transition: opacity .3s;
}
.gcard:focus-within .card-topline {
    opacity: 1;
    animation: topline-race 1.4s linear infinite;
}
@keyframes topline-race {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
}

/* Left bar on focus */
.gcard::after {
    content: ''; position: absolute; left: 0; top: 10%; bottom: 10%; width: 3px;
    background: linear-gradient(180deg, transparent, var(--red), var(--orange), transparent);
    border-radius: 0 2px 2px 0;
    opacity: 0; transform: scaleY(0);
    transition: opacity .3s, transform .35s cubic-bezier(.22,1,.36,1);
}
.gcard:focus-within::after { opacity: 1; transform: scaleY(1); }

.gcard-head { display: flex; align-items: flex-start; gap: 1rem; }

.gstep {
    flex-shrink: 0; width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    background: var(--red-dim); border: 1px solid var(--border-r); border-radius: 8px;
    font-family: var(--font-hud); font-size: .65rem; font-weight: 800;
    color: var(--red); letter-spacing: .08em;
    transition: background .2s, box-shadow .2s;
}
.gcard:focus-within .gstep {
    background: rgba(232,55,42,0.2);
    box-shadow: 0 0 14px rgba(232,55,42,0.25);
}

.gcard-title {
    font-family: var(--font-hud); font-size: .9rem; font-weight: 700;
    color: var(--text); line-height: 1.3; letter-spacing: .04em;
}
.gcard-sub { font-family: var(--font-mono); font-size: .72rem; color: var(--muted); margin-top: .2rem; }

/* ══ CATEGORY GRID ══ */
.category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: .85rem;
    align-items: stretch;
}
.cat-item { position: relative; display: flex; }
.cat-radio { position: absolute; opacity: 0; pointer-events: none; }

.cat-card {
    display: flex; align-items: center; gap: .9rem;
    padding: 1rem 1.1rem;
    width: 100%; height: 100%; min-height: 78px;
    background: rgba(255,255,255,0.022);
    border: 1px solid rgba(255,255,255,0.065);
    border-radius: 10px; cursor: pointer;
    position: relative; overflow: hidden;
    transition: border-color .22s, background .22s, transform .2s, box-shadow .22s;
}
.cat-card:hover {
    border-color: rgba(232,55,42,0.35);
    background: rgba(232,55,42,0.06);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

/* Sweep on hover */
.cat-card::before {
    content: ''; position: absolute; top:0; bottom:0; width:60px;
    background: linear-gradient(90deg, transparent, rgba(232,55,42,0.06), transparent);
    left: -60px; pointer-events: none;
    transition: none;
}
.cat-card:hover::before { animation: cat-sweep .45s ease-out forwards; }
@keyframes cat-sweep { to { left: 110%; } }

/* Corners */
.cat-corner {
    position: absolute; width: 7px; height: 7px;
    border-color: var(--red); border-style: solid;
    opacity: 0; transform: scale(1.5); transition: opacity .22s, transform .25s;
}
.cat-corner.tl { top:4px;    left:4px;  border-width:1.5px 0 0 1.5px; }
.cat-corner.tr { top:4px;    right:4px; border-width:1.5px 1.5px 0 0; }
.cat-corner.bl { bottom:4px; left:4px;  border-width:0 0 1.5px 1.5px; }
.cat-corner.br { bottom:4px; right:4px; border-width:0 1.5px 1.5px 0; }
.cat-card:hover .cat-corner { opacity: 1; transform: scale(1); }

/* Glow */
.cat-glow {
    position: absolute; width: 80px; height: 80px; border-radius: 50%;
    background: radial-gradient(circle, rgba(232,55,42,0.25), transparent 70%);
    top: -20px; right: -20px;
    opacity: 0; transition: opacity .3s; pointer-events: none;
}

/* SELECTED */
.cat-radio:checked + .cat-card {
    border-color: var(--red);
    background: rgba(232,55,42,0.1);
    box-shadow: 0 0 0 1px rgba(232,55,42,0.2), 0 8px 28px rgba(232,55,42,0.18);
}
.cat-radio:checked + .cat-card .cat-glow { opacity: 1; }
.cat-radio:checked + .cat-card .cat-corner { opacity: 1; transform: scale(1); }
.cat-radio:checked + .cat-card .cat-icon-wrap {
    background: rgba(232,55,42,0.2); border-color: rgba(232,55,42,0.5); color: #ff7055;
    box-shadow: 0 0 16px rgba(232,55,42,0.2);
}
.cat-radio:checked + .cat-card .cat-badge { opacity: 1; transform: scale(1); }

.cat-icon-wrap {
    flex-shrink: 0; width: 44px; height: 44px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; color: rgba(255,255,255,0.35); transition: all .22s;
}
.cat-card:hover .cat-icon-wrap {
    background: rgba(232,55,42,0.1); border-color: rgba(232,55,42,0.25); color: #ff7055;
}
.cat-info { flex: 1; display: flex; flex-direction: column; gap: .12rem; min-width: 0; }
.cat-label { font-family: var(--font-body); font-size: .9rem; font-weight: 700; color: var(--text); }
.cat-desc { font-family: var(--font-body); font-size: .74rem; color: var(--muted); line-height: 1.4; word-break: break-word; }
.cat-badge {
    flex-shrink: 0; width: 20px; height: 20px;
    background: var(--red); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .58rem; color: #fff;
    opacity: 0; transform: scale(.4);
    transition: opacity .2s, transform .28s cubic-bezier(.34,1.56,.64,1);
    box-shadow: 0 0 10px rgba(232,55,42,0.5);
}

/* ══ INPUTS ══ */
.g-input {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 9px;
    color: var(--text);
    font-family: var(--font-body); font-size: .95rem;
    padding: .78rem 3rem .78rem 1rem;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
    resize: vertical;
}
.g-input:focus {
    background: rgba(232,55,42,0.04);
    border-color: rgba(232,55,42,0.5);
    box-shadow: 0 0 0 3px rgba(232,55,42,0.1);
}
.g-input::placeholder { color: var(--muted); font-family: var(--font-body); }
.g-input.is-listening {
    border-color: rgba(255,77,77,0.6) !important;
    box-shadow: 0 0 0 3px rgba(255,77,77,0.1) !important;
}

/* ══ MIC ══ */
.input-mic-wrapper { position: relative; display: flex; align-items: center; }
.textarea-mic-wrapper { align-items: flex-start; }

.mic-btn {
    position: absolute; right: .65rem; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.4); font-size: .85rem;
    padding: .35rem .45rem; border-radius: 7px;
    cursor: pointer; transition: all .2s; line-height: 1; z-index: 5;
}
.mic-btn-textarea { top: .65rem; transform: none; }
.mic-btn:hover { color: #fff; background: rgba(232,55,42,0.15); border-color: rgba(232,55,42,0.4); }
.mic-btn.is-recording {
    color: #ff4d4d; background: rgba(255,77,77,0.12); border-color: rgba(255,77,77,0.3);
    animation: mic-glow 1.4s ease-in-out infinite;
}
.mic-btn.is-transcribing {
    color: #ffc107; background: rgba(255,193,7,0.1); border-color: rgba(255,193,7,0.25);
}
.mic-btn:disabled { opacity: .35; cursor: not-allowed; }
@keyframes mic-glow {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,77,77,.5); }
    50%     { box-shadow: 0 0 0 7px rgba(255,77,77,0); }
}

.stt-feedback {
    display: flex; align-items: center; gap: .5rem;
    margin-top: .4rem; font-family: var(--font-mono); font-size: .72rem; color: #ff7070;
}
.stt-feedback.transcribing .stt-label { color: #ffc107; }
.stt-pulse {
    display: inline-block; width: 7px; height: 7px; border-radius: 50%;
    background: #ff4d4d; flex-shrink: 0;
    animation: dot-blink 1s ease-in-out infinite;
}
.stt-feedback.transcribing .stt-pulse { background: #ffc107; animation: none; }
@keyframes dot-blink { 0%,100%{opacity:1} 50%{opacity:.1} }

/* ══ OPT PILL ══ */
.opt-pill {
    font-family: var(--font-mono); font-size: .6rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .08em;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    color: var(--muted); padding: .12rem .5rem; border-radius: 20px;
    margin-left: .5rem; vertical-align: middle;
}

/* ══ DROP ZONE ══ */
.drop-zone {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: .35rem; padding: 2.5rem 2rem;
    background: rgba(255,255,255,0.02);
    border: 1.5px dashed rgba(255,255,255,0.09);
    border-radius: 10px; cursor: pointer; text-align: center;
    position: relative; overflow: hidden;
    transition: background .22s, border-color .22s, box-shadow .22s;
}
.drop-zone-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
        linear-gradient(rgba(232,55,42,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.03) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0; transition: opacity .3s;
}
.drop-zone:hover .drop-zone-grid,
.drop-zone.drag-over .drop-zone-grid { opacity: 1; }

.drop-zone:hover,
.drop-zone.drag-over {
    background: rgba(232,55,42,0.06);
    border-color: rgba(232,55,42,0.4);
    box-shadow: 0 0 30px rgba(232,55,42,0.06);
}
.drop-icon {
    font-size: 2.2rem; color: rgba(255,255,255,0.18); margin-bottom: .3rem;
    position: relative; z-index: 1;
    transition: color .22s, transform .22s;
}
.drop-zone:hover .drop-icon {
    color: rgba(232,55,42,0.5); transform: translateY(-4px);
}
.drop-text {
    font-family: var(--font-body); font-size: .88rem;
    color: rgba(255,255,255,0.5); position: relative; z-index: 1;
}
.drop-text u { color: var(--red-hot); text-decoration-color: rgba(232,55,42,0.5); }
.drop-hint {
    font-family: var(--font-mono); font-size: .65rem;
    color: var(--muted); position: relative; z-index: 1; letter-spacing: .06em;
}

.file-preview {
    display: flex; align-items: center; gap: .75rem; margin-top: .6rem;
    background: rgba(232,55,42,0.08); border: 1px solid rgba(232,55,42,0.25);
    border-radius: 8px; padding: .6rem 1rem;
    font-family: var(--font-body); font-size: .85rem; color: rgba(255,255,255,0.75);
}
.file-preview i { color: var(--red); }
.file-rm {
    background: none; border: none; color: var(--muted); cursor: pointer;
    margin-left: auto; padding: 0; line-height: 1; transition: color .2s;
}
.file-rm:hover { color: #ff6b6b; }

/* ══ FORM ACTIONS ══ */
.form-actions {
    display: flex; gap: 1rem; justify-content: flex-end; align-items: center;
    margin-top: 1.5rem;
}

.btn-ghost {
    display: inline-flex; align-items: center; gap: .5rem; padding: .68rem 1.3rem;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 9px; color: rgba(255,255,255,0.55);
    font-family: var(--font-hud); font-size: .72rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase; text-decoration: none;
    transition: all .2s;
}
.btn-ghost:hover {
    background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9);
}

.btn-fire {
    position: relative; overflow: hidden;
    display: inline-flex; align-items: center; gap: .6rem; padding: .72rem 2rem;
    background: linear-gradient(135deg, #b02b20, #e8372a, #ff5533);
    border: none; border-radius: 9px; color: #fff;
    font-family: var(--font-hud); font-size: .8rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; cursor: pointer;
    box-shadow: 0 4px 24px rgba(232,55,42,0.45);
    transition: transform .18s, box-shadow .18s;
}
.btn-fire:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 36px rgba(232,55,42,0.6), 0 0 0 3px rgba(232,55,42,0.15);
    color: #fff;
}
.btn-fire:active { transform: translateY(-1px); }
.btn-fire-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.15), transparent);
    pointer-events: none;
}
.btn-fire-spark {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 50% -20%, rgba(255,180,100,.28) 0%, transparent 60%);
}

/* ══ RESPONSIVE ══ */
@media (max-width: 640px) {
    .complaint-page-hero { padding: 3rem 0 2.5rem; }
    .hero-title { font-size: 2.4rem; }
    .gcard { padding: 1.25rem 1.1rem; }
    .category-grid { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column-reverse; }
    .btn-ghost, .btn-fire { width: 100%; justify-content: center; }
}
</style>

<script>
(function () {
    'use strict';
    const TRANSCRIBE_URL = '{{ path("app_speech_transcribe") }}';

    /* ── PARTICLE CANVAS ── */
    const canvas = document.getElementById('heroCanvas');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];

        function resize() {
            const hero = canvas.parentElement;
            W = canvas.width  = hero.offsetWidth;
            H = canvas.height = hero.offsetHeight;
        }
        resize();
        window.addEventListener('resize', () => { resize(); spawnAll(); });

        const COLORS = ['rgba(232,55,42,', 'rgba(255,107,43,', 'rgba(255,77,61,', 'rgba(255,32,96,'];

        function mkParticle() {
            const c = COLORS[Math.floor(Math.random() * COLORS.length)];
            return {
                x: Math.random() * W, y: H + Math.random() * 60,
                vx: (Math.random() - .5) * .55, vy: -(0.3 + Math.random() * 1.0),
                r: 0.8 + Math.random() * 1.5, alpha: 0,
                maxAlpha: 0.25 + Math.random() * 0.45,
                phase: Math.random() * Math.PI * 2, color: c,
                life: 0, maxLife: 130 + Math.random() * 160,
            };
        }
        function spawnAll() { particles = Array.from({ length: 38 }, mkParticle); }
        spawnAll();

        function tick() {
            ctx.clearRect(0, 0, W, H);
            particles.forEach((p, i) => {
                p.life++;
                p.x += p.vx + Math.sin(p.phase + p.life * 0.02) * 0.25;
                p.y += p.vy;
                const t = p.life / p.maxLife;
                p.alpha = t < 0.15 ? (t/0.15)*p.maxAlpha : t > 0.75 ? ((1-t)/0.25)*p.maxAlpha : p.maxAlpha;
                if (p.life >= p.maxLife || p.y < -10) particles[i] = mkParticle();
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = p.color + p.alpha + ')';
                ctx.shadowColor = p.color + '0.5)';
                ctx.shadowBlur = 7;
                ctx.fill();
            });
            requestAnimationFrame(tick);
        }
        tick();

        /* Title glitch */
        const accent = document.querySelector('.title-row2');
        if (accent) {
            setInterval(() => {
                if (Math.random() > 0.82) {
                    accent.animate([
                        { transform: 'none', filter: 'none' },
                        { transform: 'skewX(-3deg) translateX(-2px)', filter: 'hue-rotate(30deg) brightness(1.4)' },
                        { transform: 'skewX(2deg) translateX(3px)', filter: 'hue-rotate(-20deg)' },
                        { transform: 'none', filter: 'none' },
                    ], { duration: 160, easing: 'steps(3)' });
                }
            }, 3000);
        }
    }

    /* ── STAGGER OBSERVER ── */
    if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) { e.target.style.animationPlayState = 'running'; io.unobserve(e.target); }
            });
        }, { threshold: 0.05 });
        document.querySelectorAll('.gcard').forEach(c => {
            c.style.animationPlayState = 'paused'; io.observe(c);
        });
    }

    /* ── SPEECH-TO-TEXT ── */
    if (!navigator.mediaDevices || !window.MediaRecorder) {
        document.querySelectorAll('.mic-btn').forEach(b => b.remove());
    } else {
        let mediaRecorder = null, audioChunks = [], activeTarget = null, micStream = null;
        const getFeedback = id => document.getElementById('stt-feedback-' + id);
        const getMicBtn   = id => document.querySelector(`.mic-btn[data-target="${id}"]`);
        const getField    = id => document.getElementById(id);

        function setRecordingUI(id, on) {
            const btn = getMicBtn(id), field = getField(id), fb = getFeedback(id);
            if (on) {
                btn.classList.add('is-recording'); btn.innerHTML = '<i class="fas fa-stop"></i>';
                field.classList.add('is-listening'); fb.classList.remove('d-none','transcribing');
                fb.querySelector('.stt-label').textContent = 'Recording… click again to stop';
            } else {
                btn.classList.remove('is-recording'); btn.innerHTML = '<i class="fas fa-microphone"></i>';
                field.classList.remove('is-listening');
            }
        }
        function setTranscribingUI(id) {
            const btn = getMicBtn(id), fb = getFeedback(id);
            btn.classList.remove('is-recording'); btn.classList.add('is-transcribing');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; btn.disabled = true;
            fb.classList.add('transcribing'); fb.querySelector('.stt-label').textContent = 'Transcribing…';
        }
        function resetUI(id) {
            const btn = getMicBtn(id), fb = getFeedback(id);
            btn.classList.remove('is-recording','is-transcribing');
            btn.innerHTML = '<i class="fas fa-microphone"></i>'; btn.disabled = false;
            fb.classList.add('d-none'); fb.classList.remove('transcribing');
        }
        async function startRecording(targetId) {
            try { micStream = await navigator.mediaDevices.getUserMedia({ audio: true }); }
            catch { alert('Microphone access denied.'); return; }
            audioChunks = []; activeTarget = targetId;
            const mime = ['audio/webm;codecs=opus','audio/webm','audio/ogg',''].find(t => t===''||MediaRecorder.isTypeSupported(t));
            mediaRecorder = new MediaRecorder(micStream, mime ? { mimeType: mime } : {});
            mediaRecorder.ondataavailable = e => { if (e.data?.size > 0) audioChunks.push(e.data); };
            mediaRecorder.onstop = async () => {
                micStream.getTracks().forEach(t => t.stop()); micStream = null;
                const blob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
                audioChunks = []; setTranscribingUI(targetId);
                await sendToServer(blob, targetId); resetUI(targetId); activeTarget = null; mediaRecorder = null;
            };
            mediaRecorder.start(250); setRecordingUI(targetId, true);
        }
        function stopRecording(targetId) {
            if (!mediaRecorder || mediaRecorder.state === 'inactive') return;
            setRecordingUI(targetId, false); mediaRecorder.stop();
        }
        async function sendToServer(blob, targetId, retryCount = 0) {
            const field = getField(targetId), formData = new FormData();
            formData.append('audio', blob, 'recording.webm');
            try {
                const res = await fetch(TRANSCRIBE_URL, { method:'POST', body:formData, credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest'} });
                const ct = res.headers.get('content-type') || '';
                if (!ct.includes('application/json')) { alert('Session expired. Please refresh.'); return; }
                const data = await res.json();
                if (res.status === 503 && retryCount < 1) {
                    const wait = (data.retry_after ?? 20) * 1000;
                    getFeedback(targetId).querySelector('.stt-label').textContent = `Retrying in ${Math.ceil(wait/1000)}s…`;
                    await new Promise(r => setTimeout(r, wait));
                    return sendToServer(blob, targetId, retryCount + 1);
                }
                if (!res.ok) { alert('Error: ' + JSON.stringify(data.error || data)); return; }
                const text = (data.text || '').trim();
                if (text) {
                    const cur = field.value.trimEnd();
                    field.value = cur ? cur + ' ' + text : text;
                    if (field.tagName === 'TEXTAREA') field.scrollTop = field.scrollHeight;
                    field.dispatchEvent(new Event('input', { bubbles: true }));
                } else { alert('No speech detected. Try again.'); }
            } catch(err) { console.error(err); alert('Cannot reach server.'); }
        }
        document.querySelectorAll('.mic-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const t = btn.dataset.target;
                if (activeTarget === t) stopRecording(t);
                else if (activeTarget) { stopRecording(activeTarget); setTimeout(() => startRecording(t), 400); }
                else await startRecording(t);
            });
        });
    }

    /* ── FILE DROP ZONE ── */
    const fileInput   = document.getElementById('attachment');
    const dropZone    = document.getElementById('drop-zone');
    const filePreview = document.getElementById('file-preview');
    const fileNameEl  = document.getElementById('file-name');
    const fileRemove  = document.getElementById('file-remove');

    function showFile(file) {
        if (file.size > 5*1024*1024) { alert('File size must be less than 5MB'); fileInput.value=''; return; }
        fileNameEl.textContent = file.name;
        filePreview.classList.remove('d-none');
        dropZone.style.display = 'none';
    }
    fileInput.addEventListener('change', e => { if (e.target.files[0]) showFile(e.target.files[0]); });
    fileRemove.addEventListener('click', () => { fileInput.value=''; filePreview.classList.add('d-none'); dropZone.style.display=''; });
    dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
        e.preventDefault(); dropZone.classList.remove('drag-over');
        const f = e.dataTransfer.files[0];
        if (f) { fileInput.files = e.dataTransfer.files; showFile(f); }
    });

})();
</script>

{% endblock %}
