{% extends 'base.html.twig' %}

{% block title %}Complaint #{{ complaint.id }}{% endblock %}

{% block body %}

{# ── Page Hero ── #}
<div class="complaint-page-hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-scanline"></div>
    <div class="container position-relative">
        <div class="hero-inner">
            <span class="hero-tag"><i class="fas fa-ticket-alt"></i> Support</span>
            <h1 class="hero-title">Ticket <span class="hero-accent">#{{ complaint.id }}</span></h1>
            <p class="hero-sub">{{ complaint.subject }}</p>
        </div>
    </div>
</div>

<section class="complaint-section py-5">
    <div class="container">

        {# Back #}
        <div class="mb-4">
            <a href="{{ path('app_complaints_index') }}" class="btn-ghost">
                <i class="fas fa-arrow-left"></i> Back to My Complaints
            </a>
        </div>

        <div class="row g-4">

            {# ══ LEFT COLUMN ══ #}
            <div class="col-lg-8">

                {# ── Main Complaint Card ── #}
                <div class="gcard mb-4">
                    <div class="gcard-head mb-4">
                        <div class="cat-icon-wrap-lg">
                            <i class="{{ complaint.category.icon }}"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="gcard-title fs-5">{{ complaint.subject }}</div>
                            <div class="d-flex gap-2 flex-wrap mt-2">
                                <span class="tbadge tbadge-{{ complaint.status.badgeClass }}">
                                    <i class="{{ complaint.status.icon }}"></i>
                                    {{ complaint.status.label }}
                                </span>
                                <span class="tbadge tbadge-priority-{{ complaint.priority.badgeClass }}">
                                    <i class="{{ complaint.priority.icon }}"></i>
                                    {{ complaint.priority.label }}
                                </span>
                                <span class="tbadge tbadge-cat">
                                    <i class="{{ complaint.category.icon }}"></i>
                                    {{ complaint.category.label }}
                                </span>
                            </div>
                        </div>
                        <span class="ticket-id-pill">#{{ complaint.id }}</span>
                    </div>

                    <div class="g-divider mb-4"></div>

                    {# Description #}
                    <div class="detail-block mb-4">
                        <div class="detail-block-title">
                            <i class="fas fa-file-alt"></i> Description
                        </div>
                        <div class="detail-block-content">
                            {{ complaint.description|nl2br }}
                        </div>
                    </div>

                    {# Attachment #}
                    {% if complaint.attachmentPath %}
                    <div class="g-divider mb-4"></div>
                    <div class="detail-block mb-4">
                        <div class="detail-block-title">
                            <i class="fas fa-paperclip"></i> Attachment
                        </div>
                        <a href="{{ asset('uploads/complaints/' ~ complaint.attachmentPath) }}"
                           class="btn-attachment" target="_blank">
                            <i class="fas fa-download"></i>
                            <span>Download Attachment</span>
                        </a>
                    </div>
                    {% endif %}

                    {# Admin Response #}
                    {% if complaint.adminResponse %}
                    <div class="g-divider mb-4"></div>
                    <div class="detail-block mb-4">
                        <div class="detail-block-title">
                            <i class="fas fa-reply"></i> Support Response
                        </div>
                        <div class="response-box response-info">
                            <div class="response-box-icon"><i class="fas fa-headset"></i></div>
                            <div>{{ complaint.adminResponse|nl2br }}</div>
                        </div>
                    </div>
                    {% endif %}

                    {# Resolution #}
                    {% if complaint.resolutionNotes %}
                    <div class="g-divider mb-4"></div>
                    <div class="detail-block">
                        <div class="detail-block-title">
                            <i class="fas fa-check-circle"></i> Resolution
                        </div>
                        <div class="response-box response-success">
                            <div class="response-box-icon"><i class="fas fa-check-circle"></i></div>
                            <div>
                                <strong class="d-block mb-1">This complaint has been resolved</strong>
                                {{ complaint.resolutionNotes|nl2br }}
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>

                {# ── Timeline Card ── #}
                <div class="gcard">
                    <div class="gcard-head mb-4">
                        <span class="gstep"><i class="fas fa-clock"></i></span>
                        <div>
                            <div class="gcard-title">Timeline</div>
                            <div class="gcard-sub">History of your ticket</div>
                        </div>
                    </div>

                    <div class="timeline">
                        <div class="tl-item">
                            <div class="tl-dot tl-primary"><i class="fas fa-paper-plane"></i></div>
                            <div class="tl-content">
                                <strong>Complaint Submitted</strong>
                                <span>{{ complaint.createdAt|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>

                        {% if complaint.updatedAt %}
                        <div class="tl-item">
                            <div class="tl-dot tl-info"><i class="fas fa-sync-alt"></i></div>
                            <div class="tl-content">
                                <strong>Last Updated</strong>
                                <span>{{ complaint.updatedAt|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                        {% endif %}

                        {% if complaint.assignedTo %}
                        <div class="tl-item">
                            <div class="tl-dot tl-warning"><i class="fas fa-user-headset"></i></div>
                            <div class="tl-content">
                                <strong>Assigned to Support Team</strong>
                                <span>Your complaint is being reviewed</span>
                            </div>
                        </div>
                        {% endif %}

                        {% if complaint.resolvedAt %}
                        <div class="tl-item">
                            <div class="tl-dot tl-success"><i class="fas fa-check"></i></div>
                            <div class="tl-content">
                                <strong>Resolved</strong>
                                <span>{{ complaint.resolvedAt|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>

            </div>

            {# ══ RIGHT COLUMN ══ #}
            <div class="col-lg-4">

                {# ── Info Card ── #}
                <div class="gcard mb-4">
                    <div class="gcard-head mb-4">
                        <span class="gstep"><i class="fas fa-info"></i></span>
                        <div>
                            <div class="gcard-title">Information</div>
                        </div>
                    </div>

                    <div class="info-list">
                        <div class="info-row-item">
                            <span class="info-label">Status</span>
                            <span class="tbadge tbadge-{{ complaint.status.badgeClass }}">
                                <i class="{{ complaint.status.icon }}"></i>
                                {{ complaint.status.label }}
                            </span>
                        </div>
                        <div class="info-row-item">
                            <span class="info-label">Priority</span>
                            <span class="tbadge tbadge-priority-{{ complaint.priority.badgeClass }}">
                                <i class="{{ complaint.priority.icon }}"></i>
                                {{ complaint.priority.label }}
                            </span>
                        </div>
                        <div class="info-row-item">
                            <span class="info-label">Category</span>
                            <span class="info-val">{{ complaint.category.label }}</span>
                        </div>
                        <div class="info-row-item">
                            <span class="info-label">Submitted</span>
                            <span class="info-val">{{ complaint.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        {% if complaint.assignedTo %}
                        <div class="info-row-item">
                            <span class="info-label">Assigned</span>
                            <span class="info-val info-success"><i class="fas fa-check-circle"></i> Support Team</span>
                        </div>
                        {% endif %}
                        {% if complaint.resolvedAt %}
                        <div class="info-row-item">
                            <span class="info-label">Resolved</span>
                            <span class="info-val">{{ complaint.resolvedAt|date('d/m/Y H:i') }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>

                {# ── Actions Card ── #}
                {% if complaint.isPending %}
                <div class="gcard gcard-danger mb-4">
                    <div class="gcard-head mb-4">
                        <span class="gstep gstep-danger"><i class="fas fa-cog"></i></span>
                        <div>
                            <div class="gcard-title">Actions</div>
                        </div>
                    </div>

                    <form method="post" action="{{ path('app_complaints_delete', {id: complaint.id}) }}"
                          onsubmit="return confirm('Are you sure you want to delete this complaint?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-complaint-' ~ complaint.id) }}">
                        <button type="submit" class="btn-delete w-100">
                            <i class="fas fa-trash"></i> Delete Complaint
                        </button>
                    </form>
                    <p class="delete-hint mt-2">
                        <i class="fas fa-info-circle"></i> You can only delete pending complaints
                    </p>
                </div>
                {% endif %}

                {# ── Help Card ── #}

            </div>

        </div>
    </div>
</section>

<style>
/* ═══════════════════════════════════════════
   EYE2WIN — COMPLAINT SHOW
═══════════════════════════════════════════ */
:root {
    --red:      #e8372a;
    --red-glow: rgba(232,55,42,0.35);
    --red-dim:  rgba(232,55,42,0.12);
    --dark:     #0d0d0f;
    --panel:    rgba(255,255,255,0.03);
    --border:   rgba(255,255,255,0.07);
    --border-r: rgba(232,55,42,0.35);
    --text:     rgba(255,255,255,0.9);
    --muted:    rgba(255,255,255,0.4);
    --r:        12px;
}

/* ── HERO ── */
.complaint-page-hero {
    position: relative;
    background: linear-gradient(160deg, #1a0505 0%, #0d0d0f 60%);
    border-bottom: 1px solid rgba(232,55,42,0.2);
    padding: 3.5rem 0 3rem;
    overflow: hidden;
}
.hero-grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(232,55,42,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.06) 1px, transparent 1px);
    background-size: 40px 40px;
}
.hero-scanline {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.07) 2px, rgba(0,0,0,0.07) 4px);
    pointer-events: none;
}
.hero-inner { position: relative; z-index: 1; }
.hero-tag {
    display: inline-flex; align-items: center; gap: .45rem;
    background: var(--red-dim); border: 1px solid var(--border-r); color: var(--red);
    font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    padding: .3rem .8rem; border-radius: 4px; margin-bottom: 1rem;
}
.hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; letter-spacing: -.01em;
    color: #fff; margin: 0 0 .6rem; line-height: 1.1;
    text-shadow: 0 0 40px rgba(232,55,42,0.3);
}
.hero-accent { color: var(--red); }
.hero-sub { color: var(--muted); font-size: .92rem; max-width: 520px; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── SECTION ── */
.complaint-section { background: var(--dark); min-height: 60vh; }

/* ── BACK BUTTON ── */
.btn-ghost {
    display: inline-flex; align-items: center; gap: .5rem; padding: .6rem 1.2rem;
    background: rgba(255,255,255,0.04); border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 9px; color: rgba(255,255,255,0.55);
    font-size: .85rem; font-weight: 500; text-decoration: none; transition: all .2s;
}
.btn-ghost:hover {
    background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.85);
}

/* ── GLASS CARD ── */
.gcard {
    background: var(--panel); border: 1px solid var(--border);
    border-radius: var(--r); padding: 1.75rem 2rem;
    position: relative; overflow: hidden;
}
.gcard::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, rgba(232,55,42,0.4), transparent);
}
.gcard-danger { border-color: rgba(232,55,42,0.2); }

.gcard-head { display: flex; align-items: flex-start; gap: 1rem; }
.gstep {
    flex-shrink: 0; width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: var(--red-dim); border: 1px solid var(--border-r); border-radius: 8px;
    font-size: .75rem; font-weight: 800; color: var(--red);
}
.gstep-danger { background: rgba(232,55,42,0.15); border-color: rgba(232,55,42,0.4); }
.gcard-title { font-size: 1rem; font-weight: 700; color: var(--text); line-height: 1.3; }
.gcard-sub   { font-size: .78rem; color: var(--muted); margin-top: .15rem; }

/* Big category icon */
.cat-icon-wrap-lg {
    flex-shrink: 0; width: 54px; height: 54px;
    background: rgba(232,55,42,0.1); border: 1px solid rgba(232,55,42,0.25);
    border-radius: 13px; display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: #ff6b4a;
}
.ticket-id-pill {
    flex-shrink: 0; align-self: flex-start;
    font-size: .72rem; font-weight: 700; letter-spacing: .06em;
    color: var(--muted); background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08); padding: .3rem .7rem; border-radius: 6px;
}

/* ── DIVIDER ── */
.g-divider { border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 0; }

/* ── DETAIL BLOCK ── */
.detail-block-title {
    font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
    color: rgba(232,55,42,0.8); margin-bottom: .75rem;
    display: flex; align-items: center; gap: .4rem;
}
.detail-block-content {
    font-size: .9rem; color: rgba(255,255,255,0.8); line-height: 1.75;
}

/* ── RESPONSE BOXES ── */
.response-box {
    display: flex; align-items: flex-start; gap: .9rem;
    padding: 1rem 1.25rem; border-radius: 9px;
    font-size: .88rem; line-height: 1.65;
}
.response-box-icon { flex-shrink: 0; font-size: 1.1rem; margin-top: .1rem; }
.response-info {
    background: rgba(13,202,240,0.08); border: 1px solid rgba(13,202,240,0.2); color: #cde8f0;
}
.response-info .response-box-icon { color: #0dcaf0; }
.response-success {
    background: rgba(25,135,84,0.08); border: 1px solid rgba(25,135,84,0.25); color: #c3f0d3;
}
.response-success .response-box-icon { color: #3dd68c; }

/* ── ATTACHMENT BTN ── */
.btn-attachment {
    display: inline-flex; align-items: center; gap: .55rem;
    padding: .6rem 1.2rem; background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12); border-radius: 9px;
    color: rgba(255,255,255,0.7); font-size: .85rem; font-weight: 600;
    text-decoration: none; transition: all .2s;
}
.btn-attachment:hover {
    background: rgba(232,55,42,0.1); border-color: rgba(232,55,42,0.3); color: #fff;
}

/* ── BADGES ── */
.tbadge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .68rem; font-weight: 700; letter-spacing: .04em;
    padding: .28rem .65rem; border-radius: 4px; text-transform: uppercase;
}
.tbadge i { font-size: .6rem; }
.tbadge-warning  { background: rgba(255,193,7,0.15);  border: 1px solid rgba(255,193,7,0.3);  color: #ffc107; }
.tbadge-info     { background: rgba(13,202,240,0.12); border: 1px solid rgba(13,202,240,0.3); color: #0dcaf0; }
.tbadge-success  { background: rgba(25,135,84,0.15);  border: 1px solid rgba(25,135,84,0.35); color: #3dd68c; }
.tbadge-danger   { background: rgba(232,55,42,0.15);  border: 1px solid rgba(232,55,42,0.35); color: #ff6b4a; }
.tbadge-secondary{ background: rgba(255,255,255,0.06);border: 1px solid rgba(255,255,255,0.1);color: var(--muted); }
.tbadge-primary  { background: rgba(13,110,253,0.15); border: 1px solid rgba(13,110,253,0.3); color: #6ea8fe; }
.tbadge-priority-danger  { background: rgba(232,55,42,0.12);  border: 1px solid rgba(232,55,42,0.25);  color: #ff6b4a; }
.tbadge-priority-warning { background: rgba(255,193,7,0.1);   border: 1px solid rgba(255,193,7,0.2);   color: #ffc107; }
.tbadge-priority-success { background: rgba(25,135,84,0.1);   border: 1px solid rgba(25,135,84,0.2);   color: #3dd68c; }
.tbadge-priority-secondary{background: rgba(255,255,255,0.04);border: 1px solid rgba(255,255,255,0.08);color: var(--muted); }
.tbadge-priority-info    { background: rgba(13,202,240,0.1);  border: 1px solid rgba(13,202,240,0.2);  color: #0dcaf0; }
.tbadge-cat { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.45); }

/* ── TIMELINE ── */
.timeline { display: flex; flex-direction: column; gap: 0; }
.tl-item {
    display: flex; align-items: flex-start; gap: 1rem;
    position: relative; padding-bottom: 1.5rem;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-item::before {
    content: ''; position: absolute; left: 17px; top: 34px; bottom: 0;
    width: 1.5px; background: rgba(255,255,255,0.06);
}
.tl-item:last-child::before { display: none; }
.tl-dot {
    flex-shrink: 0; width: 36px; height: 36px;
    border-radius: 9px; display: flex; align-items: center; justify-content: center;
    font-size: .7rem; border: 1px solid;
}
.tl-primary { background: rgba(13,110,253,0.15); border-color: rgba(13,110,253,0.3); color: #6ea8fe; }
.tl-info    { background: rgba(13,202,240,0.12); border-color: rgba(13,202,240,0.3); color: #0dcaf0; }
.tl-warning { background: rgba(255,193,7,0.12);  border-color: rgba(255,193,7,0.3);  color: #ffc107; }
.tl-success { background: rgba(25,135,84,0.15);  border-color: rgba(25,135,84,0.3);  color: #3dd68c; }
.tl-content { display: flex; flex-direction: column; gap: .15rem; padding-top: .45rem; }
.tl-content strong { font-size: .88rem; color: var(--text); font-weight: 700; }
.tl-content span   { font-size: .76rem; color: var(--muted); }

/* ── INFO LIST (sidebar) ── */
.info-list { display: flex; flex-direction: column; gap: .1rem; }
.info-row-item {
    display: flex; align-items: center; justify-content: space-between; gap: .75rem;
    padding: .6rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);
}
.info-row-item:last-child { border-bottom: none; }
.info-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); flex-shrink: 0; }
.info-val { font-size: .82rem; color: var(--text); text-align: right; }
.info-success { color: #3dd68c !important; display: flex; align-items: center; gap: .35rem; }

/* ── DELETE BUTTON ── */
.btn-delete {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .65rem 1.2rem; background: rgba(232,55,42,0.12);
    border: 1.5px solid rgba(232,55,42,0.35); border-radius: 9px;
    color: #ff6b4a; font-size: .88rem; font-weight: 700; cursor: pointer;
    transition: all .2s; width: 100%;
}
.btn-delete:hover {
    background: rgba(232,55,42,0.2); border-color: var(--red);
    color: #fff; box-shadow: 0 4px 16px rgba(232,55,42,0.3);
}
.delete-hint { font-size: .72rem; color: var(--muted); text-align: center; margin: 0; }

/* ── HELP STRIP ── */
.help-strip {
    display: flex; align-items: center; gap: .65rem; padding: .85rem 1.25rem;
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 9px; font-size: .82rem; color: var(--muted);
}
.help-strip i { color: rgba(232,55,42,0.6); font-size: .95rem; }
.help-strip a { color: var(--red); text-decoration: none; }
.help-strip a:hover { text-decoration: underline; }

/* ── RESPONSIVE ── */
@media (max-width: 640px) {
    .gcard { padding: 1.25rem 1.1rem; }
    .hero-sub { white-space: normal; }
    .gcard-head { flex-wrap: wrap; }
    .ticket-id-pill { margin-left: auto; }
}
</style>

{% endblock %}
