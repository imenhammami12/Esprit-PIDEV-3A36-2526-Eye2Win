                                                {% endif %}
                                            </div>
                                            <div class="notif-body">
                                                {% if navNotifications|default([])|length == 0 %}
                                                    <div class="p-3" style="font-family:var(--font-mono);font-size:.68rem;color:var(--muted);text-align:center;">
