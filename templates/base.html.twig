<script>
(function () {
    'use strict';

    /* ══════════════════════════════════════════════════════════
       EYETWIN — GAMING CURSOR SYSTEM
       4 curseurs canvas • 1 RAF loop • localStorage persistence
    ══════════════════════════════════════════════════════════ */

    const STORAGE_KEY = 'et_cursor_type';
    const CURSORS     = ['crosshair', 'sword', 'energy', 'arrow'];
    const ICONS       = { crosshair:'🎯', sword:'⚔️', energy:'⚡', arrow:'🏹' };

    let cursorType  = localStorage.getItem(STORAGE_KEY) || 'crosshair';
    let mouseX = -200, mouseY = -200;
    let isHover = false, isClick = false, clickTime = 0;
    let energyOrbit = 0;
    let arrowTension = 0;
    let trailPoints  = [];
    let rafPending   = false;

    // ── Canvas ────────────────────────────────────────────────
    const canvas = document.getElementById('et-cursor-canvas');
    const ctx    = canvas.getContext('2d', { alpha: true, desynchronized: true });
    ctx.imageSmoothingEnabled = false;
    const CX = 40, CY = 40; // canvas center

    // ── Hotspot offsets (canvas top-left → pointer hotspot) ──
    const HOTSPOT = {
        crosshair : { x:40, y:40 },
        sword     : { x:4,  y:4  },
        energy    : { x:40, y:40 },
        arrow     : { x:40, y:16 },
    };

    // ── Mouse events ──────────────────────────────────────────
    document.addEventListener('mousemove', e => {
        mouseX = e.clientX; mouseY = e.clientY;
        if (!rafPending) { rafPending = true; requestAnimationFrame(loop); }
    }, { passive:true });

    document.addEventListener('mouseover', e => {
        isHover = !!e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt');
    }, { passive:true });
    document.addEventListener('mouseout', e => {
        if (e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt')) isHover = false;
    }, { passive:true });

    document.addEventListener('mousedown', () => { isClick=true; clickTime=performance.now(); spawnSparks(mouseX,mouseY); });
    document.addEventListener('mouseup',   () => { isClick=false; });

    // ── Sparks ───────────────────────────────────────────────
    const SPARK_PALETTES = {
crosshair : ['#e8372a','#fff','rgba(232,55,42,0.6)'],
        sword     : ['#ff4d3d','#ff6b2b','#ff2060','#fff','#f6d860'],
        energy    : ['#00e5ff','#bf5af2','#30d5c8','#fff'],
        arrow     : ['#f6d860','#f6ad55','#fff'],
    };
    function spawnSparks(x, y) {
        const pal   = SPARK_PALETTES[cursorType];
        const count = cursorType === 'crosshair' ? 8 : 6;
        for (let i = 0; i < count; i++) {
            const sp    = document.createElement('div');
            sp.className = 'et-spark';
            const angle = (i/count)*Math.PI*2 + Math.random()*.5;
            const dist  = 20 + Math.random()*38;
            const size  = 2 + Math.random()*2;
            const dur   = .25 + Math.random()*.2;
            sp.style.cssText = `left:${x}px;top:${y}px;width:${size}px;height:${size}px;`
                + `background:${pal[i%pal.length]};`
                + `--sx:${Math.cos(angle)*dist}px;--sy:${Math.sin(angle)*dist}px;--dur:${dur}s`;
            document.body.appendChild(sp);
            setTimeout(() => sp.remove(), dur*1000+60);
        }
    }

    // ── Draw: CROSSHAIR ──────────────────────────────────────
    function drawCrosshair(ts) {
        const pulse  = .5 + .5*Math.sin(ts*.003);
        const gap    = isClick ? 14 : (isHover ? 10 : 7);
        const size   = isClick ? 10 : (isHover ? 13 : 15);
        const radar  = (ts*.001) % (Math.PI*2);

        ctx.save();
        ctx.translate(CX, CY);

        // Outer dim ring
        ctx.beginPath(); ctx.arc(0,0,18,0,Math.PI*2);
ctx.strokeStyle = `rgba(232,55,42,${(.3+.25*pulse)*.5})`;
        ctx.lineWidth = .8; ctx.stroke();

        // Radar sweep
        ctx.save(); ctx.rotate(radar);
        for (let i=0; i<30; i++) {
            const a = -(i/30)*Math.PI*.7;
            ctx.beginPath(); ctx.moveTo(0,0);
            ctx.arc(0,0,17,a-.06,a+.06); ctx.closePath();
ctx.fillStyle = `rgba(232,55,42,${(1-i/30)*.45})`;
        }
        ctx.restore();

        // Inner ring
        ctx.beginPath(); ctx.arc(0,0,5,0,Math.PI*2);
ctx.strokeStyle = `rgba(232,55,42,${.6+.4*pulse})`;

        // Center dot
        ctx.beginPath(); ctx.arc(0,0,isClick?3:1.5,0,Math.PI*2);
ctx.fillStyle = isClick?'#fff':'#e8372a';

        // 4 lines
ctx.strokeStyle = `rgba(232,55,42,${isClick?1:.85})`;
        [[0,-size,0,-gap],[0,gap,0,size],[-size,0,-gap,0],[gap,0,size,0]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
        });

        // Hit-marker on click
        if (isClick) {
            const age = (ts-clickTime)/300;
            if (age<1) {
                ctx.strokeStyle=`rgba(255,255,255,${1-age})`; ctx.lineWidth=1.5;
                const s=6+age*8;
                [[-s,-s,s,s],[-s,s,s,-s]].forEach(([x1,y1,x2,y2])=>{
                    ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
                });
            }
        }
        ctx.restore();
    }

    // ── Draw: SWORD ──────────────────────────────────────────
    function drawSword(ts) {
        const now = ts;
        trailPoints.push({ x:mouseX, y:mouseY, t:now });
        trailPoints = trailPoints.filter(p => now-p.t < 120);

        // Motion trail (relative to cursor)
        if (trailPoints.length > 1) {
            for (let i=1; i<trailPoints.length; i++) {
                const age = (now-trailPoints[i].t)/120;
                ctx.save(); ctx.translate(CX,CY);
                ctx.beginPath();
                ctx.moveTo(trailPoints[i-1].x-mouseX, trailPoints[i-1].y-mouseY);
                ctx.lineTo(trailPoints[i].x-mouseX,   trailPoints[i].y-mouseY);
                ctx.strokeStyle=`rgba(232,55,42,${(1-age)*.55})`;
                ctx.lineWidth=2*(1-age); ctx.lineCap='round'; ctx.stroke();
                ctx.restore();
            }
        }

        ctx.save(); ctx.translate(CX,CY); ctx.rotate(-Math.PI/4);

        if (isHover) { ctx.shadowColor='rgba(255,107,43,0.8)'; ctx.shadowBlur=8; }

        // Blade
        const bg = ctx.createLinearGradient(-2,-28,2,8);
        bg.addColorStop(0,'#8090a8'); bg.addColorStop(.4,'#e8eef8'); bg.addColorStop(1,'#6070a0');
        ctx.beginPath(); ctx.moveTo(0,-28); ctx.lineTo(-2,-8); ctx.lineTo(2,-8); ctx.closePath();
        ctx.fillStyle=bg; ctx.fill();

        // Shine
        ctx.beginPath(); ctx.moveTo(-.5,-26); ctx.lineTo(-.5,-8);
        ctx.strokeStyle='rgba(255,255,255,0.7)'; ctx.lineWidth=.6; ctx.stroke();

        // Guard (animated)
        const gp = .5+.5*Math.sin(ts*.004);
        ctx.shadowColor=`rgba(255,180,100,${.3+.3*gp})`; ctx.shadowBlur=4;
        ctx.fillStyle=`rgba(176,43,32,${.8+.2*gp})`;
        ctx.beginPath(); ctx.roundRect(-7,-9,14,3,1.5); ctx.fill();
        ctx.strokeStyle=`rgba(255,180,100,${.3+.3*gp})`; ctx.lineWidth=.7; ctx.stroke();

        // Handle
        const hg = ctx.createLinearGradient(-2,-6,2,8);
        hg.addColorStop(0,'#6b1a12'); hg.addColorStop(1,'#3a0e08');
        ctx.shadowBlur=0;
        ctx.beginPath(); ctx.roundRect(-2,-6,4,12,1.5); ctx.fillStyle=hg; ctx.fill();

        // Pommel
        const pa = isClick ? 1 : (.6+.4*gp);
        ctx.beginPath(); ctx.arc(0,8,3.5,0,Math.PI*2);
        ctx.fillStyle=`rgba(232,55,42,${pa})`;
        ctx.shadowColor=`rgba(232,55,42,${pa})`; ctx.shadowBlur=isClick?12:5;
        ctx.fill();
        ctx.strokeStyle='rgba(255,180,100,0.5)'; ctx.lineWidth=.7; ctx.stroke();

        ctx.restore();
    }

    // ── Draw: ENERGY ─────────────────────────────────────────
    function drawEnergy(ts) {
        energyOrbit += .04;
        const pulse = .5+.5*Math.sin(ts*.005);
        const hs    = isHover ? 1.25 : 1;

        ctx.save(); ctx.translate(CX,CY);

        // Core glow
        const cg = ctx.createRadialGradient(0,0,0,0,0,8*hs);
        cg.addColorStop(0, isHover?'rgba(0,229,255,0.9)':'rgba(0,229,255,0.6)');
        cg.addColorStop(.5,`rgba(0,229,255,${.15+.1*pulse})`);
        cg.addColorStop(1,'rgba(0,229,255,0)');
        ctx.beginPath(); ctx.arc(0,0,8*hs,0,Math.PI*2); ctx.fillStyle=cg; ctx.fill();

        // Center dot
        ctx.beginPath(); ctx.arc(0,0,2.5,0,Math.PI*2);
        ctx.fillStyle='#fff'; ctx.shadowColor='#00e5ff'; ctx.shadowBlur=10; ctx.fill();

        // 3 orbiting particles
        const orbitR = 14+3*pulse*hs;
        const orbitC = ['#00e5ff','rgba(191,90,242,0.9)','#30d5c8'];
        for (let i=0; i<3; i++) {
            const angle = energyOrbit+(i/3)*Math.PI*2;
            const ox = Math.cos(angle)*orbitR;
            const oy = Math.sin(angle)*(orbitR*.5);
            const ps = 2.2+pulse;

            // Orb trail
            for (let j=1; j<5; j++) {
                const ta=angle-j*.18;
                ctx.beginPath();
                ctx.arc(Math.cos(ta)*orbitR, Math.sin(ta)*(orbitR*.5), ps*(1-j/5)*.7,0,Math.PI*2);
                ctx.fillStyle=`rgba(0,229,255,${.25*(1-j/5)})`; ctx.shadowBlur=0; ctx.fill();
            }

            ctx.beginPath(); ctx.arc(ox,oy,ps,0,Math.PI*2);
            ctx.fillStyle=orbitC[i]; ctx.shadowColor=orbitC[i]; ctx.shadowBlur=8; ctx.fill();
        }

        // Pulse ring on click
        if (isClick) {
            const age=(ts-clickTime)/400;
            if (age<1) {
                ctx.beginPath(); ctx.arc(0,0,age*26,0,Math.PI*2);
                ctx.strokeStyle=`rgba(0,229,255,${1-age})`; ctx.lineWidth=1.5; ctx.shadowBlur=0; ctx.stroke();
            }
        }
        ctx.restore();
    }

    // ── Draw: ARROW ──────────────────────────────────────────
    function drawArrow(ts) {
        arrowTension = isClick
            ? Math.min(1,(ts-clickTime)/250)
            : Math.max(0,arrowTension-.08);

        const fp = .5+.5*Math.sin(ts*.003);
        ctx.save(); ctx.translate(CX,CY);

        // Shaft
        const sg = ctx.createLinearGradient(0,-24,0,6);
        sg.addColorStop(0,'#f6d860'); sg.addColorStop(1,'#c8a830');
        ctx.beginPath(); ctx.moveTo(0,-24); ctx.lineTo(0,6);
        ctx.strokeStyle=sg; ctx.lineWidth=1.5;
        ctx.shadowColor='rgba(246,216,96,0.5)'; ctx.shadowBlur=isHover?8:4; ctx.stroke();

        // Arrowhead
        const hs = isHover?7:5.5;
        ctx.beginPath(); ctx.moveTo(0,-24-hs); ctx.lineTo(-hs*.6,-24); ctx.lineTo(hs*.6,-24); ctx.closePath();
        ctx.fillStyle='#f6d860'; ctx.shadowColor='rgba(246,216,96,0.8)'; ctx.shadowBlur=isHover?12:6; ctx.fill();

        // Feathers
        ctx.shadowBlur=0;
        [[-3,4,-8,10],[3,4,8,10],[-3,9,-6,14],[3,9,6,14]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2);
            ctx.strokeStyle=`rgba(246,${173+42*fp|0},85,0.8)`; ctx.lineWidth=1.5; ctx.lineCap='round'; ctx.stroke();
        });

        // Bow-string tension
        if (arrowTension > .01) {
            const pull = arrowTension*12;
            [[-12,-10,12,-10],[-12,10,12,10]].forEach(([x1,y1,x2,y2])=>{
                ctx.beginPath(); ctx.moveTo(x1,y1); ctx.quadraticCurveTo(pull,0,x2,y2);
                ctx.strokeStyle=`rgba(246,216,96,${.3+arrowTension*.5})`; ctx.lineWidth=.8; ctx.stroke();
            });
        }
        ctx.restore();
    }

    // ── RAF loop ─────────────────────────────────────────────
    function loop(ts) {
        rafPending = false;
        const hot = HOTSPOT[cursorType] || HOTSPOT.crosshair;
        canvas.style.transform = `translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;

        ctx.clearRect(0,0,80,80);
        switch (cursorType) {
            case 'crosshair': drawCrosshair(ts); break;
            case 'sword':     drawSword(ts);     break;
            case 'energy':    drawEnergy(ts);    break;
            case 'arrow':     drawArrow(ts);     break;
        }

        // Continuous for animated cursors
        if (cursorType === 'energy' || cursorType === 'crosshair' || arrowTension > .01) {
            rafPending = true; requestAnimationFrame(loop);
        }
    }

    // Force continuous RAF for energy & crosshair regardless of mouse movement
    (function continuousLoop(ts) {
        if (cursorType === 'energy' || cursorType === 'crosshair') {
            const hot = HOTSPOT[cursorType];
            canvas.style.transform = `translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;
            ctx.clearRect(0,0,80,80);
            cursorType === 'energy' ? drawEnergy(ts) : drawCrosshair(ts);
        }
        requestAnimationFrame(continuousLoop);
    })(0);

    // ── Picker UI ────────────────────────────────────────────
    const btn   = document.getElementById('et-cursor-btn');
    const panel = document.getElementById('et-cursor-panel');
    const opts  = document.querySelectorAll('.et-cursor-opt');

    function setCursor(type) {
        if (!CURSORS.includes(type)) return;
        cursorType = type;
        localStorage.setItem(STORAGE_KEY, type);
        trailPoints = []; arrowTension = 0;
        opts.forEach(o => o.classList.toggle('active', o.dataset.cursor === type));
        btn.textContent = ICONS[type];
        setTimeout(() => panel.classList.remove('open'), 220);
        if (!rafPending) { rafPending=true; requestAnimationFrame(loop); }
    }

    btn.addEventListener('click', e => { e.stopPropagation(); panel.classList.toggle('open'); });
    opts.forEach(o => o.addEventListener('click', () => setCursor(o.dataset.cursor)));
    document.addEventListener('click', e => {
        if (!panel.contains(e.target) && e.target!==btn) panel.classList.remove('open');
    });
    document.addEventListener('keydown', e => { if (e.key==='Escape') panel.classList.remove('open'); });

    // Init with saved or default cursor
    setCursor(cursorType);

    /* ══════════════════════════════════════════════════════════
       BACKGROUND PARTICLE CANVAS
    ══════════════════════════════════════════════════════════ */
    const bgCanvas = document.getElementById('bgCanvas');
    if (bgCanvas) {
        const bctx = bgCanvas.getContext('2d', { alpha:true });
        bctx.imageSmoothingEnabled = false;
        let W, H, particles = [];

        function resize() { W = bgCanvas.width = window.innerWidth; H = bgCanvas.height = window.innerHeight; }
        resize();
        window.addEventListener('resize', () => { resize(); spawnAll(); }, { passive:true });

        const COLORS = ['rgba(232,55,42,','rgba(255,107,43,','rgba(255,32,96,','rgba(0,229,255,'];
        function mkParticle() {
            return { x:Math.random()*W, y:H+Math.random()*40, vx:(Math.random()-.5)*.35, vy:-(0.18+Math.random()*.55), r:.7+Math.random()*1.1, alpha:0, maxAlpha:.12+Math.random()*.18, phase:Math.random()*Math.PI*2, color:COLORS[Math.floor(Math.random()*COLORS.length)], life:0, maxLife:150+Math.random()*180 };
        }
        function spawnAll() { particles = Array.from({length:30}, mkParticle); }
        spawnAll();

        let lastFrame = 0;
        (function tick(ts) {
            if (ts-lastFrame < 33) { requestAnimationFrame(tick); return; }
            lastFrame = ts;
            bctx.clearRect(0,0,W,H);
            bctx.shadowBlur = 0;
            particles.forEach((p,i) => {
                p.life++; p.x += p.vx+Math.sin(p.phase+p.life*.018)*.18; p.y += p.vy;
                const t = p.life/p.maxLife;
                p.alpha = t<.15?(t/.15)*p.maxAlpha:t>.75?((1-t)/.25)*p.maxAlpha:p.maxAlpha;
                if (p.life>=p.maxLife||p.y<-10) particles[i]=mkParticle();
                bctx.beginPath(); bctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                bctx.fillStyle=p.color+p.alpha+')'; bctx.fill();
            });
            requestAnimationFrame(tick);
        })(0);
    }

    /* ══════════════════════════════════════════════════════════
       SCROLL PROGRESS BAR
    ══════════════════════════════════════════════════════════ */
    const sp = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
        const pct = (document.documentElement.scrollTop/(document.documentElement.scrollHeight-window.innerHeight))*100;
        if (sp) sp.style.width = pct+'%';
    }, { passive:true });

    /* ══════════════════════════════════════════════════════════
       NAVBAR SCROLL SHRINK
    ══════════════════════════════════════════════════════════ */
    const navbar = document.querySelector('.main_menu');
    window.addEventListener('scroll', () => {
        if (navbar) {
            navbar.style.background = window.scrollY>60?'rgba(5,5,12,0.95)':'';
            navbar.style.padding    = window.scrollY>60?'0':'';
        }
    }, { passive:true });

    /* ══════════════════════════════════════════════════════════
       RIPPLE ON NAV LINKS
    ══════════════════════════════════════════════════════════ */
    document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
        link.style.position='relative'; link.style.overflow='hidden';
        link.addEventListener('click', function(e) {
            const rect=this.getBoundingClientRect();
            const r=document.createElement('span');
            r.className='ripple';
            r.style.cssText=`width:40px;height:40px;left:${e.clientX-rect.left-20}px;top:${e.clientY-rect.top-20}px;`;
            this.appendChild(r); setTimeout(()=>r.remove(),500);
        });
    });

    /* ══════════════════════════════════════════════════════════
       SCROLL REVEAL
    ══════════════════════════════════════════════════════════ */
    if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='none'; io.unobserve(e.target); }
            });
        }, { threshold:.07 });
        document.querySelectorAll('section > .container > .row > [class*="col"]').forEach(el => {
            el.style.opacity='0'; el.style.transform='translateY(20px)';
            el.style.transition='opacity .55s ease, transform .55s ease';
            io.observe(el);
        });
    }

    /* ══════════════════════════════════════════════════════════
       GLITCH LOGO
    ══════════════════════════════════════════════════════════ */
    const logo = document.querySelector('.navbar-brand img');
    if (logo) {
        setInterval(() => {
            if (Math.random()>.88) {
                logo.animate([
                    { filter:'none', transform:'none' },
                    { filter:'hue-rotate(180deg) brightness(1.5)', transform:'skewX(-4deg) translateX(2px)' },
                    { filter:'hue-rotate(-90deg)', transform:'skewX(3deg) translateX(-2px)' },
                    { filter:'none', transform:'none' },
                ], { duration:140, easing:'steps(3)' });
            }
        }, 4000);
    }

})();
</script>
</body>
</html>
