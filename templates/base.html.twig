    const CURSORS     = ['crosshair','sword','energy','arrow'];
    const ICONS       = { crosshair:'🎯', sword:'⚔️', energy:'⚡', arrow:'🏹' };

    let cursorType = localStorage.getItem(STORAGE_KEY) || 'crosshair';
    let mouseX = -300, mouseY = -300;
    let isHover = false, isClick = false, clickTime = 0;
    let energyOrbit = 0, arrowTension = 0;
    let trailPoints = [], rafPending = false;

    const canvas = document.getElementById('et-cursor-canvas');
    const ctx    = canvas.getContext('2d', { alpha:true, desynchronized:true });
    const CX = 60, CY = 60;

    const HOTSPOT = {
        crosshair:{ x:60, y:60 }, sword:{ x:4, y:4 },
        energy:{ x:60, y:60 },    arrow:{ x:60, y:20 },
    };

    document.addEventListener('mousemove', e => {
        trailPoints.push({ x:mouseX, y:mouseY, t:performance.now() });
        if (trailPoints.length > 8) trailPoints.shift();
        mouseX = e.clientX; mouseY = e.clientY;
        if (!rafPending) { rafPending=true; requestAnimationFrame(loop); }
    }, { passive:true });
    document.addEventListener('mouseover', e => {
        isHover = !!e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt,.et-pd-item,.et-profile-trigger,.a11y-quick-btn,.a11y-send-btn,.a11y-mic-btn,.a11y-close-btn');
    }, { passive:true });
    document.addEventListener('mouseout', e => {
        if (e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt,.et-pd-item,.et-profile-trigger,.a11y-quick-btn,.a11y-send-btn,.a11y-mic-btn,.a11y-close-btn')) isHover=false;
    }, { passive:true });
    document.addEventListener('mousedown', ()=>{ isClick=true; clickTime=performance.now(); spawnSparks(mouseX,mouseY); });
    document.addEventListener('mouseup',   ()=>{ isClick=false; });

    const SPARK_PAL = {
        crosshair:['#e8372a','#ff4d3d','#ff6b2b','#fff','rgba(232,55,42,.5)'],
        sword:['#ff4d3d','#ff6b2b','#ff2060','#fff','#f6d860'],
        energy:['#00e5ff','#bf5af2','#30d5c8','#fff'],
        arrow:['#f6d860','#f6ad55','#fff'],
    };
    function spawnSparks(x,y) {
        const pal=SPARK_PAL[cursorType], count=cursorType==='crosshair'?10:6;
        for (let i=0;i<count;i++) {
            const sp=document.createElement('div'); sp.className='et-spark';
            const angle=(i/count)*Math.PI*2+Math.random()*.5;
            const dist=22+Math.random()*42, size=1.5+Math.random()*2.5, dur=.2+Math.random()*.25;
            sp.style.cssText=`left:${x}px;top:${y}px;width:${size}px;height:${size}px;background:${pal[i%pal.length]};--sx:${Math.cos(angle)*dist}px;--sy:${Math.sin(angle)*dist}px;--dur:${dur}s`;
            document.body.appendChild(sp); setTimeout(()=>sp.remove(),dur*1000+60);
        }
    }

    let radarAngle=0, scanRot=0;
    function drawCrosshair(ts) {
        radarAngle = ts*.002; scanRot = ts*.0012;
        const pulse   = .5+.5*Math.sin(ts*.003);
        const breathe = Math.sin(ts*.0028);
        const gap = isClick?16:(isHover?11:8);
        const len = isClick?9:(isHover?15:18);
        const thick = isHover?1.6:1.2;
        ctx.save(); ctx.translate(CX,CY);
        const now=performance.now();
        trailPoints.forEach(p=>{
            const age=(now-p.t)/200; if(age>1) return;
            const dx=(p.x-mouseX)*.4*(1-age), dy=(p.y-mouseY)*.4*(1-age);
            const sc=.45+.45*(1-age), mg=gap*sc, ml=len*sc;
            ctx.save(); ctx.translate(dx,dy); ctx.globalAlpha=(1-age)*.1;
            ctx.strokeStyle='#e8372a'; ctx.lineWidth=.7; ctx.lineCap='round';
            [[0,-ml,0,-mg],[0,mg,0,ml],[-ml,0,-mg,0],[mg,0,ml,0]].forEach(([x1,y1,x2,y2])=>{
                ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
            }); ctx.restore();
        }); ctx.globalAlpha=1;
        ctx.beginPath(); ctx.arc(0,0,38+breathe,0,Math.PI*2);
        ctx.strokeStyle=`rgba(232,55,42,${.05+.04*pulse})`; ctx.lineWidth=.6; ctx.stroke();
        ctx.save(); ctx.rotate(radarAngle);
        for(let i=0;i<40;i++){
            const a=-(i/40)*Math.PI*.85, fade=1-i/40;
            ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,28,a-.04,a+.04); ctx.closePath();
            ctx.fillStyle=`rgba(232,55,42,${fade*.3})`; ctx.fill();
        } ctx.restore();
        ctx.lineWidth=.9;
        for(let i=0;i<8;i++){
            const startA=(i/8)*Math.PI*2+scanRot, endA=startA+(Math.PI*2/8)-.2;
            ctx.beginPath(); ctx.arc(0,0,26,startA,endA);
            ctx.strokeStyle=`rgba(232,55,42,${.28+.15*pulse})`; ctx.stroke();
        }
        ctx.beginPath(); ctx.arc(0,0,12+(isHover?2:0),0,Math.PI*2);
        ctx.strokeStyle=`rgba(232,55,42,${.55+.3*pulse})`; ctx.lineWidth=isHover?1.2:.9; ctx.stroke();
        [.25,.75,1.25,1.75].forEach(f=>{
            const a=f*Math.PI, r=12+(isHover?2:0);
            ctx.beginPath(); ctx.moveTo(Math.cos(a)*(r-2),Math.sin(a)*(r-2)); ctx.lineTo(Math.cos(a)*(r+5),Math.sin(a)*(r+5));
            ctx.strokeStyle=`rgba(232,55,42,${.45+.25*pulse})`; ctx.lineWidth=.8; ctx.stroke();
        });
        ctx.strokeStyle=isClick?'rgba(255,255,255,.95)':`rgba(232,55,42,${.88+.1*pulse})`;
        ctx.lineWidth=thick; ctx.lineCap='square';
        ctx.shadowColor=isClick?'rgba(255,120,80,.9)':'rgba(232,55,42,.55)'; ctx.shadowBlur=isHover?9:5;
        [[0,-(gap+len),0,-gap],[0,gap,0,gap+len],[-(gap+len),0,-gap,0],[gap,0,gap+len,0]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
        }); ctx.shadowBlur=0;
        const cw=3; ctx.lineWidth=.8; ctx.strokeStyle=`rgba(232,55,42,${.45+.25*pulse})`;
        [[-cw,-(gap+len),cw,-(gap+len)],[-cw,gap+len,cw,gap+len],[-(gap+len),-cw,-(gap+len),cw],[gap+len,-cw,gap+len,cw]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
        });
        ctx.beginPath(); ctx.arc(0,0,isClick?4:(isHover?2.8:2),0,Math.PI*2);
        ctx.fillStyle=isClick?'#fff':'#e8372a'; ctx.shadowColor=isClick?'#fff':'rgba(232,55,42,.9)'; ctx.shadowBlur=isClick?16:7; ctx.fill(); ctx.shadowBlur=0;
        const hitAge=(performance.now()-clickTime)/420;
        if(hitAge<1&&clickTime>0){
            const s=5+hitAge*12;
            ctx.strokeStyle=`rgba(255,255,255,${(1-hitAge)*.92})`; ctx.lineWidth=1.6; ctx.lineCap='round';
            ctx.shadowColor=`rgba(255,255,255,${1-hitAge})`; ctx.shadowBlur=8;
            [[-s,-s,s,s],[-s,s,s,-s]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke(); });
            ctx.shadowBlur=0;
        }
        if(isHover){
            const br=32, bl=9;
            ctx.strokeStyle=`rgba(232,55,42,${.35+.25*pulse})`; ctx.lineWidth=.9; ctx.lineCap='square';
            [[-1,-1],[1,-1],[-1,1],[1,1]].forEach(([sx,sy])=>{
                const cx2=sx*br, cy2=sy*br;
                ctx.beginPath(); ctx.moveTo(cx2,cy2-sy*bl); ctx.lineTo(cx2,cy2); ctx.lineTo(cx2-sx*bl,cy2); ctx.stroke();
            });
        }
        ctx.restore();
    }

    function drawSword(ts) {
        const now=ts;
        trailPoints.push({x:mouseX,y:mouseY,t:now});
        trailPoints=trailPoints.filter(p=>now-p.t<120);
        if(trailPoints.length>1){
            for(let i=1;i<trailPoints.length;i++){
                const age=(now-trailPoints[i].t)/120;
                ctx.save(); ctx.translate(CX,CY);
                ctx.beginPath(); ctx.moveTo(trailPoints[i-1].x-mouseX,trailPoints[i-1].y-mouseY); ctx.lineTo(trailPoints[i].x-mouseX,trailPoints[i].y-mouseY);
                ctx.strokeStyle=`rgba(232,55,42,${(1-age)*.55})`; ctx.lineWidth=2*(1-age); ctx.lineCap='round'; ctx.stroke(); ctx.restore();
            }
        }
        ctx.save(); ctx.translate(CX,CY); ctx.rotate(-Math.PI/4);
        if(isHover){ctx.shadowColor='rgba(255,107,43,0.8)';ctx.shadowBlur=8;}
        const bg=ctx.createLinearGradient(-2,-28,2,8); bg.addColorStop(0,'#8090a8'); bg.addColorStop(.4,'#e8eef8'); bg.addColorStop(1,'#6070a0');
        ctx.beginPath(); ctx.moveTo(0,-28); ctx.lineTo(-2,-8); ctx.lineTo(2,-8); ctx.closePath(); ctx.fillStyle=bg; ctx.fill();
        ctx.beginPath(); ctx.moveTo(-.5,-26); ctx.lineTo(-.5,-8); ctx.strokeStyle='rgba(255,255,255,0.7)'; ctx.lineWidth=.6; ctx.stroke();
        const gp=.5+.5*Math.sin(ts*.004);
        ctx.shadowColor=`rgba(255,180,100,${.3+.3*gp})`; ctx.shadowBlur=4; ctx.fillStyle=`rgba(176,43,32,${.8+.2*gp})`;
        ctx.beginPath(); ctx.roundRect(-7,-9,14,3,1.5); ctx.fill();
        ctx.strokeStyle=`rgba(255,180,100,${.3+.3*gp})`; ctx.lineWidth=.7; ctx.stroke();
        const hg=ctx.createLinearGradient(-2,-6,2,8); hg.addColorStop(0,'#6b1a12'); hg.addColorStop(1,'#3a0e08');
        ctx.shadowBlur=0; ctx.beginPath(); ctx.roundRect(-2,-6,4,12,1.5); ctx.fillStyle=hg; ctx.fill();
        const pa=isClick?1:(.6+.4*gp);
        ctx.beginPath(); ctx.arc(0,8,3.5,0,Math.PI*2); ctx.fillStyle=`rgba(232,55,42,${pa})`; ctx.shadowColor=`rgba(232,55,42,${pa})`; ctx.shadowBlur=isClick?12:5; ctx.fill();
        ctx.strokeStyle='rgba(255,180,100,0.5)'; ctx.lineWidth=.7; ctx.stroke(); ctx.restore();
    }

    function drawEnergy(ts) {
        energyOrbit+=.04;
        const pulse=.5+.5*Math.sin(ts*.005), hs=isHover?1.25:1;
        ctx.save(); ctx.translate(CX,CY);
        const cg=ctx.createRadialGradient(0,0,0,0,0,8*hs);
        cg.addColorStop(0,isHover?'rgba(0,229,255,0.9)':'rgba(0,229,255,0.6)'); cg.addColorStop(.5,`rgba(0,229,255,${.15+.1*pulse})`); cg.addColorStop(1,'rgba(0,229,255,0)');
        ctx.beginPath(); ctx.arc(0,0,8*hs,0,Math.PI*2); ctx.fillStyle=cg; ctx.fill();
        ctx.beginPath(); ctx.arc(0,0,2.5,0,Math.PI*2); ctx.fillStyle='#fff'; ctx.shadowColor='#00e5ff'; ctx.shadowBlur=10; ctx.fill();
        const orbitR=14+3*pulse*hs, orbitC=['#00e5ff','rgba(191,90,242,0.9)','#30d5c8'];
        for(let i=0;i<3;i++){
            const angle=energyOrbit+(i/3)*Math.PI*2, ox=Math.cos(angle)*orbitR, oy=Math.sin(angle)*(orbitR*.5), ps=2.2+pulse;
            for(let j=1;j<5;j++){ const ta=angle-j*.18; ctx.beginPath(); ctx.arc(Math.cos(ta)*orbitR,Math.sin(ta)*(orbitR*.5),ps*(1-j/5)*.7,0,Math.PI*2); ctx.fillStyle=`rgba(0,229,255,${.25*(1-j/5)})`; ctx.shadowBlur=0; ctx.fill(); }
            ctx.beginPath(); ctx.arc(ox,oy,ps,0,Math.PI*2); ctx.fillStyle=orbitC[i]; ctx.shadowColor=orbitC[i]; ctx.shadowBlur=8; ctx.fill();
        }
        if(isClick){ const age=(ts-clickTime)/400; if(age<1){ ctx.beginPath(); ctx.arc(0,0,age*26,0,Math.PI*2); ctx.strokeStyle=`rgba(0,229,255,${1-age})`; ctx.lineWidth=1.5; ctx.shadowBlur=0; ctx.stroke(); } }
        ctx.restore();
    }

    function drawArrow(ts) {
        arrowTension=isClick?Math.min(1,(ts-clickTime)/250):Math.max(0,arrowTension-.08);
        const fp=.5+.5*Math.sin(ts*.003);
        ctx.save(); ctx.translate(CX,CY);
        const sg=ctx.createLinearGradient(0,-24,0,6); sg.addColorStop(0,'#f6d860'); sg.addColorStop(1,'#c8a830');
        ctx.beginPath(); ctx.moveTo(0,-24); ctx.lineTo(0,6); ctx.strokeStyle=sg; ctx.lineWidth=1.5; ctx.shadowColor='rgba(246,216,96,0.5)'; ctx.shadowBlur=isHover?8:4; ctx.stroke();
        const hs=isHover?7:5.5;
        ctx.beginPath(); ctx.moveTo(0,-24-hs); ctx.lineTo(-hs*.6,-24); ctx.lineTo(hs*.6,-24); ctx.closePath(); ctx.fillStyle='#f6d860'; ctx.shadowColor='rgba(246,216,96,0.8)'; ctx.shadowBlur=isHover?12:6; ctx.fill();
        ctx.shadowBlur=0;
        [[-3,4,-8,10],[3,4,8,10],[-3,9,-6,14],[3,9,6,14]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.strokeStyle=`rgba(246,${173+42*fp|0},85,0.8)`; ctx.lineWidth=1.5; ctx.lineCap='round'; ctx.stroke(); });
        if(arrowTension>.01){ const pull=arrowTension*12; [[-12,-10,12,-10],[-12,10,12,10]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.quadraticCurveTo(pull,0,x2,y2); ctx.strokeStyle=`rgba(246,216,96,${.3+arrowTension*.5})`; ctx.lineWidth=.8; ctx.stroke(); }); }
        ctx.restore();
    }

    function loop(ts) {
        rafPending=false;
        const hot=HOTSPOT[cursorType]||HOTSPOT.crosshair;
        canvas.style.transform=`translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;
        ctx.clearRect(0,0,120,120);
        switch(cursorType){
            case 'crosshair': drawCrosshair(ts); break;
            case 'sword':     drawSword(ts);     break;
            case 'energy':    drawEnergy(ts);    break;
            case 'arrow':     drawArrow(ts);     break;
        }
        if(cursorType==='energy'||cursorType==='crosshair'||arrowTension>.01){ rafPending=true; requestAnimationFrame(loop); }
    }

    (function continuousLoop(ts) {
        if(cursorType==='energy'||cursorType==='crosshair'){
            const hot=HOTSPOT[cursorType];
            canvas.style.transform=`translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;
            ctx.clearRect(0,0,120,120);
            cursorType==='energy'?drawEnergy(ts):drawCrosshair(ts);
        }
        requestAnimationFrame(continuousLoop);
    })(0);

    const btn=document.getElementById('et-cursor-btn');
    const panel=document.getElementById('et-cursor-panel');
    const opts=document.querySelectorAll('.et-cursor-opt');

    function setCursor(type) {
        if(!CURSORS.includes(type)) return;
        cursorType=type; localStorage.setItem(STORAGE_KEY,type);
        trailPoints=[]; arrowTension=0;
        opts.forEach(o=>o.classList.toggle('active',o.dataset.cursor===type));
        btn.textContent=ICONS[type];
        setTimeout(()=>panel.classList.remove('open'),220);
        btn.setAttribute('aria-expanded','false');
        panel.setAttribute('aria-hidden','true');
        if(!rafPending){ rafPending=true; requestAnimationFrame(loop); }
    }
    btn.addEventListener('click',e=>{
        e.stopPropagation();
        const opening = !panel.classList.contains('open');
        panel.classList.toggle('open');
        btn.setAttribute('aria-expanded', opening ? 'true' : 'false');
        panel.setAttribute('aria-hidden',  opening ? 'false' : 'true');
        if (opening) {
            const firstOpt = panel.querySelector('[role="menuitem"]');
            if (firstOpt) { firstOpt.setAttribute('tabindex','0'); firstOpt.focus(); }
        }
    });
    opts.forEach(o => {
        o.addEventListener('click', () => setCursor(o.dataset.cursor));
        o.addEventListener('keydown', e => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setCursor(o.dataset.cursor); }
            if (e.key === 'ArrowDown') { e.preventDefault(); o.nextElementSibling?.focus(); }
            if (e.key === 'ArrowUp')   { e.preventDefault(); o.previousElementSibling?.focus(); }
            if (e.key === 'Escape')    { panel.classList.remove('open'); btn.setAttribute('aria-expanded','false'); panel.setAttribute('aria-hidden','true'); btn.focus(); }
        });
    });
    document.addEventListener('click',e=>{
        if(!panel.contains(e.target)&&e.target!==btn) {
            panel.classList.remove('open');
            btn.setAttribute('aria-expanded','false');
            panel.setAttribute('aria-hidden','true');
        }
    });
    document.addEventListener('keydown',e=>{
        if(e.key==='Escape') {
            panel.classList.remove('open');
            btn.setAttribute('aria-expanded','false');
            panel.setAttribute('aria-hidden','true');
        }
    });
    setCursor(cursorType);

    const pfTrigger=document.querySelector('.et-profile-trigger');
    if(pfTrigger){
        pfTrigger.addEventListener('click',function(){
            setTimeout(()=>{ const open=this.closest('.dropdown').classList.contains('show'); this.classList.toggle('show',open); },10);
        });
        document.addEventListener('click',e=>{ if(!pfTrigger.closest('.dropdown').contains(e.target)) pfTrigger.classList.remove('show'); });
    }

    const bgCanvas=document.getElementById('bgCanvas');
    if(bgCanvas){
        const bctx=bgCanvas.getContext('2d',{alpha:true}); bctx.imageSmoothingEnabled=false;
        let W,H,particles=[];
        function resize(){ W=bgCanvas.width=window.innerWidth; H=bgCanvas.height=window.innerHeight; }
        resize(); window.addEventListener('resize',()=>{ resize(); spawnAll(); },{passive:true});
        const COLORS=['rgba(232,55,42,','rgba(255,107,43,','rgba(255,32,96,','rgba(0,229,255,'];
        function mkParticle(){ return {x:Math.random()*W,y:H+Math.random()*40,vx:(Math.random()-.5)*.35,vy:-(0.18+Math.random()*.55),r:.7+Math.random()*1.1,alpha:0,maxAlpha:.12+Math.random()*.18,phase:Math.random()*Math.PI*2,color:COLORS[Math.floor(Math.random()*COLORS.length)],life:0,maxLife:150+Math.random()*180}; }
        function spawnAll(){ particles=Array.from({length:30},mkParticle); }
        spawnAll();
        let lastFrame=0;
        (function tick(ts){
            if(ts-lastFrame<33){requestAnimationFrame(tick);return;} lastFrame=ts;
            bctx.clearRect(0,0,W,H); bctx.shadowBlur=0;
            particles.forEach((p,i)=>{
                p.life++; p.x+=p.vx+Math.sin(p.phase+p.life*.018)*.18; p.y+=p.vy;
                const t=p.life/p.maxLife;
                p.alpha=t<.15?(t/.15)*p.maxAlpha:t>.75?((1-t)/.25)*p.maxAlpha:p.maxAlpha;
                if(p.life>=p.maxLife||p.y<-10) particles[i]=mkParticle();
                bctx.beginPath(); bctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                bctx.fillStyle=p.color+p.alpha+')'; bctx.fill();
            }); requestAnimationFrame(tick);
        })(0);
    }

    const sp=document.getElementById('scroll-progress');
    window.addEventListener('scroll',()=>{ const pct=(document.documentElement.scrollTop/(document.documentElement.scrollHeight-window.innerHeight))*100; if(sp) sp.style.width=pct+'%'; },{passive:true});

    const navbar=document.querySelector('.main_menu');
    window.addEventListener('scroll',()=>{ if(navbar){ navbar.style.background=window.scrollY>60?'rgba(5,5,12,0.95)':''; navbar.style.padding=window.scrollY>60?'0':''; } },{passive:true});

    document.querySelectorAll('.navbar-nav .nav-link').forEach(link=>{
        link.style.position='relative'; link.style.overflow='hidden';
        link.addEventListener('click',function(e){ const rect=this.getBoundingClientRect(); const r=document.createElement('span'); r.className='ripple'; r.style.cssText=`width:40px;height:40px;left:${e.clientX-rect.left-20}px;top:${e.clientY-rect.top-20}px;`; this.appendChild(r); setTimeout(()=>r.remove(),500); });
    });

    if('IntersectionObserver' in window){
        const io=new IntersectionObserver(entries=>{ entries.forEach(e=>{ if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='none';io.unobserve(e.target);} }); },{threshold:.07});
        document.querySelectorAll('section > .container > .row > [class*="col"]').forEach(el=>{ el.style.opacity='0'; el.style.transform='translateY(20px)'; el.style.transition='opacity .55s ease,transform .55s ease'; io.observe(el); });
    }

    const logo=document.querySelector('.navbar-brand img');
    if(logo){ setInterval(()=>{ if(Math.random()>.88){ logo.animate([{filter:'none',transform:'none'},{filter:'hue-rotate(180deg) brightness(1.5)',transform:'skewX(-4deg) translateX(2px)'},{filter:'hue-rotate(-90deg)',transform:'skewX(3deg) translateX(-2px)'},{filter:'none',transform:'none'}],{duration:140,easing:'steps(3)'}); } },4000); }

    /* ══════════════════════════════════════════════════════════
       A11Y — KEYBOARD MODE + UTILITIES
    ══════════════════════════════════════════════════════════ */
    let isKeyboardUser = false;
    document.addEventListener('keydown', e => {
        if (e.key === 'Tab' && !isKeyboardUser) {
            isKeyboardUser = true;
            document.body.classList.add('et-keyboard');
        }
    });
    document.addEventListener('mousedown', () => {
        if (isKeyboardUser) {
            isKeyboardUser = false;
            document.body.classList.remove('et-keyboard');
        }
    });

    window.etAnnounce = function(msg, priority) {
        const el = document.getElementById(priority === 'assertive' ? 'et-a11y-assertive' : 'et-a11y-polite');
        if (!el) return;
        el.textContent = '';
        setTimeout(() => { el.textContent = msg; }, 80);
    };

    document.querySelectorAll('.alert').forEach(alert => {
        const msg = alert.textContent.replace(/×/g,'').trim();
        const isUrgent = alert.classList.contains('alert-danger') || alert.classList.contains('alert-warning');
        etAnnounce(msg, isUrgent ? 'assertive' : 'polite');
    });

    document.querySelectorAll('i.fas, i.fab, i.far').forEach(icon => {
        if (!icon.closest('[aria-label]') && !icon.getAttribute('aria-label')) {
            icon.setAttribute('aria-hidden', 'true');
        }
    });

    const skipLink = document.querySelector('.et-skip-nav');
    const mainEl   = document.getElementById('et-main');
    if (skipLink && mainEl) {
        skipLink.addEventListener('click', e => {
            e.preventDefault();
            mainEl.focus();
            mainEl.scrollIntoView({ behavior: 'smooth' });
        });
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('section > .container > .row > [class*="col"]').forEach(el => {
            el.style.opacity = '1'; el.style.transform = 'none'; el.style.transition = 'none';
        });
    }

    /* ══════════════════════════════════════════════════════════
       ACCESSIBILITY ASSISTANT — AI-POWERED WIDGET (ENGLISH)
    ══════════════════════════════════════════════════════════ */
    (function() {
        const a11yBtn   = document.getElementById('et-a11y-btn');
        const a11yPanel = document.getElementById('et-a11y-panel');
        const closeBtn  = document.getElementById('et-a11y-close');
        const chatEl    = document.getElementById('a11y-chat-messages');
        const inputEl   = document.getElementById('a11y-input');
        const sendBtn   = document.getElementById('a11y-send-btn');
        const micBtn    = document.getElementById('a11y-mic-btn');

        let isOpen    = false;
        let isLoading = false;
        let history   = [];

        const i18n = {
            welcome:      "Hello! I'm your accessibility assistant. How can I help you navigate EyeTwin?",
            placeholder:  "Ask your question…",
            sender:       "EyeTwin Assistant",
            loading:      "…",
            noReply:      "Sorry, no response.",
            announced:    "New response from assistant",
            listening:    "Listening, speak now",
            error:        "Connection error. Please check the server is running.",
            speak_on:     "Page reading started",
            speak_off:    "Reading stopped",
            contrast_on:  "High contrast mode enabled",
            contrast_off: "High contrast mode disabled",
            bigtext_on:   "Text enlarged",
            bigtext_off:  "Normal text size restored",
            dyslexia_on:  "Readability font enabled",
            dyslexia_off: "Normal font restored",
            guide_on:     "Reading guide enabled",
            guide_off:    "Reading guide disabled",
            focus_on:     "Keyboard focus mode enabled",
            focus_off:    "Keyboard focus mode disabled",
        };
        function t(key) { return i18n[key] || key; }

        function applyLang() {
            if (inputEl) inputEl.placeholder = t('placeholder');
            const welcomeEl = document.getElementById('a11y-welcome-msg');
            if (welcomeEl) {
                welcomeEl.innerHTML = `<span class="msg-sender">${t('sender')}</span>${t('welcome')}`;
            }
        }
        applyLang();

        const states = { contrast:false, bigtext:false, dyslexia:false, speak:false, guide:false, focus:false };
        let guideEl     = null;
        let speechSynth = window.speechSynthesis;
        let recognition = null;

        function openPanel() {
            isOpen = true;
            a11yPanel.classList.add('open');
            a11yBtn.setAttribute('aria-expanded','true');
            a11yPanel.setAttribute('aria-hidden','false');
            inputEl.focus();
        }
        function closePanel() {
            isOpen = false;
            a11yPanel.classList.remove('open');
            a11yBtn.setAttribute('aria-expanded','false');
            a11yPanel.setAttribute('aria-hidden','true');
            a11yBtn.focus();
        }

        a11yBtn.addEventListener('click', e => { e.stopPropagation(); isOpen ? closePanel() : openPanel(); });
        closeBtn.addEventListener('click', closePanel);
        document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) closePanel(); });
        document.addEventListener('click', e => {
            if (isOpen && !a11yPanel.contains(e.target) && e.target !== a11yBtn) closePanel();
        });

        document.querySelectorAll('.a11y-quick-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const action = btn.dataset.action;
                toggleFeature(action);
                btn.classList.toggle('active', states[action]);
                btn.setAttribute('aria-pressed', states[action] ? 'true' : 'false');
            });
        });

        function toggleFeature(action) {
            switch(action) {
                case 'contrast':
                    states.contrast = !states.contrast;
                    document.body.style.filter = states.contrast ? 'contrast(1.6) brightness(1.1)' : '';
                    etAnnounce(t(states.contrast ? 'contrast_on' : 'contrast_off'));
                    break;
                case 'bigtext':
                    states.bigtext = !states.bigtext;
                    document.documentElement.style.fontSize = states.bigtext ? '120%' : '';
                    etAnnounce(t(states.bigtext ? 'bigtext_on' : 'bigtext_off'));
                    break;
                case 'dyslexia':
                    states.dyslexia = !states.dyslexia;
                    if (states.dyslexia) {
                        const link = document.createElement('link');
                        link.id = 'dyslexia-font';
                        link.rel = 'stylesheet';
                        link.href = 'https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600&display=swap';
                        document.head.appendChild(link);
                        document.body.style.fontFamily = "'Lexend', sans-serif";
                    } else {
                        document.getElementById('dyslexia-font')?.remove();
                        document.body.style.fontFamily = '';
                    }
                    etAnnounce(t(states.dyslexia ? 'dyslexia_on' : 'dyslexia_off'));
                    break;
                case 'speak':
                    states.speak = !states.speak;
                    if (states.speak) {
                        const text = document.getElementById('et-main')?.innerText || document.body.innerText;
                        const utt  = new SpeechSynthesisUtterance(text.substring(0, 3000));
                        utt.lang = 'en-US';
                        utt.rate = 0.9;
                        utt.onend = () => {
                            states.speak = false;
                            document.querySelector('[data-action="speak"]')?.classList.remove('active');
                            document.querySelector('[data-action="speak"]')?.setAttribute('aria-pressed','false');
                        };
                        speechSynth.speak(utt);
                        etAnnounce(t('speak_on'));
                    } else {
                        speechSynth.cancel();
                        etAnnounce(t('speak_off'));
                    }
                    break;
                case 'guide':
                    states.guide = !states.guide;
                    if (states.guide) {
                        guideEl = document.createElement('div');
                        guideEl.style.cssText = 'position:fixed;left:0;right:0;height:3px;background:rgba(0,229,255,.5);pointer-events:none;z-index:99990;transition:top .1s;box-shadow:0 0 10px rgba(0,229,255,.4);';
                        document.body.appendChild(guideEl);
                        document.addEventListener('mousemove', moveGuide, {passive:true});
                        etAnnounce(t('guide_on'));
                    } else {
                        if (guideEl) { guideEl.remove(); guideEl = null; }
                        document.removeEventListener('mousemove', moveGuide);
                        etAnnounce(t('guide_off'));
                    }
                    break;
                case 'focus':
                    states.focus = !states.focus;
                    if (states.focus) {
                        const style = document.createElement('style');
                        style.id = 'et-focus-style';
                        style.textContent = '*:focus{outline:3px solid #f6d860!important;outline-offset:4px!important;box-shadow:0 0 0 6px rgba(246,216,96,.2)!important;}';
                        document.head.appendChild(style);
                        etAnnounce(t('focus_on'));
                    } else {
                        document.getElementById('et-focus-style')?.remove();
                        etAnnounce(t('focus_off'));
                    }
                    break;
            }
        }

        function moveGuide(e) {
            if (guideEl) guideEl.style.top = (e.clientY - 1) + 'px';
        }

        function executeCommands(text) {
            const commands = {
                '[CONTRASTE]':    () => { if (!states.contrast) toggleFeature('contrast'); document.querySelector('[data-action="contrast"]')?.classList.add('active'); document.querySelector('[data-action="contrast"]')?.setAttribute('aria-pressed','true'); },
                '[GRAND_TEXTE]':  () => { if (!states.bigtext)  toggleFeature('bigtext');  document.querySelector('[data-action="bigtext"]')?.classList.add('active');  document.querySelector('[data-action="bigtext"]')?.setAttribute('aria-pressed','true'); },
                '[DYSLEXIE]':     () => { if (!states.dyslexia) toggleFeature('dyslexia'); document.querySelector('[data-action="dyslexia"]')?.classList.add('active'); document.querySelector('[data-action="dyslexia"]')?.setAttribute('aria-pressed','true'); },
                '[LECTURE]':      () => { if (!states.speak)    toggleFeature('speak');    document.querySelector('[data-action="speak"]')?.classList.add('active');    document.querySelector('[data-action="speak"]')?.setAttribute('aria-pressed','true'); },
                '[STOP_LECTURE]': () => { speechSynth.cancel(); states.speak = false; document.querySelector('[data-action="speak"]')?.classList.remove('active'); document.querySelector('[data-action="speak"]')?.setAttribute('aria-pressed','false'); },
                '[GUIDE]':        () => { if (!states.guide)    toggleFeature('guide');    document.querySelector('[data-action="guide"]')?.classList.add('active');    document.querySelector('[data-action="guide"]')?.setAttribute('aria-pressed','true'); },
                '[FOCUS]':        () => { if (!states.focus)    toggleFeature('focus');    document.querySelector('[data-action="focus"]')?.classList.add('active');    document.querySelector('[data-action="focus"]')?.setAttribute('aria-pressed','true'); },
            };

            for (const [cmd, fn] of Object.entries(commands)) {
                if (text.includes(cmd)) fn();
            }

            const navMatch = text.match(/\[NAVIGATE:([^\]]+)\]/);
            if (navMatch) {
                let url = navMatch[1].trim();
                const urlFixes = {
                    '/planing':       '/planning',
                    '/plannig':       '/planning',
                    '/plannnig':      '/planning',
                    '/planing/':      '/planning',
                    '/tournoi':       '/tournaments/landing',
                    '/tournaments':   '/tournaments/landing',
                    '/tournament':    '/tournaments/landing',
                    '/tournaments/':  '/tournaments/landing',
                    '/video/upload':  '/upload',
                    '/video':         '/upload',
                    '/team':          '/teams/',
                    '/teams':         '/teams/',
                    '/community':     '/channels',
                    '/channel':       '/channels',
                    '/live':          '/live/',
                    '/coins':         '/coins/',
                    '/profile':       '/profile/',
                    '/complaints':    '/complaints/',
                    '/connexion':     '/login',
                    '/inscription':   '/register',
                };
                for (const [wrong, correct] of Object.entries(urlFixes)) {
                    if (url === wrong) { url = correct; break; }
                }
                setTimeout(() => { window.location.href = url; }, 1200);
            }

            return text.replace(/\[CONTRASTE\]|\[GRAND_TEXTE\]|\[DYSLEXIE\]|\[LECTURE\]|\[STOP_LECTURE\]|\[GUIDE\]|\[FOCUS\]|\[NAVIGATE:[^\]]*\]/g, '').trim();
        }

        function addMessage(content, role) {
            const div = document.createElement('div');
            div.className = `a11y-msg a11y-msg-${role === 'user' ? 'user' : 'bot'}`;
            if (role === 'bot') {
                div.innerHTML = `<span class="msg-sender">${t('sender')}</span>${escapeHtml(content)}`;
            } else {
                div.textContent = content;
            }
            chatEl.appendChild(div);
            chatEl.scrollTop = chatEl.scrollHeight;
            return div;
        }

        function escapeHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
        }

        async function sendMessage(userText) {
            if (!userText.trim() || isLoading) return;
            isLoading = true;

            addMessage(userText, 'user');
            history.push({ role: 'user', content: userText });
            inputEl.value = '';

            const loadingDiv = addMessage(t('loading'), 'bot');
            loadingDiv.classList.add('loading');

            try {
                const res = await fetch('/api/assistant', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ history, lang: 'en' })
                });

                const rawText = await res.text();

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status} — ${rawText.substring(0, 200)}`);
                }

                const data = JSON.parse(rawText);
                if (data.error) throw new Error(data.error);

                const rawReply   = data.reply || t('noReply');
                const cleanReply = executeCommands(rawReply);

                loadingDiv.classList.remove('loading');
                loadingDiv.innerHTML = `<span class="msg-sender">${t('sender')}</span>${escapeHtml(cleanReply)}`;
                history.push({ role: 'assistant', content: rawReply });
                etAnnounce(t('announced'));

            } catch (err) {
                loadingDiv.classList.remove('loading');
                loadingDiv.innerHTML = `<span class="msg-sender">${t('sender')}</span>${t('error')}`;
                console.error('[A11Y Assistant]', err);
            }

            isLoading = false;
        }

        sendBtn.addEventListener('click', () => sendMessage(inputEl.value));
        inputEl.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(inputEl.value); }
        });

        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SR();
            recognition.lang           = 'en-US';
            recognition.continuous     = false;
            recognition.interimResults = false;

            recognition.onresult = e => {
                const transcript = e.results[0][0].transcript;
                inputEl.value = transcript;
                micBtn.classList.remove('recording');
                sendMessage(transcript);
            };
            recognition.onerror = () => micBtn.classList.remove('recording');
            recognition.onend   = () => micBtn.classList.remove('recording');

            micBtn.addEventListener('click', () => {
                if (micBtn.classList.contains('recording')) {
                    recognition.stop();
                    micBtn.classList.remove('recording');
                } else {
                    recognition.start();
                    micBtn.classList.add('recording');
                    etAnnounce(t('listening'));
                }
            });
        } else {
            micBtn.style.display = 'none';
        }

    })();

})();
</script>
</body>
</html>
