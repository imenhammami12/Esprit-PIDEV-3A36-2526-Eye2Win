    .et-pd-item:hover .et-pd-ttl { color:var(--text)!important; }
    .et-pd-sub { font-family:var(--font-mono); font-size:.48rem; color:var(--muted); margin-top:1px; display:block; }
    .et-pd-arr { font-size:.45rem; color:rgba(255,255,255,.12); transition:all .18s; position:relative; z-index:1; }
    .et-pd-item:hover .et-pd-arr { color:var(--red-hot); transform:translateX(3px); }
    .et-pd-2fa .et-pd-ic { color:rgba(0,229,255,.6); }
    .et-pd-2fa:hover .et-pd-ic { background:rgba(0,229,255,.1); border-color:rgba(0,229,255,.35); box-shadow:0 0 10px rgba(0,229,255,.15); color:var(--cyan); }
    .et-pd-2fa:hover::before { background:linear-gradient(90deg,rgba(0,229,255,.07),transparent); }
    .et-pd-2fa:hover { border-color:rgba(0,229,255,.15); }
    .et-pd-support .et-pd-ic { color:rgba(255,107,43,.6); }
    .et-pd-support:hover .et-pd-ic { background:rgba(255,107,43,.1); border-color:rgba(255,107,43,.35); box-shadow:0 0 10px rgba(255,107,43,.15); color:var(--orange); }
    .et-pd-support:hover::before { background:linear-gradient(90deg,rgba(255,107,43,.07),transparent); }
    .et-pd-support:hover { border-color:rgba(255,107,43,.15); }
    .et-pd-admin .et-pd-ic { color:rgba(246,216,96,.6); }
    .et-pd-admin .et-pd-ttl { color:rgba(246,216,96,.7)!important; }
    .et-pd-admin:hover .et-pd-ic { background:rgba(246,216,96,.1); border-color:rgba(246,216,96,.35); box-shadow:0 0 10px rgba(246,216,96,.15); color:var(--gold); }
    .et-pd-admin:hover .et-pd-ttl { color:var(--gold)!important; }
    .et-pd-admin:hover::before { background:linear-gradient(90deg,rgba(246,216,96,.07),transparent); }
    .et-pd-admin:hover { border-color:rgba(246,216,96,.2); }
    .et-pd-logout .et-pd-ic { color:rgba(255,100,80,.5); }
    .et-pd-logout .et-pd-ttl { color:rgba(255,100,80,.55)!important; }
    .et-pd-logout:hover .et-pd-ic { background:rgba(255,80,60,.12); border-color:rgba(255,80,60,.4); box-shadow:0 0 10px rgba(255,80,60,.2); color:var(--red-hot); }
    .et-pd-logout:hover .et-pd-ttl { color:var(--red-hot)!important; }
    .et-pd-logout:hover::before { background:linear-gradient(90deg,rgba(255,80,60,.1),transparent); }
    .et-pd-logout:hover { border-color:rgba(255,80,60,.2); }
    .et-pd-divider { height:1px; margin:5px 7px; background:linear-gradient(90deg,transparent,rgba(232,55,42,.12),transparent); }
    .et-pd-footer { padding:10px 14px; background:rgba(246,216,96,.02); border-top:1px solid rgba(246,216,96,.07); display:flex; align-items:center; justify-content:space-between; }
    .et-pd-coins { font-family:var(--font-hud); font-size:.58rem; font-weight:700; letter-spacing:.08em; color:var(--gold); display:flex; align-items:center; gap:6px; }
    .et-pd-coins-val { color:#fff; }
    .et-pd-coins-btn { font-family:var(--font-hud); font-size:.46rem; letter-spacing:.1em; text-transform:uppercase; padding:4px 11px; border-radius:6px; background:rgba(246,216,96,.1); border:1px solid rgba(246,216,96,.22); color:var(--gold); transition:all .2s; text-decoration:none; display:inline-block; }
    .et-pd-coins-btn:hover { background:rgba(246,216,96,.18); border-color:rgba(246,216,96,.5); box-shadow:0 0 14px rgba(246,216,96,.18); color:var(--gold); text-decoration:none; }
    .alert { font-family:var(--font-mono)!important; font-size:.72rem!important; border-radius:10px!important; border:none!important; display:flex; align-items:center; gap:.6rem; animation:alert-in .4s cubic-bezier(.22,1,.36,1); }
    @keyframes alert-in { from{opacity:0;transform:translateY(-10px)} to{opacity:1;transform:none} }
    .alert-success { background:rgba(0,230,118,.1)!important; border-left:3px solid var(--green)!important; color:var(--green)!important; }
    .alert-danger  { background:rgba(232,55,42,.1)!important;  border-left:3px solid var(--red)!important;   color:var(--red-hot)!important; }
    .alert-warning { background:rgba(246,173,85,.1)!important; border-left:3px solid var(--gold)!important;  color:var(--gold)!important; }
    .alert-info    { background:rgba(0,229,255,.08)!important; border-left:3px solid var(--cyan)!important;  color:var(--cyan)!important; }
    .alert .close  { color:var(--muted)!important; opacity:1; }
    .footer_part { position:relative; background:var(--dark2)!important; border-top:1px solid rgba(232,55,42,.15)!important; overflow:hidden; }
    .footer_part::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--red),var(--orange),transparent); background-size:200% 100%; animation:shimmer-line 6s linear infinite reverse; }
    .footer_part::after { content:''; position:absolute; inset:0; pointer-events:none; background-image:linear-gradient(rgba(232,55,42,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(232,55,42,.025) 1px,transparent 1px); background-size:40px 40px; }
    .copygight_text { padding:1.2rem 0; }
    .copyright_text p { font-family:var(--font-mono)!important; font-size:.62rem!important; color:var(--muted)!important; letter-spacing:.08em; }
    .footer_icon.social_icon ul { display:flex; justify-content:flex-end; gap:.6rem; list-style:none; }
    .single_social_icon { width:36px; height:36px; border-radius:8px; background:rgba(255,255,255,.04); border:1px solid rgba(232,55,42,.15); display:flex; align-items:center; justify-content:center; color:var(--muted)!important; font-size:.8rem; transition:all .2s; position:relative; overflow:hidden; }
    .single_social_icon::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,var(--red-deep),var(--red)); opacity:0; transition:opacity .2s; }
    .single_social_icon:hover { color:#fff!important; border-color:var(--red)!important; transform:translateY(-3px); box-shadow:0 6px 20px rgba(232,55,42,.3); }
    .single_social_icon:hover::before { opacity:1; }
    .single_social_icon i { position:relative; z-index:1; }
    #page-loader { position:fixed; inset:0; z-index:99998; background:var(--dark); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:1.5rem; animation:loader-out .4s .8s forwards; pointer-events:none; }
    @keyframes loader-out { to{opacity:0;visibility:hidden} }
    .loader-logo { font-family:var(--font-hud); font-size:1.8rem; font-weight:900; color:var(--text); letter-spacing:.2em; animation:glitch-load 1s steps(2) infinite; }
    @keyframes glitch-load { 0%,100%{text-shadow:none} 25%{text-shadow:-3px 0 var(--red),3px 0 var(--cyan)} 50%{text-shadow:3px 0 var(--orange),-3px 0 var(--pink)} }
    .loader-bar-wrap { width:220px; height:3px; background:rgba(255,255,255,.07); border-radius:2px; overflow:hidden; }
    .loader-bar { height:100%; background:linear-gradient(90deg,var(--red),var(--orange),var(--pink)); border-radius:2px; animation:loader-fill .7s ease-out forwards; }
    @keyframes loader-fill { from{width:0} to{width:100%} }
    .loader-tag { font-family:var(--font-mono); font-size:.6rem; color:var(--muted); letter-spacing:.15em; text-transform:uppercase; animation:blink-text 1s step-end infinite; }
    @keyframes blink-text { 0%,100%{opacity:1} 50%{opacity:.2} }
    #scroll-progress { position:fixed; top:0; left:0; height:2px; z-index:9999; background:linear-gradient(90deg,var(--red),var(--orange),var(--pink)); width:0%; transition:width .1s linear; box-shadow:0 0 10px rgba(232,55,42,.6); }
    .hud-corner { position:fixed; z-index:500; pointer-events:none; width:40px; height:40px; border-color:rgba(232,55,42,.2); border-style:solid; }
    .hud-corner.tl { top:12px; left:12px; border-width:1.5px 0 0 1.5px; }
    .hud-corner.tr { top:12px; right:12px; border-width:1.5px 1.5px 0 0; }
    .hud-corner.bl { bottom:12px; left:12px; border-width:0 0 1.5px 1.5px; }
    .hud-corner.br { bottom:12px; right:12px; border-width:0 1.5px 1.5px 0; }
    ::-webkit-scrollbar { width:5px; }
    ::-webkit-scrollbar-track { background:var(--dark2); }
    ::-webkit-scrollbar-thumb { background:rgba(232,55,42,.4); border-radius:3px; }
    ::-webkit-scrollbar-thumb:hover { background:var(--red); }
    ::selection { background:rgba(232,55,42,.35); color:#fff; }
    .page-content { animation:page-fade-in .5s ease-out; }
    @keyframes page-fade-in { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }
    .ripple { position:absolute; border-radius:50%; background:rgba(232,55,42,.25); transform:scale(0); animation:ripple-anim .5s linear; pointer-events:none; }
    @keyframes ripple-anim { to{transform:scale(3);opacity:0} }

    /* ═══════════════════════════════════════
       UPLOADER DROPDOWN — dot accent
    ═══════════════════════════════════════ */
    .nav-uploader-toggle { display:inline-flex !important; align-items:center; gap:6px; }
    .nav-upload-dot {
        width:6px; height:6px; border-radius:50%;
        background:linear-gradient(135deg,var(--red-hot),var(--orange));
        box-shadow:0 0 6px rgba(232,55,42,.7);
        flex-shrink:0;
        animation:nav-pulse 2s ease-in-out infinite;
        display: inline-block;
    }

    /* ═══════════════════════════════════════════════════════
       A11Y — SKIP LINK + FOCUS + KEYBOARD
    ═══════════════════════════════════════════════════════ */
    .et-skip-nav {
        position: absolute; top: -100%; left: 16px; z-index: 999999;
        padding: 10px 20px;
        background: var(--dark); color: var(--red-hot);
        font-family: var(--font-hud); font-size: .7rem; font-weight: 700;
        letter-spacing: .12em; text-transform: uppercase; text-decoration: none;
        border: 1px solid var(--red); border-radius: 0 0 10px 10px;
        box-shadow: 0 4px 20px rgba(232,55,42,.4);
        transition: top .2s;
    }
    .et-skip-nav:focus { top: 0; outline: 3px solid var(--red-hot); outline-offset: 2px; }
    *:focus-visible { outline: 2px solid var(--red-hot) !important; outline-offset: 3px !important; border-radius: 4px; }
    *:focus:not(:focus-visible) { outline: none !important; }
    body.et-keyboard *, body.et-keyboard a, body.et-keyboard button, body.et-keyboard [role="button"] { cursor: auto !important; }
    body.et-keyboard #et-cursor-canvas { display: none !important; }
    .sr-only { position:absolute!important; width:1px!important; height:1px!important; padding:0!important; margin:-1px!important; overflow:hidden!important; clip:rect(0,0,0,0)!important; white-space:nowrap!important; border:0!important; }
    @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
        #et-cursor-canvas, body.et-keyboard #et-cursor-canvas { display: none !important; }
        *, a, button, [role="button"] { cursor: auto !important; }
    }
    @media (prefers-contrast: high) {
        .navbar-nav .nav-link { color: #fff !important; }
        .et-pd-ttl { color: rgba(255,255,255,.9) !important; }
    }
    #et-a11y-polite, #et-a11y-assertive {
        position:absolute; width:1px; height:1px; padding:0; margin:-1px;
        overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
    }

    /* ═══════════════════════════════════════════════════════
       ACCESSIBILITY ASSISTANT WIDGET
    ═══════════════════════════════════════════════════════ */
    #et-a11y-btn {
        position: fixed; bottom: 24px; left: 24px; z-index: 9996;
        width: 52px; height: 52px; border-radius: 14px;
        background: rgba(8,8,16,0.92); border: 1px solid rgba(0,229,255,0.4);
        box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 16px rgba(0,229,255,0.15);
        display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
        backdrop-filter: blur(12px);
        transition: transform .2s, box-shadow .2s, border-color .2s;
        cursor: none !important;
        animation: a11y-pulse 3s ease-in-out infinite;
    }
    @keyframes a11y-pulse {
        0%,100% { box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 16px rgba(0,229,255,0.15); }
        50%      { box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 28px rgba(0,229,255,0.4), 0 0 50px rgba(0,229,255,0.1); }
    }
    #et-a11y-btn:hover { transform: scale(1.08); border-color: rgba(0,229,255,0.8); box-shadow: 0 6px 30px rgba(0,0,0,0.7), 0 0 24px rgba(0,229,255,0.35); animation: none; }
    #et-a11y-panel {
        position: fixed; bottom: 88px; left: 24px; z-index: 9995;
        width: 340px; background: rgba(6,5,14,0.97);
        border: 1px solid rgba(0,229,255,0.2); border-radius: 18px;
        box-shadow: 0 20px 70px rgba(0,0,0,0.85), 0 0 0 1px rgba(0,229,255,0.06);
        backdrop-filter: blur(20px); transform-origin: bottom left;
        transition: opacity .25s cubic-bezier(.22,1,.36,1), transform .25s cubic-bezier(.22,1,.36,1);
        opacity: 0; transform: scale(0.88) translateY(10px); pointer-events: none; overflow: hidden;
    }
    #et-a11y-panel.open { opacity: 1; transform: scale(1) translateY(0); pointer-events: all; }
    .a11y-header {
        padding: 14px 16px 10px;
        background: linear-gradient(135deg, rgba(0,229,255,.08), rgba(191,90,242,.04));
        border-bottom: 1px solid rgba(0,229,255,.1);
        display: flex; align-items: center; justify-content: space-between;
        position: relative; overflow: hidden;
    }
    .a11y-header::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--cyan),transparent); background-size:200% 100%; animation:shimmer-line 3s linear infinite; }
    .a11y-header-title { font-family:var(--font-hud); font-size:.62rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--cyan); display:flex; align-items:center; gap:8px; }
    .a11y-close-btn { width:24px; height:24px; border-radius:6px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:var(--muted); font-size:.7rem; display:flex; align-items:center; justify-content:center; transition:all .15s; cursor:none !important; }
    .a11y-close-btn:hover { background:rgba(255,80,60,.15); border-color:rgba(255,80,60,.4); color:var(--red-hot); }
    .a11y-quick { display:grid; grid-template-columns:repeat(3,1fr); gap:6px; padding:12px; border-bottom:1px solid rgba(255,255,255,.05); }
    .a11y-quick-btn { display:flex; flex-direction:column; align-items:center; gap:5px; padding:10px 6px; border-radius:10px; border:1px solid rgba(255,255,255,.07); background:rgba(255,255,255,.03); transition:all .18s; cursor:none !important; }
    .a11y-quick-btn:hover { background:rgba(0,229,255,.08); border-color:rgba(0,229,255,.3); transform:translateY(-2px); }
    .a11y-quick-btn.active { background:rgba(0,229,255,.12); border-color:rgba(0,229,255,.5); box-shadow:0 0 12px rgba(0,229,255,.15); }
    .a11y-quick-icon { font-size:1.1rem; }
    .a11y-quick-label { font-family:var(--font-hud); font-size:.44rem; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:rgba(255,255,255,.45); text-align:center; line-height:1.2; }
    .a11y-quick-btn.active .a11y-quick-label { color:var(--cyan); }
    .a11y-chat { height:220px; overflow-y:auto; padding:12px; display:flex; flex-direction:column; gap:8px; scrollbar-width:thin; scrollbar-color:rgba(0,229,255,.2) transparent; }
    .a11y-chat::-webkit-scrollbar { width:3px; }
    .a11y-chat::-webkit-scrollbar-thumb { background:rgba(0,229,255,.25); border-radius:2px; }
    .a11y-msg { max-width:85%; padding:8px 12px; border-radius:10px; font-family:var(--font-body); font-size:.82rem; line-height:1.4; animation:msg-in .2s ease-out; }
    @keyframes msg-in { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }
    .a11y-msg-user { align-self:flex-end; background:rgba(0,229,255,.1); border:1px solid rgba(0,229,255,.25); color:rgba(255,255,255,.9); border-bottom-right-radius:3px; }
    .a11y-msg-bot { align-self:flex-start; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); color:rgba(255,255,255,.8); border-bottom-left-radius:3px; }
    .a11y-msg-bot.loading { color:var(--muted); font-style:italic; }
    .a11y-msg-bot .msg-sender { font-family:var(--font-hud); font-size:.44rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--cyan); display:block; margin-bottom:3px; }
    .a11y-input-row { display:flex; gap:6px; padding:10px 12px 12px; border-top:1px solid rgba(255,255,255,.05); align-items:center; }
    .a11y-input { flex:1; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:8px; padding:8px 12px; font-family:var(--font-body); font-size:.82rem; color:var(--text); outline:none; transition:border-color .15s; cursor:auto !important; }
    .a11y-input:focus { border-color:rgba(0,229,255,.4); box-shadow:0 0 0 2px rgba(0,229,255,.08); }
    .a11y-input::placeholder { color:var(--muted); }
    .a11y-send-btn, .a11y-mic-btn { width:34px; height:34px; border-radius:8px; border:1px solid rgba(0,229,255,.25); background:rgba(0,229,255,.08); color:var(--cyan); font-size:.85rem; display:flex; align-items:center; justify-content:center; transition:all .15s; cursor:none !important; flex-shrink:0; }
    .a11y-send-btn:hover { background:rgba(0,229,255,.18); border-color:rgba(0,229,255,.5); transform:scale(1.05); }
    .a11y-mic-btn { border-color:rgba(191,90,242,.25); background:rgba(191,90,242,.08); color:#bf5af2; }
    .a11y-mic-btn:hover { background:rgba(191,90,242,.18); border-color:rgba(191,90,242,.5); transform:scale(1.05); }
    .a11y-mic-btn.recording { background:rgba(232,55,42,.15); border-color:var(--red); color:var(--red-hot); animation:mic-pulse 1s ease-in-out infinite; }
    @keyframes mic-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(232,55,42,.4)} 50%{box-shadow:0 0 0 6px rgba(232,55,42,0)} }
    @media (prefers-contrast: high) {
        #et-a11y-panel { background:#000; border-color:#00e5ff; }
        .a11y-msg-user { background:#003040; }
        .a11y-input { background:#111; border-color:#00e5ff; color:#fff; }
    }
    </style>
</head>

<body data-user-id="{{ app.user ? app.user.id : '' }}">

{# ── A11Y: Live regions ── #}
<div id="et-a11y-polite"    role="status" aria-live="polite"    aria-atomic="true"></div>
<div id="et-a11y-assertive" role="alert"  aria-live="assertive" aria-atomic="true"></div>

{# ── A11Y: Skip link ── #}
<a href="#et-main" class="et-skip-nav">Skip to main content</a>

<canvas id="et-cursor-canvas" width="120" height="120" aria-hidden="true"></canvas>

<button id="et-cursor-btn"
        title="Change cursor"
