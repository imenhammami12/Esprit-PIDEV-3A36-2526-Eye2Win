    <style>
    /* ═══════════════════════════════════════════════════════
       EYETWIN — GAMING BASE THEME
    ═══════════════════════════════════════════════════════ */
    :root {
        --red:        #e8372a;
        --red-hot:    #ff4d3d;
        --red-deep:   #b02b20;
        --orange:     #ff6b2b;
        --pink:       #ff2060;
        --gold:       #f6d860;
        --green:      #00e676;
        --cyan:       #00e5ff;
        --dark:       #080810;
        --dark2:      #0d0c1a;
        --dark3:      #12101f;
        --text:       rgba(255,255,255,0.93);
        --muted:      rgba(255,255,255,0.38);
        --border-r:   rgba(232,55,42,0.25);
        --font-hud:   'Orbitron', sans-serif;
        --font-body:  'Rajdhani', sans-serif;
        --font-mono:  'Share Tech Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
        background: var(--dark);
        font-family: var(--font-body);
        color: var(--text);
        overflow-x: hidden;
        cursor: none;
    }

    /* ── CURSOR SYSTEM ── */
    *, a, button, [role="button"] { cursor: none !important; }

    #et-cursor-canvas {
        position: fixed;
        pointer-events: none;
        z-index: 99999;
        top: 0; left: 0;
        width: 80px; height: 80px;
        transform: translate(-200px, -200px);
        will-change: transform;
        image-rendering: pixelated;
    }

    /* ── CURSOR PICKER BUTTON ── */
    #et-cursor-btn {
        position: fixed;
        bottom: 24px; right: 24px;
        z-index: 9998;
        width: 46px; height: 46px;
        border-radius: 12px;
        background: rgba(8,8,16,0.92);
        border: 1px solid rgba(232,55,42,0.4);
        box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 12px rgba(232,55,42,0.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        backdrop-filter: blur(12px);
        transition: transform .2s, box-shadow .2s, border-color .2s;
        cursor: none !important;
    }
    #et-cursor-btn:hover {
        transform: scale(1.1);
        border-color: rgba(232,55,42,0.8);
        box-shadow: 0 6px 30px rgba(0,0,0,0.7), 0 0 20px rgba(232,55,42,0.3);
    }

    /* ── PICKER PANEL ── */
    #et-cursor-panel {
        position: fixed;
        bottom: 80px; right: 24px;
        z-index: 9997;
        background: rgba(8,8,16,0.96);
        border: 1px solid rgba(232,55,42,0.2);
        border-radius: 16px;
        padding: 12px;
        width: 200px;
        box-shadow: 0 16px 60px rgba(0,0,0,0.8), 0 0 0 1px rgba(232,55,42,0.06);
        backdrop-filter: blur(16px);
        transform-origin: bottom right;
        transition: opacity .22s cubic-bezier(.22,1,.36,1), transform .22s cubic-bezier(.22,1,.36,1);
        opacity: 0;
        transform: scale(0.88) translateY(8px);
        pointer-events: none;
    }
    #et-cursor-panel.open {
        opacity: 1;
        transform: scale(1) translateY(0);
        pointer-events: all;
    }
    #et-cursor-panel-title {
        font-family: 'Orbitron', sans-serif;
        font-size: .52rem;
        letter-spacing: .18em;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        margin-bottom: 10px;
        padding: 0 4px;
    }
    .et-cursor-opt {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border-radius: 9px;
        border: 1px solid transparent;
        margin-bottom: 4px;
        transition: background .15s, border-color .15s, transform .15s;
        cursor: none !important;
    }
    .et-cursor-opt:last-child { margin-bottom: 0; }
    .et-cursor-opt:hover {
        background: rgba(232,55,42,0.1);
        border-color: rgba(232,55,42,0.3);
        transform: translateX(-3px);
    }
    .et-cursor-opt.active {
        background: rgba(232,55,42,0.15);
        border-color: rgba(232,55,42,0.5);
    }
    .et-cursor-opt-icon {
        font-size: 1.1rem;
        width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 7px;
        background: rgba(255,255,255,0.05);
        flex-shrink: 0;
        transition: background .15s;
    }
    .et-cursor-opt:hover .et-cursor-opt-icon,
    .et-cursor-opt.active .et-cursor-opt-icon { background: rgba(232,55,42,0.2); }
    .et-cursor-opt-label {
        font-family: 'Orbitron', sans-serif;
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .1em;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
        line-height: 1.2;
    }
    .et-cursor-opt.active .et-cursor-opt-label { color: rgba(255,255,255,0.9); }
    .et-cursor-opt-sub {
        font-family: 'Share Tech Mono', monospace;
        font-size: .52rem;
        color: rgba(255,255,255,0.25);
        display: block;
        margin-top: 1px;
    }
    .et-cursor-opt.active .et-cursor-opt-sub { color: rgba(232,55,42,0.7); }
    .et-cursor-opt-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--red);
        margin-left: auto;
        opacity: 0;
        box-shadow: 0 0 6px rgba(232,55,42,0.8);
        transition: opacity .15s;
    }
    .et-cursor-opt.active .et-cursor-opt-dot { opacity: 1; }

    /* ── SPARK PARTICLES ── */
    .et-spark {
        position: fixed; pointer-events: none; z-index: 99998;
        border-radius: 50%;
        will-change: transform, opacity;
        animation: et-spark-fly var(--dur,.4s) ease-out forwards;
    }
    @keyframes et-spark-fly {
        0%   { opacity:1; transform:translate(-50%,-50%) translate(0,0) scale(1); }
        100% { opacity:0; transform:translate(-50%,-50%) translate(var(--sx),var(--sy)) scale(0); }
    }

    /* ── GLOBAL BACKGROUND ── */
    .body_bg { position: relative; min-height: 100vh; }
    .body_bg::before {
        content: '';
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background-image:
            linear-gradient(rgba(232,55,42,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(232,55,42,0.04) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: grid-drift 20s linear infinite;
    }
    @keyframes grid-drift { from{background-position:0 0} to{background-position:60px 60px} }
    .body_bg::after {
        content: '';
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
    }
    #bgCanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; width: 100%; height: 100%; }
    header, footer, main, section, .container { position: relative; z-index: 1; }

    /* ═══════════════════════════════════════
       NAVBAR
    ═══════════════════════════════════════ */
    .main_menu {
        position: sticky; top: 0; z-index: 1000;
        background: rgba(8,8,16,0.85) !important;
        backdrop-filter: blur(16px) saturate(1.2);
        border-bottom: 1px solid rgba(232,55,42,0.15);
        box-shadow: 0 2px 40px rgba(0,0,0,0.6), 0 1px 0 rgba(232,55,42,0.1);
        transition: background .3s;
    }
    .main_menu::after {
        content: '';
        position: absolute; bottom: -1px; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
        background-size: 300% 100%;
        animation: shimmer-line 4s linear infinite;
    }
    @keyframes shimmer-line { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .navbar-brand img {
        height: 42px; width: auto;
        filter: drop-shadow(0 0 12px rgba(232,55,42,0.4));
        transition: filter .3s, transform .3s;
    }
    .navbar-brand:hover img {
        filter: drop-shadow(0 0 22px rgba(232,55,42,0.7));
        transform: scale(1.04);
    }
    .navbar-nav .nav-link {
        font-family: var(--font-hud) !important;
        font-size: .65rem !important;
        font-weight: 600 !important;
        letter-spacing: .14em !important;
        text-transform: uppercase !important;
        color: var(--muted) !important;
        padding: .5rem .9rem !important;
        position: relative;
        transition: color .2s !important;
    }
    .navbar-nav .nav-link::after {
        content: '';
        position: absolute; bottom: -2px; left: 50%; right: 50%;
        height: 1px;
        background: linear-gradient(90deg, var(--red), var(--orange));
        transition: left .25s, right .25s;
    }
    .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active { color: var(--text) !important; }
    .navbar-nav .nav-link:hover::after { left: 10%; right: 10%; }
    .nav-live-link { color: var(--red-hot) !important; }
    .nav-live-link:hover { color: #fff !important; }
    .nav-live-dot {
        width: 7px; height: 7px;
        background: var(--red-hot); border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 8px var(--red);
        animation: nav-pulse 1.5s ease-in-out infinite;
    }
    @keyframes nav-pulse { 0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 8px var(--red)} 50%{opacity:.4;transform:scale(.7);box-shadow:0 0 3px var(--red)} }
    .nav-coins-pill {
        background: linear-gradient(90deg, #f6d860, #f6ad55);
        color: #1a1a2e !important;
        padding: 4px 12px !important;
        border-radius: 20px !important;
        font-family: var(--font-hud) !important;
        font-size: .6rem !important;
        font-weight: 800 !important;
        display: inline-flex; align-items: center; gap: 5px;
        box-shadow: 0 2px 12px rgba(246,216,96,.25);
        transition: box-shadow .2s, transform .2s !important;
    }
    .nav-coins-pill:hover { box-shadow: 0 4px 20px rgba(246,216,96,.5) !important; transform: translateY(-1px) !important; color: #1a1a2e !important; }
    .nav-bell { position: relative; }
    .nav-bell .badge {
        position: absolute; top: 0; right: -6px;
        background: var(--red) !important;
        font-size: .55rem; border-radius: 50%;
        width: 16px; height: 16px;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-hud);
        animation: badge-pop .3s cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 0 8px rgba(232,55,42,.5);
    }
    @keyframes badge-pop { from{transform:scale(0)} to{transform:scale(1)} }
    .dropdown-menu {
        background: rgba(10,9,20,0.97) !important;
        border: 1px solid rgba(232,55,42,.2) !important;
        border-radius: 12px !important;
        box-shadow: 0 16px 60px rgba(0,0,0,.8), 0 0 0 1px rgba(232,55,42,.08) !important;
        backdrop-filter: blur(12px);
        animation: dropdown-in .2s cubic-bezier(.22,1,.36,1);
        overflow: hidden;
    }
    @keyframes dropdown-in { from{opacity:0;transform:translateY(-8px) scale(.97)} to{opacity:1;transform:none} }
    .dropdown-item {
        font-family: var(--font-hud) !important;
        font-size: .62rem !important;
        letter-spacing: .1em !important;
        text-transform: uppercase !important;
        color: var(--muted) !important;
        padding: .6rem 1.1rem !important;
        display: flex; align-items: center; gap: .6rem;
        transition: background .15s, color .15s, padding-left .15s !important;
        border-left: 2px solid transparent;
    }
    .dropdown-item:hover { background: rgba(232,55,42,.1) !important; color: var(--red-hot) !important; padding-left: 1.4rem !important; border-left-color: var(--red) !important; }
    .dropdown-item i { width: 16px; text-align: center; color: rgba(232,55,42,.5); }
    .dropdown-item:hover i { color: var(--red-hot); }
    .dropdown-divider { border-color: rgba(232,55,42,.1) !important; margin: .2rem 0 !important; }
    .admin-link { color: var(--gold) !important; }
    .admin-link:hover { color: var(--gold) !important; background: rgba(246,216,96,.08) !important; border-left-color: var(--gold) !important; }
    .admin-link i { color: rgba(246,216,96,.5) !important; }
    .admin-link:hover i { color: var(--gold) !important; }
    .btn_1 {
        font-family: var(--font-hud) !important;
        font-size: .65rem !important;
        font-weight: 700 !important;
        letter-spacing: .12em !important;
        text-transform: uppercase !important;
        background: linear-gradient(135deg, var(--red-deep), var(--red), var(--red-hot)) !important;
        border: none !important; border-radius: 8px !important;
        color: #fff !important; padding: .5rem 1.4rem !important;
        box-shadow: 0 4px 20px rgba(232,55,42,.4) !important;
        transition: transform .2s, box-shadow .2s !important;
        position: relative; overflow: hidden;
    }
    .btn_1::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,.2), transparent); pointer-events: none; }
    .btn_1:hover { transform: translateY(-2px) !important; box-shadow: 0 8px 30px rgba(232,55,42,.6) !important; color: #fff !important; }
    .navbar-toggler { border: 1px solid rgba(232,55,42,.35) !important; border-radius: 6px !important; }
    .menu_icon i { color: var(--red-hot); }
    .notif-header { background: rgba(232,55,42,.08); border-bottom: 1px solid rgba(232,55,42,.15) !important; font-family: var(--font-hud); font-size: .68rem; letter-spacing: .1em; color: var(--text) !important; padding: .7rem 1rem !important; }
    .notif-body { background: rgba(8,8,16,.98) !important; max-height: 400px; overflow: auto; }
    .notif-body::-webkit-scrollbar { width: 4px; }
    .notif-body::-webkit-scrollbar-track { background: transparent; }
    .notif-body::-webkit-scrollbar-thumb { background: rgba(232,55,42,.3); border-radius: 2px; }
    .notif-item { border-bottom: 1px solid rgba(255,255,255,.06) !important; padding: .75rem 1rem !important; transition: background .15s; }
    .notif-item:hover { background: rgba(232,55,42,.05) !important; }
    .notif-item-unread { background: rgba(232,55,42,.04) !important; }
    .notif-msg { font-family: var(--font-body); font-size: .85rem; color: var(--text); }
    .notif-msg.read { color: var(--muted); }
    .notif-date { font-family: var(--font-mono); font-size: .6rem; color: var(--muted); margin-top: .2rem; }

    /* ═══════════════════════════════════════
       FLASH ALERTS
    ═══════════════════════════════════════ */
    .alert { font-family: var(--font-mono) !important; font-size: .72rem !important; border-radius: 10px !important; border: none !important; display: flex; align-items: center; gap: .6rem; animation: alert-in .4s cubic-bezier(.22,1,.36,1); }
    @keyframes alert-in { from{opacity:0;transform:translateY(-10px)} to{opacity:1;transform:none} }
    .alert-success { background: rgba(0,230,118,.1) !important; border-left: 3px solid var(--green) !important; color: var(--green) !important; }
    .alert-danger  { background: rgba(232,55,42,.1) !important; border-left: 3px solid var(--red) !important; color: var(--red-hot) !important; }
    .alert-warning { background: rgba(246,173,85,.1) !important; border-left: 3px solid var(--gold) !important; color: var(--gold) !important; }
    .alert-info    { background: rgba(0,229,255,.08) !important; border-left: 3px solid var(--cyan) !important; color: var(--cyan) !important; }
    .alert .close  { color: var(--muted) !important; opacity: 1; }

    /* ═══════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════ */
    .footer_part { position: relative; background: var(--dark2) !important; border-top: 1px solid rgba(232,55,42,.15) !important; overflow: hidden; }
    .footer_part::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--red), var(--orange), transparent); background-size: 200% 100%; animation: shimmer-line 6s linear infinite reverse; }
    .footer_part::after { content: ''; position: absolute; inset: 0; pointer-events: none; background-image: linear-gradient(rgba(232,55,42,.025) 1px, transparent 1px), linear-gradient(90deg, rgba(232,55,42,.025) 1px, transparent 1px); background-size: 40px 40px; }
    .copygight_text { padding: 1.2rem 0; }
    .copyright_text p { font-family: var(--font-mono) !important; font-size: .62rem !important; color: var(--muted) !important; letter-spacing: .08em; }
    .footer_icon.social_icon ul { display: flex; justify-content: flex-end; gap: .6rem; list-style: none; }
    .single_social_icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(255,255,255,.04); border: 1px solid rgba(232,55,42,.15); display: flex; align-items: center; justify-content: center; color: var(--muted) !important; font-size: .8rem; transition: all .2s; position: relative; overflow: hidden; }
    .single_social_icon::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, var(--red-deep), var(--red)); opacity: 0; transition: opacity .2s; }
    .single_social_icon:hover { color: #fff !important; border-color: var(--red) !important; transform: translateY(-3px); box-shadow: 0 6px 20px rgba(232,55,42,.3); }
    .single_social_icon:hover::before { opacity: 1; }
    .single_social_icon i { position: relative; z-index: 1; }

    /* ═══════════════════════════════════════
       GLITCH LOADER OVERLAY
    ═══════════════════════════════════════ */
    #page-loader { position: fixed; inset: 0; z-index: 99998; background: var(--dark); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1.5rem; animation: loader-out .4s .8s forwards; pointer-events: none; }
    @keyframes loader-out { to{opacity:0;visibility:hidden} }
    .loader-logo { font-family: var(--font-hud); font-size: 1.8rem; font-weight: 900; color: var(--text); letter-spacing: .2em; animation: glitch-load 1s steps(2) infinite; }
    @keyframes glitch-load {
        0%,100% { text-shadow:none; }
        25% { text-shadow:-3px 0 var(--red),3px 0 var(--cyan); }
        50% { text-shadow:3px 0 var(--orange),-3px 0 var(--pink); }
    }
    .loader-bar-wrap { width: 220px; height: 3px; background: rgba(255,255,255,.07); border-radius: 2px; overflow: hidden; }
    .loader-bar { height: 100%; background: linear-gradient(90deg, var(--red), var(--orange), var(--pink)); border-radius: 2px; animation: loader-fill .7s ease-out forwards; }
    @keyframes loader-fill { from{width:0} to{width:100%} }
    .loader-tag { font-family: var(--font-mono); font-size: .6rem; color: var(--muted); letter-spacing: .15em; text-transform: uppercase; animation: blink-text 1s step-end infinite; }
    @keyframes blink-text { 0%,100%{opacity:1} 50%{opacity:.2} }

    /* ═══════════════════════════════════════
       SCROLL PROGRESS BAR
    ═══════════════════════════════════════ */
    #scroll-progress { position: fixed; top: 0; left: 0; height: 2px; z-index: 9999; background: linear-gradient(90deg, var(--red), var(--orange), var(--pink)); width: 0%; transition: width .1s linear; box-shadow: 0 0 10px rgba(232,55,42,.6); }

    /* ═══════════════════════════════════════
       CORNER HUD DECORATION
    ═══════════════════════════════════════ */
    .hud-corner { position: fixed; z-index: 500; pointer-events: none; width: 40px; height: 40px; border-color: rgba(232,55,42,.2); border-style: solid; }
    .hud-corner.tl { top: 12px; left: 12px; border-width: 1.5px 0 0 1.5px; }
    .hud-corner.tr { top: 12px; right: 12px; border-width: 1.5px 1.5px 0 0; }
    .hud-corner.bl { bottom: 12px; left: 12px; border-width: 0 0 1.5px 1.5px; }
    .hud-corner.br { bottom: 12px; right: 12px; border-width: 0 1.5px 1.5px 0; }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--dark2); }
    ::-webkit-scrollbar-thumb { background: rgba(232,55,42,.4); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--red); }
    ::selection { background: rgba(232,55,42,.35); color: #fff; }

    .page-content { animation: page-fade-in .5s ease-out; }
    @keyframes page-fade-in { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:none} }

    .ripple { position: absolute; border-radius: 50%; background: rgba(232,55,42,.25); transform: scale(0); animation: ripple-anim .5s linear; pointer-events: none; }
    @keyframes ripple-anim { to{transform:scale(3);opacity:0} }
    </style>
</head>

