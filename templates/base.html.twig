    <style>
    /* ═══════════════════════════════════════════════════════
       EYETWIN — GAMING BASE THEME v2
    ═══════════════════════════════════════════════════════ */
    :root {
        --red:       #e8372a; --red-hot: #ff4d3d; --red-deep: #b02b20;
        --orange:    #ff6b2b; --pink:    #ff2060; --gold:     #f6d860;
        --green:     #00e676; --cyan:    #00e5ff;
        --dark:      #080810; --dark2:   #0d0c1a; --dark3:    #12101f;
        --text:      rgba(255,255,255,0.93); --muted: rgba(255,255,255,0.38);
        --border-r:  rgba(232,55,42,0.25);
        --font-hud:  'Orbitron', sans-serif;
        --font-body: 'Rajdhani', sans-serif;
        --font-mono: 'Share Tech Mono', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--dark); font-family: var(--font-body); color: var(--text); overflow-x: hidden; cursor: none; }
    *, a, button, [role="button"] { cursor: none !important; }

    #et-cursor-canvas {
        position: fixed; pointer-events: none; z-index: 99999;
        top: 0; left: 0; width: 120px; height: 120px;
        transform: translate(-300px,-300px); will-change: transform;
    }
    #et-cursor-btn {
        position: fixed; bottom: 24px; right: 24px; z-index: 9998;
        width: 46px; height: 46px; border-radius: 12px;
        background: rgba(8,8,16,0.92); border: 1px solid rgba(232,55,42,0.4);
        box-shadow: 0 4px 24px rgba(0,0,0,0.6), 0 0 12px rgba(232,55,42,0.15);
        display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
        backdrop-filter: blur(12px); transition: transform .2s, box-shadow .2s, border-color .2s;
        cursor: none !important;
    }
    #et-cursor-btn:hover { transform: scale(1.1); border-color: rgba(232,55,42,0.8); box-shadow: 0 6px 30px rgba(0,0,0,0.7), 0 0 20px rgba(232,55,42,0.3); }
    #et-cursor-panel {
        position: fixed; bottom: 80px; right: 24px; z-index: 9997;
        background: rgba(8,8,16,0.96); border: 1px solid rgba(232,55,42,0.2);
        border-radius: 16px; padding: 12px; width: 200px;
        box-shadow: 0 16px 60px rgba(0,0,0,0.8), 0 0 0 1px rgba(232,55,42,0.06);
        backdrop-filter: blur(16px); transform-origin: bottom right;
        transition: opacity .22s cubic-bezier(.22,1,.36,1), transform .22s cubic-bezier(.22,1,.36,1);
        opacity: 0; transform: scale(0.88) translateY(8px); pointer-events: none;
    }
    #et-cursor-panel.open { opacity: 1; transform: scale(1) translateY(0); pointer-events: all; }
    #et-cursor-panel-title { font-family:'Orbitron',sans-serif; font-size:.52rem; letter-spacing:.18em; color:rgba(255,255,255,0.35); text-transform:uppercase; margin-bottom:10px; padding:0 4px; }
    .et-cursor-opt { display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:9px; border:1px solid transparent; margin-bottom:4px; transition:background .15s,border-color .15s,transform .15s; cursor:none !important; }
    .et-cursor-opt:last-child { margin-bottom:0; }
    .et-cursor-opt:hover { background:rgba(232,55,42,0.1); border-color:rgba(232,55,42,0.3); transform:translateX(-3px); }
    .et-cursor-opt.active { background:rgba(232,55,42,0.15); border-color:rgba(232,55,42,0.5); }
    .et-cursor-opt-icon { font-size:1.1rem; width:28px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:7px; background:rgba(255,255,255,0.05); flex-shrink:0; transition:background .15s; }
    .et-cursor-opt:hover .et-cursor-opt-icon, .et-cursor-opt.active .et-cursor-opt-icon { background:rgba(232,55,42,0.2); }
    .et-cursor-opt-label { font-family:'Orbitron',sans-serif; font-size:.58rem; font-weight:600; letter-spacing:.1em; color:rgba(255,255,255,0.5); text-transform:uppercase; line-height:1.2; }
    .et-cursor-opt.active .et-cursor-opt-label { color:rgba(255,255,255,0.9); }
    .et-cursor-opt-sub { font-family:'Share Tech Mono',monospace; font-size:.52rem; color:rgba(255,255,255,0.25); display:block; margin-top:1px; }
    .et-cursor-opt.active .et-cursor-opt-sub { color:rgba(232,55,42,0.7); }
    .et-cursor-opt-dot { width:6px; height:6px; border-radius:50%; background:var(--red); margin-left:auto; opacity:0; box-shadow:0 0 6px rgba(232,55,42,0.8); transition:opacity .15s; }
    .et-cursor-opt.active .et-cursor-opt-dot { opacity:1; }
    .et-spark { position:fixed; pointer-events:none; z-index:99998; border-radius:50%; will-change:transform,opacity; animation:et-spark-fly var(--dur,.4s) ease-out forwards; }
    @keyframes et-spark-fly { 0%{opacity:1;transform:translate(-50%,-50%) translate(0,0) scale(1)} 100%{opacity:0;transform:translate(-50%,-50%) translate(var(--sx),var(--sy)) scale(0)} }
    .body_bg { position:relative; min-height:100vh; }
    .body_bg::before {
        content:''; position:fixed; inset:0; z-index:0; pointer-events:none;
        background-image: linear-gradient(rgba(232,55,42,0.04) 1px,transparent 1px), linear-gradient(90deg,rgba(232,55,42,0.04) 1px,transparent 1px);
        background-size:60px 60px; animation:grid-drift 20s linear infinite;
    }
    @keyframes grid-drift { from{background-position:0 0} to{background-position:60px 60px} }
    .body_bg::after { content:''; position:fixed; inset:0; z-index:0; pointer-events:none; background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.03) 3px,rgba(0,0,0,0.03) 4px); }
    #bgCanvas { position:fixed; inset:0; z-index:0; pointer-events:none; width:100%; height:100%; }
    header, footer, main, section, .container { position:relative; z-index:1; }
    .main_menu {
        position:sticky; top:0; z-index:1000;
        background:rgba(8,8,16,0.85) !important; backdrop-filter:blur(16px) saturate(1.2);
        border-bottom:1px solid rgba(232,55,42,0.15);
        box-shadow:0 2px 40px rgba(0,0,0,0.6), 0 1px 0 rgba(232,55,42,0.1); transition:background .3s;
    }
    .main_menu::after {
        content:''; position:absolute; bottom:-1px; left:0; right:0; height:1px;
        background:linear-gradient(90deg,transparent,var(--red),var(--orange),var(--pink),transparent);
        background-size:300% 100%; animation:shimmer-line 4s linear infinite;
    }
    @keyframes shimmer-line { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .navbar-brand img { height:42px; width:auto; filter:drop-shadow(0 0 12px rgba(232,55,42,0.4)); transition:filter .3s,transform .3s; }
    .navbar-brand:hover img { filter:drop-shadow(0 0 22px rgba(232,55,42,0.7)); transform:scale(1.04); }
    .navbar-nav .nav-link { font-family:var(--font-hud)!important; font-size:.65rem!important; font-weight:600!important; letter-spacing:.14em!important; text-transform:uppercase!important; color:var(--muted)!important; padding:.5rem .9rem!important; position:relative; transition:color .2s!important; }
    .navbar-nav .nav-link::after { content:''; position:absolute; bottom:-2px; left:50%; right:50%; height:1px; background:linear-gradient(90deg,var(--red),var(--orange)); transition:left .25s,right .25s; }
    .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active { color:var(--text)!important; }
    .navbar-nav .nav-link:hover::after { left:10%; right:10%; }
    .nav-live-link { color:var(--red-hot)!important; }
    .nav-live-link:hover { color:#fff!important; }
    .nav-live-dot { width:7px; height:7px; background:var(--red-hot); border-radius:50%; display:inline-block; box-shadow:0 0 8px var(--red); animation:nav-pulse 1.5s ease-in-out infinite; }
    @keyframes nav-pulse { 0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 8px var(--red)} 50%{opacity:.4;transform:scale(.7);box-shadow:0 0 3px var(--red)} }
    .nav-coins-pill { background:linear-gradient(90deg,#f6d860,#f6ad55); color:#1a1a2e!important; padding:4px 12px!important; border-radius:20px!important; font-family:var(--font-hud)!important; font-size:.6rem!important; font-weight:800!important; display:inline-flex; align-items:center; gap:5px; box-shadow:0 2px 12px rgba(246,216,96,.25); transition:box-shadow .2s,transform .2s!important; }
    .nav-coins-pill:hover { box-shadow:0 4px 20px rgba(246,216,96,.5)!important; transform:translateY(-1px)!important; color:#1a1a2e!important; }
    .nav-bell { position:relative; }
    .nav-bell .badge { position:absolute; top:0; right:-6px; background:var(--red)!important; font-size:.55rem; border-radius:50%; width:16px; height:16px; display:flex; align-items:center; justify-content:center; font-family:var(--font-hud); animation:badge-pop .3s cubic-bezier(.34,1.56,.64,1); box-shadow:0 0 8px rgba(232,55,42,.5); }
    @keyframes badge-pop { from{transform:scale(0)} to{transform:scale(1)} }
    .dropdown-menu { background:rgba(10,9,20,0.97)!important; border:1px solid rgba(232,55,42,.2)!important; border-radius:12px!important; box-shadow:0 16px 60px rgba(0,0,0,.8),0 0 0 1px rgba(232,55,42,.08)!important; backdrop-filter:blur(12px); animation:dropdown-in .2s cubic-bezier(.22,1,.36,1); overflow:hidden; }
    @keyframes dropdown-in { from{opacity:0;transform:translateY(-8px) scale(.97)} to{opacity:1;transform:none} }
    .dropdown-item { font-family:var(--font-hud)!important; font-size:.62rem!important; letter-spacing:.1em!important; text-transform:uppercase!important; color:var(--muted)!important; padding:.6rem 1.1rem!important; display:flex; align-items:center; gap:.6rem; transition:background .15s,color .15s,padding-left .15s!important; border-left:2px solid transparent; }
    .dropdown-item:hover { background:rgba(232,55,42,.1)!important; color:var(--red-hot)!important; padding-left:1.4rem!important; border-left-color:var(--red)!important; }
    .dropdown-item i { width:16px; text-align:center; color:rgba(232,55,42,.5); }
    .dropdown-item:hover i { color:var(--red-hot); }
    .dropdown-divider { border-color:rgba(232,55,42,.1)!important; margin:.2rem 0!important; }
    .btn_1 { font-family:var(--font-hud)!important; font-size:.65rem!important; font-weight:700!important; letter-spacing:.12em!important; text-transform:uppercase!important; background:linear-gradient(135deg,var(--red-deep),var(--red),var(--red-hot))!important; border:none!important; border-radius:8px!important; color:#fff!important; padding:.5rem 1.4rem!important; box-shadow:0 4px 20px rgba(232,55,42,.4)!important; transition:transform .2s,box-shadow .2s!important; position:relative; overflow:hidden; }
    .btn_1::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,.2),transparent); pointer-events:none; }
    .btn_1:hover { transform:translateY(-2px)!important; box-shadow:0 8px 30px rgba(232,55,42,.6)!important; color:#fff!important; }
    .navbar-toggler { border:1px solid rgba(232,55,42,.35)!important; border-radius:6px!important; }
    .menu_icon i { color:var(--red-hot); }
    .notif-header { background:rgba(232,55,42,.08); border-bottom:1px solid rgba(232,55,42,.15)!important; font-family:var(--font-hud); font-size:.68rem; letter-spacing:.1em; color:var(--text)!important; padding:.7rem 1rem!important; }
    .notif-body { background:rgba(8,8,16,.98)!important; max-height:400px; overflow:auto; }
    .notif-body::-webkit-scrollbar { width:4px; }
    .notif-body::-webkit-scrollbar-track { background:transparent; }
    .notif-body::-webkit-scrollbar-thumb { background:rgba(232,55,42,.3); border-radius:2px; }
    .notif-item { border-bottom:1px solid rgba(255,255,255,.06)!important; padding:.75rem 1rem!important; transition:background .15s; }
    .notif-item:hover { background:rgba(232,55,42,.05)!important; }
    .notif-item-unread { background:rgba(232,55,42,.04)!important; }
    .notif-msg { font-family:var(--font-body); font-size:.85rem; color:var(--text); }
    .notif-msg.read { color:var(--muted); }
    .notif-date { font-family:var(--font-mono); font-size:.6rem; color:var(--muted); margin-top:.2rem; }
    .et-profile-trigger {
        display:inline-flex; align-items:center; gap:9px;
        padding:5px 12px 5px 5px;
        background:rgba(255,255,255,0.03);
        border:1px solid rgba(232,55,42,0.18);
        border-radius:50px;
        transition:all .25s;
        backdrop-filter:blur(8px);
        text-decoration:none !important;
    }
    .et-profile-trigger:hover, .et-profile-trigger.show {
        background:rgba(232,55,42,0.09); border-color:rgba(232,55,42,0.5);
        box-shadow:0 0 20px rgba(232,55,42,0.12); text-decoration:none;
    }
    .et-pf-av { position:relative; width:30px; height:30px; flex-shrink:0; }
    .et-pf-av-inner {
        width:30px; height:30px; border-radius:50%;
        background:linear-gradient(135deg,var(--red-deep),var(--red-hot));
        display:flex; align-items:center; justify-content:center;
        font-size:.68rem; font-weight:900; color:#fff; font-family:var(--font-hud);
        position:relative; z-index:1;
    }
    .et-pf-av-ring {
        position:absolute; inset:-2px; border-radius:50%;
        background:conic-gradient(var(--red),var(--orange),var(--pink),var(--red));
        animation:et-ring-spin 4s linear infinite; opacity:0; transition:opacity .3s;
    }
    .et-pf-av-ring::after { content:''; position:absolute; inset:2px; border-radius:50%; background:var(--dark); }
    .et-profile-trigger:hover .et-pf-av-ring,
    .et-profile-trigger.show .et-pf-av-ring { opacity:1; }
    @keyframes et-ring-spin { to{transform:rotate(360deg)} }
    .et-pf-dot {
        position:absolute; bottom:0; right:0;
        width:8px; height:8px; border-radius:50%;
        background:var(--green); border:2px solid var(--dark); z-index:2;
        box-shadow:0 0 6px rgba(0,230,118,.8);
        animation:et-dot-pulse 2s ease-in-out infinite;
    }
    @keyframes et-dot-pulse { 0%,100%{box-shadow:0 0 6px rgba(0,230,118,.8)} 50%{box-shadow:0 0 14px rgba(0,230,118,1),0 0 24px rgba(0,230,118,.3)} }
    .et-pf-name { font-family:var(--font-hud)!important; font-size:.6rem!important; font-weight:700!important; letter-spacing:.1em!important; color:var(--text)!important; text-transform:uppercase!important; line-height:1; }
    .et-pf-chevron { font-size:.45rem; color:var(--muted); transition:transform .25s,color .25s; margin-left:2px; }
    .et-profile-trigger.show .et-pf-chevron { transform:rotate(180deg); color:var(--red-hot); }
    .et-profile-menu {
        min-width:280px!important; padding:0!important;
        background:rgba(7,5,16,0.98)!important;
        border:1px solid rgba(232,55,42,0.15)!important;
        border-radius:16px!important;
        box-shadow:0 24px 80px rgba(0,0,0,.9),0 0 0 1px rgba(232,55,42,.05),0 0 50px rgba(232,55,42,.04) inset!important;
        backdrop-filter:blur(24px)!important;
        overflow:hidden!important;
        animation:et-pd-in .22s cubic-bezier(.22,1,.36,1)!important;
    }
    @keyframes et-pd-in { from{opacity:0;transform:translateY(-8px) scale(.95)} to{opacity:1;transform:none} }
    .et-pd-header {
        position:relative; padding:18px 18px 14px;
        background:linear-gradient(135deg,rgba(232,55,42,.1),rgba(255,107,43,.05),rgba(255,32,96,.03));
        border-bottom:1px solid rgba(232,55,42,.1); overflow:hidden;
    }
    .et-pd-header::before { content:''; position:absolute; inset:0; background:repeating-linear-gradient(-45deg,transparent,transparent 8px,rgba(232,55,42,.025) 8px,rgba(232,55,42,.025) 9px); }
    .et-pd-scanline { position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--red),var(--orange),transparent); background-size:200% 100%; animation:shimmer-line 3s linear infinite; }
    .et-pd-row { display:flex; align-items:center; gap:13px; position:relative; z-index:1; }
    .et-pd-av-lg { position:relative; width:48px; height:48px; flex-shrink:0; }
    .et-pd-av-glow { position:absolute; inset:-3px; border-radius:12px; background:conic-gradient(var(--red),var(--orange),var(--pink),var(--red)); animation:et-ring-spin 6s linear infinite; opacity:.4; }
    .et-pd-av-glow::after { content:''; position:absolute; inset:2.5px; border-radius:10px; background:var(--dark2); }
    .et-pd-av-inner { width:48px; height:48px; border-radius:10px; background:linear-gradient(135deg,#180808,var(--red-deep)); border:1px solid rgba(232,55,42,.3); display:flex; align-items:center; justify-content:center; font-family:var(--font-hud); font-size:1.15rem; font-weight:900; color:#fff; position:relative; z-index:1; }
    .et-pd-info { flex:1; min-width:0; }
    .et-pd-uname { font-family:var(--font-hud); font-size:.72rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .et-pd-email { font-family:var(--font-mono); font-size:.52rem; color:var(--muted); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .et-pd-badges { display:flex; gap:5px; margin-top:7px; flex-wrap:wrap; }
    .et-pd-badge { font-family:var(--font-hud); font-size:.46rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; padding:2px 7px; border-radius:4px; }
