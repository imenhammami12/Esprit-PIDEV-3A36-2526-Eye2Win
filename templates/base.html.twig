<script>
(function () {
    'use strict';

    /* ══════════════════════════════════════════════════════════
       EYETWIN — GAMING CURSOR SYSTEM v2
       Canvas 120×120 | Crosshair 10 layers | localStorage
    ══════════════════════════════════════════════════════════ */
    const STORAGE_KEY = 'et_cursor_type';
    const CURSORS     = ['crosshair','sword','energy','arrow'];
    const ICONS       = { crosshair:'🎯', sword:'⚔️', energy:'⚡', arrow:'🏹' };

    let cursorType = localStorage.getItem(STORAGE_KEY) || 'crosshair';
    let mouseX = -300, mouseY = -300;
    let isHover = false, isClick = false, clickTime = 0;
    let energyOrbit = 0, arrowTension = 0;
    let trailPoints = [], rafPending = false;

    const canvas = document.getElementById('et-cursor-canvas');
    const ctx    = canvas.getContext('2d', { alpha:true, desynchronized:true });
    const CX = 60, CY = 60; // centre du canvas 120×120

    const HOTSPOT = {
        crosshair:{ x:60, y:60 }, sword:{ x:4, y:4 },
        energy:{ x:60, y:60 },    arrow:{ x:60, y:20 },
    };

    /* ── Mouse events ── */
    document.addEventListener('mousemove', e => {
        trailPoints.push({ x:mouseX, y:mouseY, t:performance.now() });
        if (trailPoints.length > 8) trailPoints.shift();
        mouseX = e.clientX; mouseY = e.clientY;
        if (!rafPending) { rafPending=true; requestAnimationFrame(loop); }
    }, { passive:true });
    document.addEventListener('mouseover', e => {
        isHover = !!e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt,.et-pd-item,.et-profile-trigger');
    }, { passive:true });
    document.addEventListener('mouseout', e => {
        if (e.target.closest('a,button,[role="button"],input,select,textarea,label,.et-cursor-opt,.et-pd-item,.et-profile-trigger')) isHover=false;
    }, { passive:true });
    document.addEventListener('mousedown', ()=>{ isClick=true; clickTime=performance.now(); spawnSparks(mouseX,mouseY); });
    document.addEventListener('mouseup',   ()=>{ isClick=false; });

    /* ── Sparks ── */
    const SPARK_PAL = {
        crosshair:['#e8372a','#ff4d3d','#ff6b2b','#fff','rgba(232,55,42,.5)'],
        sword:['#ff4d3d','#ff6b2b','#ff2060','#fff','#f6d860'],
        energy:['#00e5ff','#bf5af2','#30d5c8','#fff'],
        arrow:['#f6d860','#f6ad55','#fff'],
    };
    function spawnSparks(x,y) {
        const pal=SPARK_PAL[cursorType], count=cursorType==='crosshair'?10:6;
        for (let i=0;i<count;i++) {
            const sp=document.createElement('div'); sp.className='et-spark';
            const angle=(i/count)*Math.PI*2+Math.random()*.5;
            const dist=22+Math.random()*42, size=1.5+Math.random()*2.5, dur=.2+Math.random()*.25;
            sp.style.cssText=`left:${x}px;top:${y}px;width:${size}px;height:${size}px;background:${pal[i%pal.length]};--sx:${Math.cos(angle)*dist}px;--sy:${Math.sin(angle)*dist}px;--dur:${dur}s`;
            document.body.appendChild(sp); setTimeout(()=>sp.remove(),dur*1000+60);
        }
    }

    /* ══════════════════════════════════════════
       DRAW: CROSSHAIR v2 — 10 couches animées
    ══════════════════════════════════════════ */
    let radarAngle=0, scanRot=0;

    function drawCrosshair(ts) {
        radarAngle = ts*.002; scanRot = ts*.0012;
        const pulse   = .5+.5*Math.sin(ts*.003);
        const breathe = Math.sin(ts*.0028);
        const gap = isClick?16:(isHover?11:8);
        const len = isClick?9:(isHover?15:18);
        const thick = isHover?1.6:1.2;

        ctx.save(); ctx.translate(CX,CY);

        /* 1 — Ghost trail mini-crosshairs */
        const now=performance.now();
        trailPoints.forEach(p=>{
            const age=(now-p.t)/200; if(age>1) return;
            const dx=(p.x-mouseX)*.4*(1-age), dy=(p.y-mouseY)*.4*(1-age);
            const sc=.45+.45*(1-age), mg=gap*sc, ml=len*sc;
            ctx.save(); ctx.translate(dx,dy); ctx.globalAlpha=(1-age)*.1;
            ctx.strokeStyle='#e8372a'; ctx.lineWidth=.7; ctx.lineCap='round';
            [[0,-ml,0,-mg],[0,mg,0,ml],[-ml,0,-mg,0],[mg,0,ml,0]].forEach(([x1,y1,x2,y2])=>{
                ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
            }); ctx.restore();
        }); ctx.globalAlpha=1;

        /* 2 — Outermost ring */
        ctx.beginPath(); ctx.arc(0,0,38+breathe,0,Math.PI*2);
        ctx.strokeStyle=`rgba(232,55,42,${.05+.04*pulse})`; ctx.lineWidth=.6; ctx.stroke();

        /* 3 — Radar sweep */
        ctx.save(); ctx.rotate(radarAngle);
        for(let i=0;i<40;i++){
            const a=-(i/40)*Math.PI*.85, fade=1-i/40;
            ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,28,a-.04,a+.04); ctx.closePath();
            ctx.fillStyle=`rgba(232,55,42,${fade*.3})`; ctx.fill();
        } ctx.restore();

        /* 4 — Outer segmented ring (8 arcs, counter-rotate) */
        ctx.lineWidth=.9;
        for(let i=0;i<8;i++){
            const startA=(i/8)*Math.PI*2+scanRot, endA=startA+(Math.PI*2/8)-.2;
            ctx.beginPath(); ctx.arc(0,0,26,startA,endA);
            ctx.strokeStyle=`rgba(232,55,42,${.28+.15*pulse})`; ctx.stroke();
        }

        /* 5 — Inner ring */
        ctx.beginPath(); ctx.arc(0,0,12+(isHover?2:0),0,Math.PI*2);
        ctx.strokeStyle=`rgba(232,55,42,${.55+.3*pulse})`; ctx.lineWidth=isHover?1.2:.9; ctx.stroke();

        /* 6 — 4 diagonal tick marks */
        [.25,.75,1.25,1.75].forEach(f=>{
            const a=f*Math.PI, r=12+(isHover?2:0);
            ctx.beginPath(); ctx.moveTo(Math.cos(a)*(r-2),Math.sin(a)*(r-2)); ctx.lineTo(Math.cos(a)*(r+5),Math.sin(a)*(r+5));
            ctx.strokeStyle=`rgba(232,55,42,${.45+.25*pulse})`; ctx.lineWidth=.8; ctx.stroke();
        });

        /* 7 — Main 4 lines */
        ctx.strokeStyle=isClick?'rgba(255,255,255,.95)':`rgba(232,55,42,${.88+.1*pulse})`;
        ctx.lineWidth=thick; ctx.lineCap='square';
        ctx.shadowColor=isClick?'rgba(255,120,80,.9)':'rgba(232,55,42,.55)'; ctx.shadowBlur=isHover?9:5;
        [[0,-(gap+len),0,-gap],[0,gap,0,gap+len],[-(gap+len),0,-gap,0],[gap,0,gap+len,0]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
        }); ctx.shadowBlur=0;

        /* 8 — End caps */
        const cw=3; ctx.lineWidth=.8; ctx.strokeStyle=`rgba(232,55,42,${.45+.25*pulse})`;
        [[-cw,-(gap+len),cw,-(gap+len)],[-cw,gap+len,cw,gap+len],[-(gap+len),-cw,-(gap+len),cw],[gap+len,-cw,gap+len,cw]].forEach(([x1,y1,x2,y2])=>{
            ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
        });

        /* 9 — Center dot */
        ctx.beginPath(); ctx.arc(0,0,isClick?4:(isHover?2.8:2),0,Math.PI*2);
        ctx.fillStyle=isClick?'#fff':'#e8372a'; ctx.shadowColor=isClick?'#fff':'rgba(232,55,42,.9)'; ctx.shadowBlur=isClick?16:7; ctx.fill(); ctx.shadowBlur=0;

        /* 10 — Hit-marker X flash */
        const hitAge=(performance.now()-clickTime)/420;
        if(hitAge<1&&clickTime>0){
            const s=5+hitAge*12;
            ctx.strokeStyle=`rgba(255,255,255,${(1-hitAge)*.92})`; ctx.lineWidth=1.6; ctx.lineCap='round';
            ctx.shadowColor=`rgba(255,255,255,${1-hitAge})`; ctx.shadowBlur=8;
            [[-s,-s,s,s],[-s,s,s,-s]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke(); });
            ctx.shadowBlur=0;
        }

        /* BONUS — HUD brackets on hover */
        if(isHover){
            const br=32, bl=9;
            ctx.strokeStyle=`rgba(232,55,42,${.35+.25*pulse})`; ctx.lineWidth=.9; ctx.lineCap='square';
            [[-1,-1],[1,-1],[-1,1],[1,1]].forEach(([sx,sy])=>{
                const cx2=sx*br, cy2=sy*br;
                ctx.beginPath(); ctx.moveTo(cx2,cy2-sy*bl); ctx.lineTo(cx2,cy2); ctx.lineTo(cx2-sx*bl,cy2); ctx.stroke();
            });
        }
        ctx.restore();
    }

    /* ── Draw: SWORD (inchangé) ── */
    function drawSword(ts) {
        const now=ts;
        trailPoints.push({x:mouseX,y:mouseY,t:now});
        trailPoints=trailPoints.filter(p=>now-p.t<120);
        if(trailPoints.length>1){
            for(let i=1;i<trailPoints.length;i++){
                const age=(now-trailPoints[i].t)/120;
                ctx.save(); ctx.translate(CX,CY);
                ctx.beginPath(); ctx.moveTo(trailPoints[i-1].x-mouseX,trailPoints[i-1].y-mouseY); ctx.lineTo(trailPoints[i].x-mouseX,trailPoints[i].y-mouseY);
                ctx.strokeStyle=`rgba(232,55,42,${(1-age)*.55})`; ctx.lineWidth=2*(1-age); ctx.lineCap='round'; ctx.stroke(); ctx.restore();
            }
        }
        ctx.save(); ctx.translate(CX,CY); ctx.rotate(-Math.PI/4);
        if(isHover){ctx.shadowColor='rgba(255,107,43,0.8)';ctx.shadowBlur=8;}
        const bg=ctx.createLinearGradient(-2,-28,2,8); bg.addColorStop(0,'#8090a8'); bg.addColorStop(.4,'#e8eef8'); bg.addColorStop(1,'#6070a0');
        ctx.beginPath(); ctx.moveTo(0,-28); ctx.lineTo(-2,-8); ctx.lineTo(2,-8); ctx.closePath(); ctx.fillStyle=bg; ctx.fill();
        ctx.beginPath(); ctx.moveTo(-.5,-26); ctx.lineTo(-.5,-8); ctx.strokeStyle='rgba(255,255,255,0.7)'; ctx.lineWidth=.6; ctx.stroke();
        const gp=.5+.5*Math.sin(ts*.004);
        ctx.shadowColor=`rgba(255,180,100,${.3+.3*gp})`; ctx.shadowBlur=4; ctx.fillStyle=`rgba(176,43,32,${.8+.2*gp})`;
        ctx.beginPath(); ctx.roundRect(-7,-9,14,3,1.5); ctx.fill();
        ctx.strokeStyle=`rgba(255,180,100,${.3+.3*gp})`; ctx.lineWidth=.7; ctx.stroke();
        const hg=ctx.createLinearGradient(-2,-6,2,8); hg.addColorStop(0,'#6b1a12'); hg.addColorStop(1,'#3a0e08');
        ctx.shadowBlur=0; ctx.beginPath(); ctx.roundRect(-2,-6,4,12,1.5); ctx.fillStyle=hg; ctx.fill();
        const pa=isClick?1:(.6+.4*gp);
        ctx.beginPath(); ctx.arc(0,8,3.5,0,Math.PI*2); ctx.fillStyle=`rgba(232,55,42,${pa})`; ctx.shadowColor=`rgba(232,55,42,${pa})`; ctx.shadowBlur=isClick?12:5; ctx.fill();
        ctx.strokeStyle='rgba(255,180,100,0.5)'; ctx.lineWidth=.7; ctx.stroke(); ctx.restore();
    }

    /* ── Draw: ENERGY (inchangé) ── */
    function drawEnergy(ts) {
        energyOrbit+=.04;
        const pulse=.5+.5*Math.sin(ts*.005), hs=isHover?1.25:1;
        ctx.save(); ctx.translate(CX,CY);
        const cg=ctx.createRadialGradient(0,0,0,0,0,8*hs);
        cg.addColorStop(0,isHover?'rgba(0,229,255,0.9)':'rgba(0,229,255,0.6)'); cg.addColorStop(.5,`rgba(0,229,255,${.15+.1*pulse})`); cg.addColorStop(1,'rgba(0,229,255,0)');
        ctx.beginPath(); ctx.arc(0,0,8*hs,0,Math.PI*2); ctx.fillStyle=cg; ctx.fill();
        ctx.beginPath(); ctx.arc(0,0,2.5,0,Math.PI*2); ctx.fillStyle='#fff'; ctx.shadowColor='#00e5ff'; ctx.shadowBlur=10; ctx.fill();
        const orbitR=14+3*pulse*hs, orbitC=['#00e5ff','rgba(191,90,242,0.9)','#30d5c8'];
        for(let i=0;i<3;i++){
            const angle=energyOrbit+(i/3)*Math.PI*2, ox=Math.cos(angle)*orbitR, oy=Math.sin(angle)*(orbitR*.5), ps=2.2+pulse;
            for(let j=1;j<5;j++){ const ta=angle-j*.18; ctx.beginPath(); ctx.arc(Math.cos(ta)*orbitR,Math.sin(ta)*(orbitR*.5),ps*(1-j/5)*.7,0,Math.PI*2); ctx.fillStyle=`rgba(0,229,255,${.25*(1-j/5)})`; ctx.shadowBlur=0; ctx.fill(); }
            ctx.beginPath(); ctx.arc(ox,oy,ps,0,Math.PI*2); ctx.fillStyle=orbitC[i]; ctx.shadowColor=orbitC[i]; ctx.shadowBlur=8; ctx.fill();
        }
        if(isClick){ const age=(ts-clickTime)/400; if(age<1){ ctx.beginPath(); ctx.arc(0,0,age*26,0,Math.PI*2); ctx.strokeStyle=`rgba(0,229,255,${1-age})`; ctx.lineWidth=1.5; ctx.shadowBlur=0; ctx.stroke(); } }
        ctx.restore();
    }

    /* ── Draw: ARROW (inchangé) ── */
    function drawArrow(ts) {
        arrowTension=isClick?Math.min(1,(ts-clickTime)/250):Math.max(0,arrowTension-.08);
        const fp=.5+.5*Math.sin(ts*.003);
        ctx.save(); ctx.translate(CX,CY);
        const sg=ctx.createLinearGradient(0,-24,0,6); sg.addColorStop(0,'#f6d860'); sg.addColorStop(1,'#c8a830');
        ctx.beginPath(); ctx.moveTo(0,-24); ctx.lineTo(0,6); ctx.strokeStyle=sg; ctx.lineWidth=1.5; ctx.shadowColor='rgba(246,216,96,0.5)'; ctx.shadowBlur=isHover?8:4; ctx.stroke();
        const hs=isHover?7:5.5;
        ctx.beginPath(); ctx.moveTo(0,-24-hs); ctx.lineTo(-hs*.6,-24); ctx.lineTo(hs*.6,-24); ctx.closePath(); ctx.fillStyle='#f6d860'; ctx.shadowColor='rgba(246,216,96,0.8)'; ctx.shadowBlur=isHover?12:6; ctx.fill();
        ctx.shadowBlur=0;
        [[-3,4,-8,10],[3,4,8,10],[-3,9,-6,14],[3,9,6,14]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.strokeStyle=`rgba(246,${173+42*fp|0},85,0.8)`; ctx.lineWidth=1.5; ctx.lineCap='round'; ctx.stroke(); });
        if(arrowTension>.01){ const pull=arrowTension*12; [[-12,-10,12,-10],[-12,10,12,10]].forEach(([x1,y1,x2,y2])=>{ ctx.beginPath(); ctx.moveTo(x1,y1); ctx.quadraticCurveTo(pull,0,x2,y2); ctx.strokeStyle=`rgba(246,216,96,${.3+arrowTension*.5})`; ctx.lineWidth=.8; ctx.stroke(); }); }
        ctx.restore();
    }

    /* ── RAF loop ── */
    function loop(ts) {
        rafPending=false;
        const hot=HOTSPOT[cursorType]||HOTSPOT.crosshair;
        canvas.style.transform=`translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;
        ctx.clearRect(0,0,120,120);
        switch(cursorType){
            case 'crosshair': drawCrosshair(ts); break;
            case 'sword':     drawSword(ts);     break;
            case 'energy':    drawEnergy(ts);    break;
            case 'arrow':     drawArrow(ts);     break;
        }
        if(cursorType==='energy'||cursorType==='crosshair'||arrowTension>.01){ rafPending=true; requestAnimationFrame(loop); }
    }

    /* ── Continuous RAF for energy & crosshair ── */
    (function continuousLoop(ts) {
        if(cursorType==='energy'||cursorType==='crosshair'){
            const hot=HOTSPOT[cursorType];
            canvas.style.transform=`translate(${mouseX-hot.x}px,${mouseY-hot.y}px)`;
            ctx.clearRect(0,0,120,120);
            cursorType==='energy'?drawEnergy(ts):drawCrosshair(ts);
        }
        requestAnimationFrame(continuousLoop);
    })(0);

    /* ── Picker UI ── */
    const btn=document.getElementById('et-cursor-btn');
    const panel=document.getElementById('et-cursor-panel');
    const opts=document.querySelectorAll('.et-cursor-opt');

    function setCursor(type) {
        if(!CURSORS.includes(type)) return;
        cursorType=type; localStorage.setItem(STORAGE_KEY,type);
        trailPoints=[]; arrowTension=0;
        opts.forEach(o=>o.classList.toggle('active',o.dataset.cursor===type));
        btn.textContent=ICONS[type];
        setTimeout(()=>panel.classList.remove('open'),220);
        if(!rafPending){ rafPending=true; requestAnimationFrame(loop); }
    }
    btn.addEventListener('click',e=>{ e.stopPropagation(); panel.classList.toggle('open'); });
    opts.forEach(o=>o.addEventListener('click',()=>setCursor(o.dataset.cursor)));
    document.addEventListener('click',e=>{ if(!panel.contains(e.target)&&e.target!==btn) panel.classList.remove('open'); });
    document.addEventListener('keydown',e=>{ if(e.key==='Escape') panel.classList.remove('open'); });
    setCursor(cursorType);

    /* ── Profile chevron sync ── */
    const pfTrigger=document.querySelector('.et-profile-trigger');
    if(pfTrigger){
        pfTrigger.addEventListener('click',function(){
            setTimeout(()=>{ const open=this.closest('.dropdown').classList.contains('show'); this.classList.toggle('show',open); },10);
        });
        document.addEventListener('click',e=>{ if(!pfTrigger.closest('.dropdown').contains(e.target)) pfTrigger.classList.remove('show'); });
    }

    /* ══════════════════════════════════════════════════════════
       BACKGROUND PARTICLES
    ══════════════════════════════════════════════════════════ */
    const bgCanvas=document.getElementById('bgCanvas');
    if(bgCanvas){
        const bctx=bgCanvas.getContext('2d',{alpha:true}); bctx.imageSmoothingEnabled=false;
        let W,H,particles=[];
        function resize(){ W=bgCanvas.width=window.innerWidth; H=bgCanvas.height=window.innerHeight; }
        resize(); window.addEventListener('resize',()=>{ resize(); spawnAll(); },{passive:true});
        const COLORS=['rgba(232,55,42,','rgba(255,107,43,','rgba(255,32,96,','rgba(0,229,255,'];
        function mkParticle(){ return {x:Math.random()*W,y:H+Math.random()*40,vx:(Math.random()-.5)*.35,vy:-(0.18+Math.random()*.55),r:.7+Math.random()*1.1,alpha:0,maxAlpha:.12+Math.random()*.18,phase:Math.random()*Math.PI*2,color:COLORS[Math.floor(Math.random()*COLORS.length)],life:0,maxLife:150+Math.random()*180}; }
        function spawnAll(){ particles=Array.from({length:30},mkParticle); }
        spawnAll();
        let lastFrame=0;
        (function tick(ts){
            if(ts-lastFrame<33){requestAnimationFrame(tick);return;} lastFrame=ts;
            bctx.clearRect(0,0,W,H); bctx.shadowBlur=0;
            particles.forEach((p,i)=>{
                p.life++; p.x+=p.vx+Math.sin(p.phase+p.life*.018)*.18; p.y+=p.vy;
                const t=p.life/p.maxLife;
                p.alpha=t<.15?(t/.15)*p.maxAlpha:t>.75?((1-t)/.25)*p.maxAlpha:p.maxAlpha;
                if(p.life>=p.maxLife||p.y<-10) particles[i]=mkParticle();
                bctx.beginPath(); bctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                bctx.fillStyle=p.color+p.alpha+')'; bctx.fill();
            }); requestAnimationFrame(tick);
        })(0);
    }

    /* ── Scroll progress ── */
    const sp=document.getElementById('scroll-progress');
    window.addEventListener('scroll',()=>{ const pct=(document.documentElement.scrollTop/(document.documentElement.scrollHeight-window.innerHeight))*100; if(sp) sp.style.width=pct+'%'; },{passive:true});

    /* ── Navbar shrink ── */
    const navbar=document.querySelector('.main_menu');
    window.addEventListener('scroll',()=>{ if(navbar){ navbar.style.background=window.scrollY>60?'rgba(5,5,12,0.95)':''; navbar.style.padding=window.scrollY>60?'0':''; } },{passive:true});

    /* ── Ripple on nav links ── */
    document.querySelectorAll('.navbar-nav .nav-link').forEach(link=>{
        link.style.position='relative'; link.style.overflow='hidden';
        link.addEventListener('click',function(e){ const rect=this.getBoundingClientRect(); const r=document.createElement('span'); r.className='ripple'; r.style.cssText=`width:40px;height:40px;left:${e.clientX-rect.left-20}px;top:${e.clientY-rect.top-20}px;`; this.appendChild(r); setTimeout(()=>r.remove(),500); });
    });

    /* ── Scroll reveal ── */
    if('IntersectionObserver' in window){
        const io=new IntersectionObserver(entries=>{ entries.forEach(e=>{ if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='none';io.unobserve(e.target);} }); },{threshold:.07});
        document.querySelectorAll('section > .container > .row > [class*="col"]').forEach(el=>{ el.style.opacity='0'; el.style.transform='translateY(20px)'; el.style.transition='opacity .55s ease,transform .55s ease'; io.observe(el); });
    }

    /* ── Glitch logo ── */
    const logo=document.querySelector('.navbar-brand img');
    if(logo){ setInterval(()=>{ if(Math.random()>.88){ logo.animate([{filter:'none',transform:'none'},{filter:'hue-rotate(180deg) brightness(1.5)',transform:'skewX(-4deg) translateX(2px)'},{filter:'hue-rotate(-90deg)',transform:'skewX(3deg) translateX(-2px)'},{filter:'none',transform:'none'}],{duration:140,easing:'steps(3)'}); } },4000); }

})();
</script>
</body>
</html>
