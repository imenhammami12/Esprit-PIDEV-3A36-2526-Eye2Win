<script>
(function () {
    'use strict';

    /* ── SVG SWORD CURSOR — OPTIMIZED ── */
    const sw = document.getElementById('sword-cursor');
    if (sw) { sw.style.left = '0px'; sw.style.top = '0px'; sw.style.willChange = 'transform'; }

    let mouseX = -200, mouseY = -200, rafPending = false;

    document.addEventListener('mousemove', e => {
        mouseX = e.clientX; mouseY = e.clientY;
        if (!rafPending) { rafPending = true; requestAnimationFrame(moveCursor); }
    }, { passive: true });

    function moveCursor() {
        rafPending = false;
        if (sw) sw.style.transform = `translate(${mouseX - 4}px, ${mouseY - 4}px) rotate(-45deg)`;
    }

    document.addEventListener('mouseover', e => { if (sw && e.target.closest('a,button,[role="button"],input,select,textarea,label')) sw.classList.add('sw-hover'); }, { passive: true });
    document.addEventListener('mouseout',  e => { if (sw && e.target.closest('a,button,[role="button"],input,select,textarea,label')) sw.classList.remove('sw-hover'); }, { passive: true });
    document.addEventListener('mousedown', () => sw && sw.classList.add('sw-click'));
    document.addEventListener('mouseup',   () => sw && sw.classList.remove('sw-click'));

    const SPARK_COLORS = ['#ff4d3d','#ff6b2b','#ff2060','#fff','#f6d860'];
    document.addEventListener('click', e => {
        for (let i = 0; i < 6; i++) {
            const sp = document.createElement('div');
            sp.className = 'spark';
            const angle = (i / 6) * Math.PI * 2 + Math.random() * .5;
            const dist  = 22 + Math.random() * 40;
            const dur   = .28 + Math.random() * .22;
            sp.style.cssText = `left:${e.clientX}px;top:${e.clientY}px;background:${SPARK_COLORS[i%SPARK_COLORS.length]};--sx:${Math.cos(angle)*dist}px;--sy:${Math.sin(angle)*dist}px;--dur:${dur}s;`;
            document.body.appendChild(sp);
            setTimeout(() => sp.remove(), dur * 1000 + 50);
        }
    });

    /* ── SCROLL PROGRESS ── */
    const sp = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
        const pct = (document.documentElement.scrollTop / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (sp) sp.style.width = pct + '%';
    }, { passive: true });

    /* ── BG PARTICLE CANVAS ── */
    const canvas = document.getElementById('bgCanvas');
    if (canvas) {
        const ctx = canvas.getContext('2d', { alpha: true });
        ctx.imageSmoothingEnabled = false;
        let W, H, particles = [];

        function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
        resize();
        window.addEventListener('resize', () => { resize(); spawnAll(); }, { passive: true });

        const COLORS = ['rgba(232,55,42,','rgba(255,107,43,','rgba(255,32,96,','rgba(0,229,255,'];
        function mkParticle() {
            return { x:Math.random()*W, y:H+Math.random()*40, vx:(Math.random()-.5)*.35, vy:-(0.18+Math.random()*.55), r:.7+Math.random()*1.1, alpha:0, maxAlpha:.12+Math.random()*.18, phase:Math.random()*Math.PI*2, color:COLORS[Math.floor(Math.random()*COLORS.length)], life:0, maxLife:150+Math.random()*180 };
        }
        function spawnAll() { particles = Array.from({ length: 30 }, mkParticle); }
        spawnAll();

        let lastFrame = 0;
        (function tick(ts) {
            if (ts - lastFrame < 33) { requestAnimationFrame(tick); return; }
            lastFrame = ts;
            ctx.clearRect(0, 0, W, H);
            ctx.shadowBlur = 0;
            particles.forEach((p, i) => {
                p.life++; p.x += p.vx + Math.sin(p.phase + p.life * .018) * .18; p.y += p.vy;
                const t = p.life / p.maxLife;
                p.alpha = t < .15 ? (t/.15)*p.maxAlpha : t > .75 ? ((1-t)/.25)*p.maxAlpha : p.maxAlpha;
                if (p.life >= p.maxLife || p.y < -10) particles[i] = mkParticle();
                ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = p.color + p.alpha + ')'; ctx.fill();
            });
            requestAnimationFrame(tick);
        })(0);
    }

    /* ── RIPPLE on nav links ── */
    document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
        link.style.position = 'relative'; link.style.overflow = 'hidden';
        link.addEventListener('click', function(e) {
            const rect = this.getBoundingClientRect();
            const r = document.createElement('span');
            r.className = 'ripple';
            r.style.cssText = `width:40px;height:40px;left:${e.clientX-rect.left-20}px;top:${e.clientY-rect.top-20}px;`;
            this.appendChild(r);
            setTimeout(() => r.remove(), 500);
        });
    });

    /* ── SCROLL REVEAL ── */
    if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='none'; io.unobserve(e.target); }
            });
        }, { threshold: .07 });
        document.querySelectorAll('section > .container > .row > [class*="col"]').forEach(el => {
            el.style.opacity = '0'; el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity .55s ease, transform .55s ease';
            io.observe(el);
        });
    }

    /* ── NAVBAR scroll shrink ── */
    const navbar = document.querySelector('.main_menu');
    window.addEventListener('scroll', () => {
        if (navbar) {
            navbar.style.background = window.scrollY > 60 ? 'rgba(5,5,12,0.95)' : '';
            navbar.style.padding    = window.scrollY > 60 ? '0' : '';
        }
    }, { passive: true });

    /* ── GLITCH logo ── */
    const logo = document.querySelector('.navbar-brand img');
    if (logo) {
        setInterval(() => {
            if (Math.random() > .88) {
                logo.animate([
                    { filter:'none', transform:'none' },
                    { filter:'hue-rotate(180deg) brightness(1.5)', transform:'skewX(-4deg) translateX(2px)' },
                    { filter:'hue-rotate(-90deg)', transform:'skewX(3deg) translateX(-2px)' },
                    { filter:'none', transform:'none' },
                ], { duration: 140, easing: 'steps(3)' });
            }
        }, 4000);
    }
})();
</script>
</body>
</html>