    .et-pd-item:hover .et-pd-ic { background:rgba(232,55,42,.15); border-color:rgba(232,55,42,.4); box-shadow:0 0 10px rgba(232,55,42,.2); color:var(--red-hot); }
    .et-pd-txt { flex:1; position:relative; z-index:1; }
