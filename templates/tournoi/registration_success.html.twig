{% extends 'base.html.twig' %}

{% block title %}Inscription Réussie - {{ tournoi.nom }}{% endblock %}

{% block body %}
    <section class="breadcrumb breadcrumb_bg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="breadcrumb_iner text-center">
                        <div class="breadcrumb_iner_item">
                            <h2>Félicitations !</h2>
                            <p><a href="{{ path('app_tournoi_index') }}">Tournois</a> <span>-</span> Inscription Terminée</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section_padding text-center" style="background-color: #0b0b1a; color: #fff;">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="success_card p-5 rounded shadow-lg" style="background-color: #1a1a2e; border: 2px solid #e94560;">
                        <div class="mb-4">
                            <i class="fas fa-check-circle fa-5x" style="color: #43e97b;"></i>
                        </div>
                        <h2 class="text-white mb-3">Paiement et Inscription Réussis !</h2>
                        <p class="lead mb-4" style="color: #aeb8c9;">
                            Vous êtes maintenant officiellement inscrit au tournoi <strong>{{ tournoi.nom }}</strong>. 
                            Un email de confirmation contenant tous les détails vous a été envoyé.
                        </p>
                        <div class="tournament_brief mb-5 p-3 rounded" style="background-color: #16213e; border: 1px solid #2d2d44;">
                            <div class="row">
                                <div class="col-6 text-start">
                                    <span class="text-white-50 small">Tournoi</span>
                                    <div class="fw-bold">{{ tournoi.nom }}</div>
                                </div>
                                <div class="col-6 text-end">
                                    <span class="text-white-50 small">Date</span>
                                    <div class="fw-bold">{{ tournoi.dateDebut|date('d M, Y') }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-3 justify-content-center">
                            <a href="{{ path('app_tournoi_show', {'id': tournoi.id}) }}" class="btn btn-primary px-4 py-2" style="background-color: #e94560; border: none;">
                                <i class="fas fa-trophy me-2"></i> Voir les détails
                            </a>
                            <a href="{{ path('app_tournoi_index') }}" class="btn btn-outline-light px-4 py-2">
                                <i class="fas fa-list me-2"></i> Tous les tournois
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
