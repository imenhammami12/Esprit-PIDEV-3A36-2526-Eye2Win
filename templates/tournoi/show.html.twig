{% extends 'base.html.twig' %}

{% block title %}{{ tournament.nom }} - EyeTwin{% endblock %}

{% block body %}
    <!-- Breadcrumb -->
    <section class="breadcrumb breadcrumb_bg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="breadcrumb_iner text-center">
                        <div class="breadcrumb_iner_item">
                            <h2>{{ tournament.nom }}</h2>
                            <p><a href="{{ path('app_tournoi_index') }}">Tournaments</a> <span>-</span> Details</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tournament Details -->
    <section class="tournament_details section_padding">
        <div class="container">
            <div class="row">
                <!-- Sidebar / Image -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm mb-4" style="background-color: #1a1a2e; color: #fff; border: 1px solid #2d2d44;">
                        {% if tournament.image %}
                            <img src="{{ asset('uploads/tournois/' ~ tournament.image) }}" 
                                 class="card-img-top rounded-top" 
                                 alt="{{ tournament.nom }}">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center rounded-top" style="height: 300px; background: linear-gradient(45deg, #16213e, #0f3460);">
                                <i class="fas fa-trophy fa-5x text-white-50"></i>
                            </div>
                        {% endif %}
                        <div class="card-body p-4">
                            <h4 class="mb-4 text-white" style="border-bottom: 2px solid #e94560; padding-bottom: 10px; display: inline-block;">Tournament Info</h4>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: transparent; color: #aeb8c9; border-bottom: 1px solid #2d2d44;">
                                    Type
                                    <span class="badge rounded-pill" style="background-color: #e94560;">{{ tournament.typeTournoi ? tournament.typeTournoi.name : 'N/A' }}</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: transparent; color: #aeb8c9; border-bottom: 1px solid #2d2d44;">
                                    Start Date
                                    <span class="text-white">{{ tournament.dateDebut ? tournament.dateDebut|date('M d, Y') : 'TBA' }}</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: transparent; color: #aeb8c9; border-bottom: 1px solid #2d2d44;">
                                    End Date
                                    <span class="text-white">{{ tournament.dateFin ? tournament.dateFin|date('M d, Y') : 'TBA' }}</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: transparent; color: #aeb8c9; border-bottom: 1px solid #2d2d44;">
                                    Entry Fee
                                    <span class="text-white fw-bold">{{ tournament.prix|number_format(2, '.', ',') }} TND</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: transparent; color: #aeb8c9; border-bottom: none;">
                                    Total Matches
                                    <span class="badge rounded-pill" style="background-color: #0f3460; border: 1px solid #2d2d44;">{{ matches|length }}</span>
                                </li>
                            </ul>

                            <div class="mt-4 text-center">
                                {% if app.user %}
                                    {% set isRegistered = false %}
                                    {% for p in tournament.participants %}
                                        {% if p.id == app.user.id %}
                                            {% set isRegistered = true %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if isRegistered %}
                                        <button class="btn btn-secondary w-100" disabled style="cursor: not-allowed; opacity: 0.7;">
                                            <i class="fas fa-check-circle me-2"></i> Déjà inscrit
                                        </button>
                                    {% else %}
                                        {% if tournament.prix > 0 %}
                                            <button type="button" class="btn btn-primary w-100" style="background-color: #e94560; border-color: #e94560;" data-toggle="modal" data-target="#paymentConfirmationModal">
                                                <i class="fas fa-user-plus me-2"></i> S'inscrire ({{ tournament.prix|number_format(2, '.', ',') }} USD)
                                            </button>
                                        {% else %}
                                            <form action="{{ path('app_tournoi_inscription', {'id': tournament.id}) }}" method="post">
                                                <input type="hidden" name="_token" value="{{ csrf_token('inscription' ~ tournament.id) }}">
                                                <button type="submit" class="btn btn-primary w-100" style="background-color: #e94560; border-color: #e94560;">
                                                    <i class="fas fa-user-plus me-2"></i> S'inscrire (Gratuit)
                                                </button>
                                            </form>
                                        {% endif %}
                                    {% endif %}
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="btn btn-outline-light w-100">
                                        <i class="fas fa-sign-in-alt me-2"></i> Connectez-vous pour vous inscrire
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Main Content -->
                <div class="col-lg-8">
                    <div class="content_wrapper">
                        <h3 class="mb-3">Description</h3>
                        <p class="text-muted mb-5">
                            {{ tournament.description|default('No description available for this tournament.')|nl2br }}
                        </p>
                        
                        <h3 class="mb-4">Match Schedule</h3>
                        
                        {% if matches|length > 0 %}
                            <div class="matches-list">
                                {% for match in matches %}
                                    <div class="match-card mb-3 p-4 rounded shadow-sm d-flex flex-wrap align-items-center justify-content-between" 
                                         style="background-color: #1a1a2e; border: 1px solid #16213e; transition: transform 0.2s;">
                                        
                                        {# Date Column #}
                                        <div class="match-date mb-2 mb-md-0 me-md-4 text-center" style="min-width: 100px;">
                                            <div style="color: #e94560; font-weight: bold; font-size: 1.1rem;">
                                                {{ match.dateMatch ? match.dateMatch|date('M d') : 'TBA' }}
                                            </div>
                                            <div class="small text-muted">
                                                {{ match.dateMatch ? match.dateMatch|date('H:i') : '--:--' }}
                                            </div>
                                        </div>

                                        {# Teams & Location Column #}
                                        <div class="match-teams flex-grow-1 text-center mb-3 mb-md-0 px-3">
                                            <div class="d-flex align-items-center justify-content-center gap-3 mb-2">
                                                <div class="team-name text-end fw-bold text-white fs-5" style="width: 45%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                    {{ match.equipe1 }}
                                                </div>
                                                
                                                <div class="vs-badge px-2 py-1 rounded small fw-bold" style="background-color: #0f3460; color: #aeb8c9; flex-shrink: 0;">VS</div>
                                                
                                                <div class="team-name text-start fw-bold text-white fs-5" style="width: 45%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                    {{ match.equipe2 }}
                                                </div>
                                            </div>
                                            
                                            {# Play Mode & Location #}
                                            <div class="d-flex justify-content-center">
                                                {% if match.playMode and match.playMode.value == 'Sur Site' %}
                                                    <div class="location-container">
                                                        <button class="badge rounded-pill p-2 px-3 border-0" 
                                                                style="background-color: #e94560; font-size: 0.75rem; cursor: pointer; transition: all 0.3s;"
                                                                type="button"
                                                                onclick="this.nextElementSibling.classList.toggle('d-none'); this.classList.toggle('active-location');">
                                                            <i class="fas fa-map-marker-alt me-1"></i> Sur Site
                                                        </button>
                                                        <div class="mt-2 d-none text-muted small px-2" style="max-width: 300px; line-height: 1.4; animation: fadeIn 0.3s;">
                                                            {{ match.localisation|default('Adresse non spécifiée') }}
                                                        </div>
                                                    </div>
                                                {% else %}
                                                    <span class="badge rounded-pill p-2 px-3" style="background-color: #0f3460; border: 1px solid #2d2d44; color: #aeb8c9; font-size: 0.75rem;">
                                                        <i class="fas fa-globe me-1"></i> En Ligne
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>

                                        {# Status/Score Column #}
                                        <div class="match-status text-center ms-md-4" style="min-width: 120px;">
                                            {% if match.score is not null %}
                                                <div class="score-display px-3 py-2 rounded fw-bold text-white mb-1" style="background-color: #e94560;">
                                                    {{ match.score }}
                                                </div>
                                                <small class="text-muted">Final Score</small>
                                            {% else %}
                                                {% if match.dateMatch and match.dateMatch < date() %}
                                                     <span class="badge bg-secondary">Finished</span>
                                                {% else %}
                                                     <span class="badge bg-warning text-dark">Upcoming</span>
                                                {% endif %}
                                            {% endif %}
                                        </div>

                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-dark border-0" style="background-color: #1a1a2e; color: #fff;">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                No matches have been scheduled for this tournament yet.
                            </div>
                        {% endif %}
                        
                        <div class="mt-5">
                            <a href="{{ path('app_tournoi_index') }}" class="btn btn-outline-primary">
                                <i class="fas fa-arrow-left me-2"></i> Back to Tournaments
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Payment Confirmation Modal -->
    <div class="modal fade" id="paymentConfirmationModal" tabindex="-1" aria-labelledby="paymentConfirmationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #1a1a2e; color: #fff; border: 2px solid #e94560; border-radius: 12px;">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold" id="paymentConfirmationModalLabel">Confirmation d'Inscription</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true" class="text-white">&times;</span>
                    </button>
                </div>
                <div class="modal-body p-4 text-center">
                    <div class="mb-4">
                        <i class="fas fa-credit-card fa-3x" style="color: #e94560;"></i>
                    </div>
                    <h4 class="mb-3">Résumé du paiement</h4>
                    <p class="mb-4" style="color: #aeb8c9;">
                        Vous êtes sur le point de vous inscrire au tournoi <strong class="text-white">{{ tournament.nom }}</strong>. 
                        Pour confirmer votre participation, un paiement de <strong class="text-white">{{ tournament.prix|number_format(2, '.', ',') }} USD</strong> est requis.
                    </p>
                    <div class="alert mt-3 p-3 text-start small" style="background-color: #16213e; border: 1px solid #2d2d44; color: #aeb8c9;">
                        <i class="fas fa-shield-alt me-2" style="color: #43e97b;"></i>
                        Paiement sécurisé via Stripe. Vos informations bancaires ne sont jamais stockées sur nos serveurs.
                    </div>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-light px-4" data-dismiss="modal">Annuler</button>
                    <form action="{{ path('app_tournoi_checkout', {'id': tournament.id}) }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ tournament.id) }}">
                        <button type="submit" class="btn btn-primary px-4" style="background-color: #e94560; border: none;">
                            <i class="fas fa-lock me-2"></i> Confirmer et Payer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <style>
        .active-location {
            box-shadow: 0 0 10px #e94560;
            transform: scale(1.05);
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
{% endblock %}
