{% extends 'base.html.twig' %}

{% block title %}Home - EyeTwin eSport Platform{% endblock %}

{% block body %}

{# ═══════════════════════════════════════════════
   HERO SECTION
═══════════════════════════════════════════════ #}
<section class="et-hero">
    <canvas id="heroCanvas"></canvas>

    {# Arcade background image — WebP avec fallback PNG #}
    <div class="et-hero-arcade" id="heroArcade"></div>

    {# Overlays #}
    <div class="et-hero-grid"></div>
    <div class="et-hero-scan"></div>
    <div class="et-hero-vignette"></div>
    <div class="et-hero-bottom-fade"></div>

    <div class="container position-relative" style="z-index:4;">
        <div class="et-hero-inner">

            {# Tag #}
            <div class="et-tag">
                <span class="et-tag-dot"></span>
                <i class="fas fa-gamepad"></i>&nbsp; EYETWIN ESPORT PLATFORM
            </div>

            {# Headline #}
            <h1 class="et-hero-title">
                <span class="et-ht-line1">Dominate</span>
                <span class="et-ht-line2">The Arena</span>
            </h1>

            <p class="et-hero-sub">
                Intelligent analysis · Personalized coaching · Competitive tournaments.<br>
                Level up your game with the ultimate eSport ecosystem.
            </p>

            {# CTA buttons #}
            {% if not app.user %}
            <div class="et-hero-cta">
                <a href="{{ path('app_register') }}" class="btn-fire btn-fire-lg">
                    <span class="btn-fire-bg"></span>
                    <i class="fas fa-bolt"></i>
                    <span>Get Started</span>
                </a>
                <a href="{{ path('app_login') }}" class="btn-ghost">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </a>
            </div>
            {% else %}
            <div class="et-hero-cta">
                <a href="{{ path('app_video_upload') }}" class="btn-fire btn-fire-lg">
                    <span class="btn-fire-bg"></span>
                    <i class="fas fa-upload"></i>
                    <span>Upload a Video</span>
                </a>
                <a href="{{ path('live_index') }}" class="btn-ghost">
                    <span class="live-dot-sm"></span> Watch Live
                </a>
            </div>
            {% endif %}

            {# Scroll indicator #}
            <div class="et-scroll-hint">
                <span class="et-scroll-line"></span>
                <span class="et-scroll-txt">SCROLL</span>
            </div>
        </div>
    </div>

    {# HUD stat bar #}
    <div class="et-hero-statsbar">
        <div class="container">
            <div class="et-stats-row">
                <div class="et-stat">
                    <span class="et-stat-val" data-target="2400">0</span>
                    <span class="et-stat-lbl">Players</span>
                </div>
                <div class="et-stat-div"></div>
                <div class="et-stat">
                    <span class="et-stat-val" data-target="180">0</span>
                    <span class="et-stat-lbl">Tournaments</span>
                </div>
                <div class="et-stat-div"></div>
                <div class="et-stat">
                    <span class="et-stat-val" data-target="95">0</span>
                    <span class="et-stat-lbl">% Satisfaction</span>
                </div>
                <div class="et-stat-div"></div>
                <div class="et-stat">
                    <span class="et-stat-val" data-target="48">0</span>
                    <span class="et-stat-lbl">Coaches</span>
                </div>
            </div>
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════
   FEATURES SECTION
═══════════════════════════════════════════════ #}
<section class="et-features">
    <div class="et-features-bg"></div>
    <div class="container position-relative" style="z-index:1;">

        <div class="et-section-header">
            <span class="et-section-tag">Platform Features</span>
            <h2 class="et-section-title">Everything You Need<br><span class="et-gradient-text">To Win</span></h2>
            <p class="et-section-sub">A complete ecosystem built for competitive players and coaches.</p>
        </div>

        <div class="et-features-grid">

            <div class="et-feat-card et-feat-card--highlight">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-video"></i></div>
                <h3>Video Analysis</h3>
                <p>Upload your match recordings and get AI-powered breakdowns of your gameplay, positioning, and decision-making.</p>
                {% if app.user %}
                <a href="{{ path('app_video_upload') }}" class="et-feat-link">Upload Now <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

            <div class="et-feat-card">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-broadcast-tower"></i></div>
                <h3>Live Streams</h3>
                <p>Watch expert coaches stream in real time. Ask questions, learn techniques, and level up live.</p>
                {% if app.user %}
                <a href="{{ path('live_index') }}" class="et-feat-link">Watch Live <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

            <div class="et-feat-card">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-trophy"></i></div>
                <h3>Tournaments</h3>
                <p>Compete in structured brackets, climb the leaderboard, and prove your skills against top players.</p>
                {% if app.user %}
                <a href="{{ path('app_tournoi_landing') }}" class="et-feat-link">Browse Tournois <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

            <div class="et-feat-card">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-calendar-alt"></i></div>
                <h3>Training Sessions</h3>
                <p>Book structured coaching sessions, track your progress, and join group training with elite coaches.</p>
                {% if app.user %}
                <a href="{{ path('app_planning') }}" class="et-feat-link">View Planning <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

            <div class="et-feat-card">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-users"></i></div>
                <h3>Teams</h3>
                <p>Form or join a team, coordinate strategies, and compete together in organized team events.</p>
                {% if app.user %}
                <a href="{{ path('app_teams_index') }}" class="et-feat-link">My Teams <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

            <div class="et-feat-card">
                <div class="et-feat-glow"></div>
                <div class="et-feat-icon"><i class="fas fa-comments"></i></div>
                <h3>Community</h3>
                <p>Connect with players across all games, share clips, strategies, and build your network.</p>
                {% if app.user %}
                <a href="{{ path('community_channels_index') }}" class="et-feat-link">Join Community <i class="fas fa-arrow-right"></i></a>
                {% endif %}
                <div class="et-feat-corner tl"></div>
                <div class="et-feat-corner tr"></div>
                <div class="et-feat-corner bl"></div>
                <div class="et-feat-corner br"></div>
            </div>

        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════
   UPCOMING EVENT SECTION
═══════════════════════════════════════════════ #}
<section class="et-event">
    {# ✅ FIX: event_bg en WebP avec fallback PNG via JS #}
    <div class="et-event-bg" id="eventBg"></div>
    <div class="et-event-overlay"></div>
    <div class="et-event-scan"></div>

    <div class="container position-relative" style="z-index:3;">
        <div class="et-event-inner">
            <div class="et-event-content">
                <span class="et-event-tag">
                    <span class="et-event-dot"></span>
                    Upcoming Event
                </span>
                <h2 class="et-event-title">EyeTwin<br><span class="et-gradient-fire">Championship</span></h2>
                <p class="et-event-desc">
                    The biggest eSport event of the year is coming. Compete for glory, prestige, and exclusive rewards. 
                    Register your team and prove you belong at the top.
                </p>

                <div class="et-event-countdown">
                    <div class="et-cd-block">
                        <span class="et-cd-val" id="cd-days">00</span>
                        <span class="et-cd-lbl">Days</span>
                    </div>
                    <span class="et-cd-sep">:</span>
                    <div class="et-cd-block">
                        <span class="et-cd-val" id="cd-hours">00</span>
                        <span class="et-cd-lbl">Hours</span>
                    </div>
                    <span class="et-cd-sep">:</span>
                    <div class="et-cd-block">
                        <span class="et-cd-val" id="cd-mins">00</span>
                        <span class="et-cd-lbl">Min</span>
                    </div>
                    <span class="et-cd-sep">:</span>
                    <div class="et-cd-block">
                        <span class="et-cd-val" id="cd-secs">00</span>
                        <span class="et-cd-lbl">Sec</span>
                    </div>
                </div>

                {% if app.user %}
                <a href="{{ path('app_tournoi_landing') }}" class="btn-fire btn-fire-lg mt-3" style="text-decoration:none;">
                    <span class="btn-fire-bg"></span>
                    <i class="fas fa-trophy"></i>
                    <span>Register Now</span>
                </a>
                {% else %}
                <a href="{{ path('app_register') }}" class="btn-fire btn-fire-lg mt-3" style="text-decoration:none;">
                    <span class="btn-fire-bg"></span>
                    <i class="fas fa-bolt"></i>
                    <span>Join To Compete</span>
                </a>
                {% endif %}
            </div>

            <div class="et-event-badges">
                <div class="et-ev-badge">
                    <i class="fas fa-coins"></i>
                    <span class="et-ev-badge-val">50K</span>
                    <span class="et-ev-badge-lbl">Prize Pool</span>
                </div>
                <div class="et-ev-badge">
                    <i class="fas fa-users"></i>
                    <span class="et-ev-badge-val">256</span>
                    <span class="et-ev-badge-lbl">Teams Max</span>
                </div>
                <div class="et-ev-badge">
                    <i class="fas fa-gamepad"></i>
                    <span class="et-ev-badge-val">4</span>
                    <span class="et-ev-badge-lbl">Games</span>
                </div>
            </div>
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════
   RECENT VIDEOS SECTION (logged in only)
═══════════════════════════════════════════════ #}
{% if app.user %}
<section class="et-videos">
    <div class="container">
        <div class="et-section-header et-section-header--left">
            <span class="et-section-tag">Your Content</span>
            <h2 class="et-section-title">Recent <span class="et-gradient-text">Videos</span></h2>
            <a href="{{ path('app_video_upload') }}" class="btn-fire btn-fire-sm et-section-btn" style="text-decoration:none;">
                <span class="btn-fire-bg"></span>
                <i class="fas fa-plus"></i> <span>Add Video</span>
            </a>
        </div>

        {% if videos is empty %}
        <div class="et-empty">
            <div class="et-empty-glow"></div>
            <div class="et-empty-icon"><i class="fas fa-film"></i></div>
            <h4>No videos yet</h4>
            <p>Upload your first match recording and start improving.</p>
            <a href="{{ path('app_video_upload') }}" class="btn-fire mt-2" style="text-decoration:none;">
                <span class="btn-fire-bg"></span>
                <i class="fas fa-upload"></i> <span>Upload Now</span>
            </a>
        </div>
        {% else %}
        <div class="et-videos-grid">
            {% for video in videos %}
            <div class="et-vid-card">
                <div class="et-vid-glow"></div>
                <div class="et-vid-corner tl"></div>
                <div class="et-vid-corner tr"></div>
                <div class="et-vid-corner bl"></div>
                <div class="et-vid-corner br"></div>

                <div class="et-vid-thumb">
                    {# ✅ FIX: preload="none" — ne charge pas la vidéo au démarrage #}
                    <video preload="none" muted loading="lazy">
                        <source src="{{ video.videoUrl }}" type="video/mp4">
                    </video>
                    <div class="et-vid-play"><i class="fas fa-play"></i></div>
                    <div class="et-vid-overlay"></div>
                    {% if video.visibility == 'PUBLIC' %}
                    <span class="et-vid-badge et-vid-badge--pub">PUBLIC</span>
                    {% else %}
                    <span class="et-vid-badge et-vid-badge--priv">PRIVATE</span>
                    {% endif %}
                </div>

                <div class="et-vid-body">
                    <h5 class="et-vid-title">{{ video.title }}</h5>
                    <div class="et-vid-meta">
                        <span><i class="fas fa-gamepad"></i> {{ video.gameType }}</span>
                        <span><i class="fas fa-user"></i> {{ video.uploadedBy.username }}</span>
                    </div>
                    <a href="{{ path('app_video_show', { id: video.id }) }}" class="et-vid-btn">
                        View Analysis <i class="fas fa-chart-bar"></i>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
{% endif %}

{# ═══════════════════════════════════════════════
   CTA BOTTOM (not logged in)
═══════════════════════════════════════════════ #}
{% if not app.user %}
<section class="et-cta">
    <div class="et-cta-grid"></div>
    <div class="container position-relative" style="z-index:1;">
        <div class="et-cta-inner">
            <h2 class="et-cta-title">Ready to <span class="et-gradient-fire">Dominate?</span></h2>
            <p class="et-cta-sub">Join thousands of competitive players already leveling up on EyeTwin.</p>
            <div class="et-cta-btns">
                <a href="{{ path('app_register') }}" class="btn-fire btn-fire-lg" style="text-decoration:none;">
                    <span class="btn-fire-bg"></span>
                    <i class="fas fa-bolt"></i>
                    <span>Create Free Account</span>
                </a>
                <a href="{{ path('app_login') }}" class="btn-ghost" style="text-decoration:none;">
                    <i class="fas fa-sign-in-alt"></i> Already have an account
                </a>
            </div>
        </div>
    </div>
</section>
{% endif %}

{# ═══════════════════════════════════════════════
   STYLES
═══════════════════════════════════════════════ #}
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

:root {
    --red:      #e8372a;
    --red-hot:  #ff4d3d;
    --red-deep: #b02b20;
    --orange:   #ff6b2b;
    --pink:     #ff2060;
    --gold:     #f6d860;
    --green:    #00e676;
    --dark:     #080810;
    --dark2:    #0d0c1a;
    --text:     rgba(255,255,255,0.93);
    --muted:    rgba(255,255,255,0.38);
    --fhud:     'Orbitron', sans-serif;
    --fbody:    'Rajdhani', sans-serif;
    --fmono:    'Share Tech Mono', monospace;
}

/* ══════════════════════
   HERO
══════════════════════ */
.et-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #05040f;
}

#heroCanvas {
    position: absolute; inset: 0; z-index: 3;
    pointer-events: none; width: 100%; height: 100%;
}

.et-hero-arcade {
    position: absolute; inset: 0; z-index: 1;
    background-size: cover;
    background-position: center 30%;
    opacity: .22;
    filter: saturate(1.3) blur(.5px);
    transform: scale(1.04);
    transition: opacity .4s;
}

.et-hero-grid {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background-image:
        linear-gradient(rgba(232,55,42,.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,.05) 1px, transparent 1px);
    background-size: 55px 55px;
    animation: grid-drift 18s linear infinite;
}
@keyframes grid-drift { from{background-position:0 0} to{background-position:55px 55px} }

.et-hero-scan {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.04) 2px, rgba(0,0,0,.04) 4px);
    animation: scan-move 10s linear infinite;
}
@keyframes scan-move { from{background-position:0 0} to{background-position:0 100px} }

.et-hero-vignette {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 25%, rgba(0,0,0,.82) 100%);
}
.et-hero-bottom-fade {
    position: absolute; bottom: 0; left: 0; right: 0; height: 200px; z-index: 2; pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--dark));
}

/* Shimmer bottom border */
.et-hero::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 1px; z-index: 5;
    background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
    background-size: 300% 100%;
    animation: shimmer 4s linear infinite;
}
@keyframes shimmer { 0%{background-position:200%} 100%{background-position:-200%} }

.et-hero-inner {
    position: relative; z-index: 4;
    padding: 14vh 0 4rem;
    flex: 1; display: flex; flex-direction: column; justify-content: center;
}

.et-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    font-family: var(--fhud); font-size: .58rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase; color: var(--red-hot);
    background: rgba(232,55,42,.08); border: 1px solid rgba(232,55,42,.25);
    padding: .3rem .9rem; border-radius: 3px; margin-bottom: 1.6rem;
    animation: fade-up .5s .1s both;
}
.et-tag-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green); box-shadow: 0 0 8px var(--green);
    animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.et-hero-title {
    font-family: var(--fhud); font-weight: 900;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: .9; letter-spacing: .04em;
    margin-bottom: 1.4rem;
}
.et-ht-line1 {
    display: block; color: var(--text);
    animation: fade-up .6s .2s both cubic-bezier(.22,1,.36,1);
    text-shadow: 0 0 80px rgba(232,55,42,.2);
}
.et-ht-line2 {
    display: block;
    background: linear-gradient(90deg, var(--red) 0%, var(--orange) 45%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    background-size: 200%;
    animation: fade-up .6s .3s both cubic-bezier(.22,1,.36,1), grad-pan 5s ease-in-out infinite alternate;
    filter: drop-shadow(0 0 40px rgba(232,55,42,.5));
}
@keyframes grad-pan { from{background-position:0%} to{background-position:100%} }

.et-hero-sub {
    font-family: var(--fbody); font-size: 1.05rem;
    color: var(--muted); max-width: 520px; line-height: 1.7;
    margin-bottom: 2rem;
    animation: fade-up .5s .45s both;
}

.et-hero-cta {
    display: flex; flex-wrap: wrap; gap: .8rem; align-items: center;
    animation: fade-up .5s .55s both;
}

/* Fire button */
.btn-fire {
    position: relative; overflow: hidden;
    display: inline-flex; align-items: center; gap: .6rem;
    font-family: var(--fhud); font-size: .75rem; font-weight: 700;
    letter-spacing: .12em; text-transform: uppercase; color: #fff;
    background: linear-gradient(135deg, var(--red-deep), var(--red), var(--red-hot));
    border: none; border-radius: 9px; padding: .65rem 1.6rem;
    box-shadow: 0 4px 24px rgba(232,55,42,.4);
    text-decoration: none; cursor: pointer;
    transition: transform .18s, box-shadow .18s;
}
.btn-fire:hover { transform: translateY(-3px); box-shadow: 0 10px 36px rgba(232,55,42,.65); color: #fff; }
.btn-fire-bg { position: absolute; inset: 0; background: linear-gradient(135deg,rgba(255,255,255,.15),transparent); pointer-events: none; }
.btn-fire-lg  { padding: .85rem 2.2rem; font-size: .82rem; }
.btn-fire-sm  { padding: .5rem 1.1rem; font-size: .65rem; }

/* Ghost button */
.btn-ghost {
    display: inline-flex; align-items: center; gap: .45rem;
    font-family: var(--fhud); font-size: .72rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    color: rgba(255,255,255,.5); text-decoration: none;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
    padding: .65rem 1.4rem; border-radius: 9px;
    transition: all .2s;
}
.btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,.25); background: rgba(255,255,255,.08); }

.live-dot-sm {
    width: 7px; height: 7px; border-radius: 50%; background: var(--red-hot);
    box-shadow: 0 0 8px var(--red);
    animation: blink 1s step-end infinite;
}

/* Scroll hint */
.et-scroll-hint {
    display: flex; flex-direction: column; align-items: center; gap: .4rem;
    margin-top: 3rem; animation: fade-up .5s .7s both;
}
.et-scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, transparent, var(--red-hot), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
}
@keyframes scroll-pulse { 0%,100%{opacity:.3} 50%{opacity:1} }
.et-scroll-txt {
    font-family: var(--fmono); font-size: .52rem; color: var(--muted);
    letter-spacing: .22em;
}

/* Stat bar */
.et-hero-statsbar {
    position: relative; z-index: 4;
    background: rgba(0,0,0,.45); border-top: 1px solid rgba(232,55,42,.1);
    padding: 1rem 0; backdrop-filter: blur(12px);
}
.et-stats-row { display: flex; align-items: center; flex-wrap: wrap; }
.et-stat { display: flex; flex-direction: column; align-items: center; padding: .4rem 2.5rem; }
.et-stat-val {
    font-family: var(--fhud); font-size: 1.6rem; font-weight: 900;
    color: var(--red-hot); line-height: 1;
    text-shadow: 0 0 24px rgba(232,55,42,.6);
}
