{# ═══════════════════════════════════════════════
   SCRIPTS
═══════════════════════════════════════════════ #}
<script>
(function(){
    'use strict';

    /* ✅ FIX #1 — WebP detection + lazy background images */
    function supportsWebP(cb) {
        const img = new Image();
        img.onload = img.onerror = function() { cb(img.width === 2); };
        img.src = 'data:image/webp;base64,UklGRjoAAABXRUJQVlA4IC4AAACyAgCdASoCAAIALmk0mk0iIiIiIgBoSygABc6WWgAA/veff/0PP8bA//LwYAAA';
    }

    supportsWebP(function(supported) {
        const ext = supported ? 'webp' : 'png';

        // Hero arcade background
        const heroArcade = document.getElementById('heroArcade');
        if (heroArcade) {
            heroArcade.style.backgroundImage = "url('/assets/img/latest_war_img_1." + ext + "')";
        }

        // Event background (lazy — chargé seulement quand visible)
        const eventBg = document.getElementById('eventBg');
        if (eventBg) {
            const observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        eventBg.style.backgroundImage = "url('/assets/img/event_bg." + ext + "')";
                        observer.unobserve(eventBg);
                    }
                });
            }, { rootMargin: '200px' });
            observer.observe(eventBg);
        }
    });

    /* ── HERO PARTICLES ── */
    const canvas = document.getElementById('heroCanvas');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        let W, H, pts = [];
        function resize() {
            W = canvas.width  = canvas.parentElement.offsetWidth;
            H = canvas.height = canvas.parentElement.offsetHeight;
        }
        resize();
        window.addEventListener('resize', () => { resize(); spawn(); });

        const COLS = ['rgba(232,55,42,','rgba(255,77,61,','rgba(255,107,43,','rgba(255,32,96,','rgba(0,229,255,'];
        function mk() {
            const c = COLS[Math.floor(Math.random()*COLS.length)];
            return { x:Math.random()*W, y:H+50, vx:(Math.random()-.5)*.5, vy:-(0.25+Math.random()*.9), r:.8+Math.random()*1.4, a:0, ma:.2+Math.random()*.4, ph:Math.random()*Math.PI*2, c, l:0, ml:140+Math.random()*200 };
        }
        function spawn() { pts = Array.from({length:60}, mk); }
        spawn();

        (function tick() {
            ctx.clearRect(0,0,W,H);
            pts.forEach((p,i) => {
                p.l++; p.x += p.vx+Math.sin(p.ph+p.l*.018)*.2; p.y += p.vy;
                const t=p.l/p.ml;
                p.a = t<.15?(t/.15)*p.ma : t>.75?((1-t)/.25)*p.ma : p.ma;
                if(p.l>=p.ml||p.y<-10) pts[i]=mk();
                ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                ctx.fillStyle=p.c+p.a+')';
                ctx.shadowColor=p.c+'.4)'; ctx.shadowBlur=6;
                ctx.fill();
            });
            requestAnimationFrame(tick);
        })();
    }

    /* ── STAT COUNTER ── */
    const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (!e.isIntersecting) return;
            const el = e.target;
            const target = parseInt(el.dataset.target, 10);
            if (!target) return;
            let cur = 0;
            const step = Math.ceil(target / 20);
            const t = setInterval(() => {
                cur = Math.min(cur + step, target);
                el.textContent = cur.toLocaleString();
                if (cur >= target) clearInterval(t);
            }, 50);
            io.unobserve(el);
        });
    }, { threshold: .3 });
    document.querySelectorAll('.et-stat-val[data-target]').forEach(el => io.observe(el));

    /* ── SCROLL REVEAL ── */
    const sr = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                e.target.style.animationPlayState = 'running';
                sr.unobserve(e.target);
            }
        });
    }, { threshold: .06 });
    document.querySelectorAll('.et-feat-card, .et-vid-card').forEach(c => {
        c.style.animationPlayState = 'paused';
        sr.observe(c);
    });

    /* ── COUNTDOWN ── */
    const target = new Date('2025-09-01T20:00:00').getTime();
    function updateCd() {
        const diff = target - Date.now();
        if (diff <= 0) { ['days','hours','mins','secs'].forEach(k => document.getElementById('cd-'+k) && (document.getElementById('cd-'+k).textContent='00')); return; }
        const d = Math.floor(diff/86400000);
        const h = Math.floor((diff%86400000)/3600000);
        const m = Math.floor((diff%3600000)/60000);
        const s = Math.floor((diff%60000)/1000);
        const pad = n => String(n).padStart(2,'0');
        ['days','hours','mins','secs'].forEach((k,i) => {
            const el = document.getElementById('cd-'+k);
            if (el) el.textContent = pad([d,h,m,s][i]);
        });
    }
    updateCd();
    setInterval(updateCd, 1000);

    /* ── GLITCH on hero title ── */
    const line2 = document.querySelector('.et-ht-line2');
    if (line2) {
        setInterval(() => {
            if (Math.random() > .85) {
                line2.animate([
                    { transform:'none', filter:'none' },
                    { transform:'skewX(-4deg) translateX(-3px)', filter:'hue-rotate(40deg) brightness(1.5)' },
                    { transform:'skewX(2deg) translateX(4px)', filter:'hue-rotate(-20deg)' },
                    { transform:'none', filter:'none' },
                ], { duration:150, easing:'steps(3)' });
            }
        }, 3500);
    }
})();
</script>

