{% extends 'base.html.twig' %}

{% block title %}Highlight {{ highlight.uploadedBy ? highlight.uploadedBy.username : '' }}{% endblock %}

{% block body %}
<section class="clips-shell py-5">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <p class="text-uppercase text-primary-emphasis small mb-1">Player highlight</p>
                <h1 class="h3 mb-1">Highlight of {{ highlight.uploadedBy ? highlight.uploadedBy.username : 'Player' }}</h1>
                <p class="text-secondary mb-0">Match {{ highlight.matchExternalId ?: 'N/A' }} • {{ clips|length }} clips</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary" href="{{ path('clips_public') }}">Players Highlights</a>
                <a class="btn btn-primary" href="{{ path('clips_download', { id: highlight.id }) }}">Download</a>
            </div>
        </div>

        <div class="card border-0 shadow-lg mb-4 overflow-hidden">
            <div class="ratio ratio-16x9 bg-black">
                <video controls preload="metadata" poster="{{ highlight.thumbnailPath ?: '' }}">
                    <source src="{{ highlight.filePath }}" type="video/mp4">
                </video>
            </div>
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                    <h2 class="h5 mb-1">{{ highlight.title }}</h2>
                    <span class="badge text-bg-dark">{{ highlight.gameType ?: 'Game' }}</span>
                    <span class="badge text-bg-secondary">{{ highlight.visibility }}</span>
                    <span class="badge text-bg-danger"><i class="bi bi-heart-fill"></i> {{ highlight.likesCount }}</span>
                </div>
                <div class="d-flex gap-2">
                    {% if canManageVisibility %}
                        <form method="post" action="{{ path('clips_toggle_visibility', { id: highlight.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('clips_toggle_' ~ highlight.id) }}">
                            <button class="btn btn-sm btn-outline-dark" type="submit">
                                {{ highlight.visibility == 'PUBLIC' ? 'Set Private' : 'Publish' }}
                            </button>
                        </form>
                    {% endif %}
                    <a class="btn btn-sm btn-dark" href="{{ highlight.filePath }}" target="_blank" rel="noopener">Play</a>
                </div>
            </div>
        </div>

        <div class="row g-4">
            {% for clip in clips %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm clip-card">
                        <div class="position-relative">
                            {% if clip.thumbnailPath %}
                                <img src="{{ clip.thumbnailPath }}" class="card-img-top clip-thumb" alt="{{ clip.title }}">
                            {% else %}
                                <div class="clip-thumb bg-dark"></div>
                            {% endif %}
                            <a href="{{ clip.filePath }}" target="_blank" rel="noopener" class="play-overlay">
                                <i class="bi bi-play-fill"></i>
                            </a>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="h6 mb-1">{{ clip.killInfo ?: clip.title }}</h3>
                            <p class="text-secondary small mb-2">{{ clip.duration ?: 0 }} sec</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="badge text-bg-light">{{ clip.visibility }}</span>
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('clips_download', { id: clip.id }) }}">Download</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">No clips available for this highlight.</div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-5">
            <h2 class="h5 mb-3">clipsData (sample)</h2>
            <pre class="bg-dark text-light p-3 rounded small">{{ clipsData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
        </div>
    </div>
</section>

<style>
    .clips-shell {
        background: #f8fafc;
        min-height: 100vh;
    }

    .clip-thumb {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
    }

    .play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(8, 10, 20, 0.45);
        color: #fff;
        font-size: 2rem;
        opacity: 0;
        transition: opacity .2s ease-in-out;
        text-decoration: none;
    }

    .clip-card:hover .play-overlay {
        opacity: 1;
    }

    @media (max-width: 768px) {
        .card-body .btn {
            width: 100%;
        }
    }
</style>
{% endblock %}
