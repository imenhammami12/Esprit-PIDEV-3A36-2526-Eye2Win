{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Tooltips ── */
    [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        .forEach(el => new bootstrap.Tooltip(el, { delay:{show:300,hide:100} }));

    /* ── Live clock ── */
    function updateTime() {
        const el = document.getElementById('liveTime');
        if (!el) return;
        el.textContent = new Date().toLocaleTimeString('en-US', { hour12:false });
    }
    updateTime(); setInterval(updateTime, 1000);

    /* ════════════════════════════════════════════
       COUNT-UP — animation initiale au chargement
    ════════════════════════════════════════════ */
    function animateTo(el, targetVal, duration) {
        if (!el) return;
        const isPercent = typeof targetVal === 'string' && targetVal.includes('%');
        const target    = parseInt(targetVal, 10);
        if (isNaN(target)) return;

        const start = 0; // toujours de 0 pour l'animation initiale
        const steps = 60;
        const delay = (duration || 1200) / steps;
        let   i     = 0;
        const timer = setInterval(() => {
            i++;
            const val = Math.round(start + ((target - start) * i / steps));
            el.textContent = isPercent ? val + '%' : val;
            if (i >= steps) {
                el.textContent = isPercent ? target + '%' : target;
                clearInterval(timer);
            }
        }, delay);
    }

    function animateUpdate(el, newTarget, duration) {
        if (!el) return;
        const isPercent = el.id === 'statActiveRate' || el.id === 'donutPct';
        newTarget       = parseInt(newTarget, 10);
        if (isNaN(newTarget)) return;
        const start = parseInt(el.textContent, 10) || 0;
        if (start === newTarget) return;
        const diff  = newTarget - start;
        const steps = 40;
        const delay = (duration || 800) / steps;
        let   i     = 0;
        const timer = setInterval(() => {
            i++;
            const val = Math.round(start + (diff * i / steps));
            el.textContent = isPercent ? val + '%' : val;
            if (i >= steps) {
                el.textContent = isPercent ? newTarget + '%' : newTarget;
                clearInterval(timer);
            }
        }, delay);
    }

    // ── Animation initiale (chargement de page) ──────────────────
    const initialData = {
        total:      parseInt(document.getElementById('statTotal')?.textContent   || '0', 10),
        active:     parseInt(document.getElementById('statActive')?.textContent  || '0', 10),
        coaches:    parseInt(document.getElementById('statCoaches')?.textContent || '0', 10),
        admins:     parseInt(document.getElementById('statAdmins')?.textContent  || '0', 10),
        inactive:   parseInt(document.getElementById('statInactive')?.textContent || '0', 10),
        activeRate: parseInt((document.getElementById('statActiveRate')?.textContent || '0%').replace('%',''), 10),
    };

    // On met temporairement à 0 pour l'effet count-up
    ['statTotal','statActive','statCoaches','statAdmins','statInactive'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.textContent = '0'; animateTo(el, initialData[id === 'statCoaches' ? 'coaches' : id === 'statAdmins' ? 'admins' : id === 'statInactive' ? 'inactive' : id.replace('stat','').toLowerCase()], 1200); }
    });

    // Fix pour les noms de clés
    const keyMap = { statTotal:'total', statActive:'active', statCoaches:'coaches', statAdmins:'admins', statInactive:'inactive', statCoachesMini:'coaches' };
    ['statTotal','statActive','statCoaches','statAdmins','statInactive','statCoachesMini'].forEach(id => {
        const el  = document.getElementById(id);
        const key = keyMap[id];
        if (el && key) { el.textContent = '0'; animateTo(el, initialData[key], 1200); }
    });

    const rateEl = document.getElementById('statActiveRate');
    if (rateEl) { rateEl.textContent = '0%'; animateTo(rateEl, initialData.activeRate + '%', 1200); }
    const donutEl = document.getElementById('donutPct');
    if (donutEl) { donutEl.textContent = '0%'; animateTo(donutEl, initialData.activeRate + '%', 1200); }

    /* ════════════════════════════════════════════
       PARTICLE SYSTEM
    ════════════════════════════════════════════ */
    document.querySelectorAll('.xp-card').forEach(card => {
        const canvas = card.querySelector('.xp-particles');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let color = 'rgba(255,255,255,0.4)';
        if (card.classList.contains('xp-total'))          color = 'rgba(102,126,234,0.6)';
        else if (card.classList.contains('xp-resolved'))  color = 'rgba(67,233,123,0.6)';
        else if (card.classList.contains('xp-pending'))   color = 'rgba(240,147,251,0.6)';
        else if (card.classList.contains('xp-progress-card')) color = 'rgba(79,172,254,0.6)';

        const particles = Array.from({length:18}, () => ({
            x: Math.random() * canvas.width, y: Math.random() * canvas.height,
            r: Math.random() * 1.5 + 0.3,
            vx: (Math.random() - 0.5) * 0.4, vy: -Math.random() * 0.5 - 0.2,
            alpha: Math.random()
        }));

        let rafId = null;
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.x += p.vx; p.y += p.vy; p.alpha -= 0.004;
                if (p.alpha <= 0 || p.y < 0) {
                    p.x = Math.random() * canvas.width; p.y = canvas.height + 2;
                    p.alpha = Math.random() * 0.7 + 0.3;
                    p.vy = -Math.random() * 0.5 - 0.2; p.vx = (Math.random() - 0.5) * 0.4;
                }
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = color.replace('0.6', p.alpha.toFixed(2));
                ctx.fill();
            });
            rafId = requestAnimationFrame(draw);
        }
        card.addEventListener('mouseenter', () => draw());
        card.addEventListener('mouseleave', () => {
            if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        });
    });

    /* ── Row hover ── */
    document.querySelectorAll('.custom-table tbody tr').forEach(row => {
        row.addEventListener('mouseenter', () => row.style.transform = 'translateX(2px)');
        row.addEventListener('mouseleave', () => row.style.transform = 'translateX(0)');
    });

    /* ── Search bar border ── */
    const searchInput = document.getElementById('voiceSearchInput');
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            this.closest('.search-bar').style.borderColor =
                this.value.length > 0 ? 'rgba(102,126,234,0.5)' : '';
        });
    }

    /* ════════════════════════════════════════════
       STATS DYNAMIQUES — AJAX POLLING (30s)
    ════════════════════════════════════════════ */
    const STATS_URL    = '{{ path("admin_users_stats") }}';
    const refreshBadge = document.getElementById('lastRefreshBadge');

    function updateDonut(pct) {
        const circle = document.getElementById('donutCircle');
        if (circle) circle.setAttribute('stroke-dasharray', Math.round(pct * 150.8 / 100) + ' 150.8');
        const label = document.getElementById('donutPct');
        if (label) animateUpdate(label, pct);
    }

    async function refreshStats() {
        if (refreshBadge) {
            refreshBadge.classList.add('cmd-badge-refreshing');
            refreshBadge.textContent = 'REFRESHING…';
        }

        try {
            const res  = await fetch(STATS_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();

            // Cartes principales
            animateUpdate(document.getElementById('statTotal'),   data.total);
            animateUpdate(document.getElementById('statActive'),  data.active);
            animateUpdate(document.getElementById('statCoaches'), data.coaches);
            animateUpdate(document.getElementById('statAdmins'),  data.admins);

            // Barres de progression
            const pActive  = data.total > 0 ? Math.round((data.active  / data.total) * 100) : 0;
            const pCoaches = data.total > 0 ? Math.round((data.coaches / data.total) * 100) : 0;
            const pAdmins  = data.total > 0 ? Math.round((data.admins  / data.total) * 100) : 0;
            const pa = document.getElementById('progressActive');
            const pc = document.getElementById('progressCoaches');
            const pad = document.getElementById('progressAdmins');
            if (pa)  pa.style.width  = pActive  + '%';
            if (pc)  pc.style.width  = pCoaches + '%';
            if (pad) pad.style.width = pAdmins  + '%';

            // Mini cards
            animateUpdate(document.getElementById('statInactive'),    data.inactive);
            animateUpdate(document.getElementById('statCoachesMini'), data.coaches);
            const rateEl = document.getElementById('statActiveRate');
            if (rateEl) animateUpdate(rateEl, data.activeRate);

            // Donut
            updateDonut(data.activeRate);

            // Badge header
            const headerBadge = document.getElementById('headerTotalBadge');
            if (headerBadge) headerBadge.textContent = data.total + ' USERS';

            // Badge refresh
            if (refreshBadge) {
                refreshBadge.classList.remove('cmd-badge-refreshing');
                const now = new Date();
                refreshBadge.textContent = 'UPDATED ' + now.toLocaleTimeString('en-US', {hour12:false});
            }

        } catch (e) {
            console.warn('[Stats] Refresh failed:', e);
            if (refreshBadge) {
                refreshBadge.classList.remove('cmd-badge-refreshing');
                refreshBadge.textContent = 'RETRY';
            }
        }
    }

    // Clic manuel sur le badge
    if (refreshBadge) {
        refreshBadge.addEventListener('click', refreshStats);
    }

    // Auto-refresh : 5s après le chargement, puis toutes les 30s
    setTimeout(() => {
        refreshStats();
        setInterval(refreshStats, 30000);
    }, 5000);

    /* ════════════ Voice Search ════════════ */
    const micBtn     = document.getElementById('voiceMicBtn');
    const statusDiv  = document.getElementById('voiceStatus');
    const statusText = document.getElementById('voiceStatusText');
    const searchForm = document.getElementById('searchForm');
    if (!micBtn) return;

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const hasNativeSTT      = !!SpeechRecognition;
    const hasMediaRecorder  = !!(navigator.mediaDevices && window.MediaRecorder);
    if (hasNativeSTT || hasMediaRecorder) micBtn.style.display = 'flex';

    let isListening = false, recognition = null, mediaRecorder = null, audioChunks = [], micStream = null;

    function setListening(on) {
        isListening = on;
        if (on) {
            micBtn.classList.add('is-listening');
            micBtn.innerHTML = '<i class="bi bi-stop-fill"></i>';
            statusDiv.classList.remove('d-none');
            statusText.textContent = 'Listening… speak now';
        } else {
            micBtn.classList.remove('is-listening');
            micBtn.innerHTML = '<i class="bi bi-mic-fill"></i>';
            statusDiv.classList.add('d-none');
        }
    }
    function applyTranscript(text) {
        const clean = text.trim();
        if (!clean) return;
        searchInput.value = clean;
        setTimeout(() => searchForm.submit(), 600);
    }
    function startNativeSTT() {
        recognition = new SpeechRecognition();
        recognition.lang = 'en-US'; recognition.continuous = false; recognition.interimResults = true; recognition.maxAlternatives = 1;
        recognition.onstart  = () => setListening(true);
        recognition.onresult = (e) => {
            let interim = '', final = '';
            for (let i = e.resultIndex; i < e.results.length; i++) {
                const t = e.results[i][0].transcript;
                e.results[i].isFinal ? (final += t) : (interim += t);
            }
            searchInput.value = final || interim;
            if (final) recognition.stop();
        };
        recognition.onerror = (e) => { setListening(false); if (e.error === 'not-allowed') alert('Microphone access denied.'); };
        recognition.onend   = () => { const val = searchInput.value.trim(); setListening(false); if (val) setTimeout(() => searchForm.submit(), 500); };
        recognition.start();
    }
    const TRANSCRIBE_URL = '{{ path("app_speech_transcribe") }}';
    async function startMediaSTT() {
        try { micStream = await navigator.mediaDevices.getUserMedia({audio:true}); } catch { alert('Microphone access denied.'); return; }
        audioChunks = [];
        const mime = ['audio/webm;codecs=opus','audio/webm','audio/ogg',''].find(t => t === '' || MediaRecorder.isTypeSupported(t));
        mediaRecorder = new MediaRecorder(micStream, mime ? {mimeType:mime} : {});
        mediaRecorder.ondataavailable = e => { if (e.data?.size > 0) audioChunks.push(e.data); };
        mediaRecorder.onstop = async () => {
            micStream.getTracks().forEach(t => t.stop()); micStream = null; setListening(false);
            statusDiv.classList.remove('d-none'); statusText.textContent = 'Transcribing…';
            statusDiv.querySelector('.voice-pulse').style.background = '#ffc107';
            const blob = new Blob(audioChunks, {type: mediaRecorder.mimeType || 'audio/webm'});
            const formData = new FormData(); formData.append('audio', blob, 'search.webm');
            try {
                const res  = await fetch(TRANSCRIBE_URL, {method:'POST', body:formData, credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest'}});
                const ct   = res.headers.get('content-type') || '';
                if (!ct.includes('application/json')) { alert('Session expired. Please refresh.'); statusDiv.classList.add('d-none'); return; }
                const data = await res.json();
                statusDiv.classList.add('d-none');
                if (res.ok && data.text) { applyTranscript(data.text); } else { alert('Could not transcribe. Please try again.'); }
            } catch (err) { statusDiv.classList.add('d-none'); console.error(err); alert('Server error. Check your connection.'); }
            audioChunks = []; mediaRecorder = null;
        };
        mediaRecorder.start(250); setListening(true);
    }
    micBtn.addEventListener('click', () => {
        if (isListening) {
            if (recognition) recognition.stop();
            if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
            setListening(false);
            return;
        }
        hasNativeSTT ? startNativeSTT() : startMediaSTT();
    });
});
</script>
{% endblock %}
