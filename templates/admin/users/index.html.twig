{% extends 'admin_layout.html.twig' %}

{% block title %}User Management{% endblock %}
{% block page_title %}User Management{% endblock %}

{% block body %}

{# ══════════════════════════════════════════════════════════════
   MAIN STAT CARDS — PRIMARY ROW
══════════════════════════════════════════════════════════════ #}
<div class="xp-grid fade-in" style="animation-delay:0.05s;">

    {# TOTAL USERS #}
    <div class="xp-card xp-total">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(102,126,234,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(102,126,234,0.12)" stroke="rgba(102,126,234,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-people-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">◈ ROSTER COUNT</div>
                <div class="xp-num" id="statTotal">{{ stats.total }}</div>
                <div class="xp-title">Total Users</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressTotal" style="width:100%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# ACTIVE #}
    <div class="xp-card xp-resolved">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(67,233,123,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(67,233,123,0.12)" stroke="rgba(67,233,123,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-check-circle-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow xp-eyebrow-success">✓ IN THE ARENA</div>
                <div class="xp-num" id="statActive">{{ stats.active }}</div>
                <div class="xp-title">Active</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressActive"
                         style="width:{{ stats.total > 0 ? ((stats.active / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# COACHES #}
    <div class="xp-card xp-pending">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(240,147,251,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(240,147,251,0.12)" stroke="rgba(240,147,251,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-award-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">⚡ ELITE SQUAD</div>
                <div class="xp-num" id="statCoaches">{{ stats.coaches }}</div>
                <div class="xp-title">Coaches</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressCoaches"
                         style="width:{{ stats.total > 0 ? ((stats.coaches / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# ADMINS #}
    <div class="xp-card xp-progress-card">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(79,172,254,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(79,172,254,0.12)" stroke="rgba(79,172,254,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-shield-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">◉ COMMAND OPS</div>
                <div class="xp-num" id="statAdmins">{{ stats.admins }}</div>
                <div class="xp-title">Admins</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressAdmins"
                         style="width:{{ stats.total > 0 ? ((stats.admins / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

</div>

{# ══════════════════════════════════════════════════════════════
   SECONDARY STATS — MINI ROW
══════════════════════════════════════════════════════════════ #}
<div class="mini-stat-row fade-in" style="animation-delay:0.12s;">

    <div class="mini-card mini-orange">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-person-check-fill"></i></div>
            <div class="mini-data">
                <div class="mini-val mini-val-text" id="statActiveRate">{{ stats.activeRate }}%</div>
                <div class="mini-lbl">Active Rate</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,25 10,20 20,18 30,12 40,10 50,7 60,5" fill="none" stroke="rgba(255,167,81,0.6)" stroke-width="1.5"/>
                    <polyline points="0,25 10,20 20,18 30,12 40,10 50,7 60,5 60,30 0,30" fill="rgba(255,167,81,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="mini-card mini-red">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-person-x-fill"></i></div>
            <div class="mini-data">
                <div class="mini-val" id="statInactive">{{ stats.inactive }}</div>
                <div class="mini-lbl">Inactive</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,10 10,14 20,12 30,18 40,15 50,20 60,17" fill="none" stroke="rgba(255,107,107,0.6)" stroke-width="1.5"/>
                    <polyline points="0,10 10,14 20,12 30,18 40,15 50,20 60,17 60,30 0,30" fill="rgba(255,107,107,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="mini-card mini-teal">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-award-fill"></i></div>
            <div class="mini-data">
                <div class="mini-val" id="statCoachesMini">{{ stats.coaches }}</div>
                <div class="mini-lbl">Coaches</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,20 10,18 20,15 30,11 40,9 50,7 60,5" fill="none" stroke="rgba(56,249,215,0.6)" stroke-width="1.5"/>
                    <polyline points="0,20 10,18 20,15 30,11 40,9 50,7 60,5 60,30 0,30" fill="rgba(56,249,215,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    {# Active rate donut #}
    <div class="mini-card mini-donut-card">
        <div class="mini-card-inner">
            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 60 60">
                    <circle cx="30" cy="30" r="24" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6"/>
                    <circle id="donutCircle" cx="30" cy="30" r="24" fill="none"
                            stroke="url(#donutGradUsers)" stroke-width="6"
                            stroke-dasharray="{{ ((stats.activeRate * 150.8) / 100)|round }} 150.8"
                            stroke-dashoffset="37.7"
                            stroke-linecap="round"/>
                    <defs>
                        <linearGradient id="donutGradUsers" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#43e97b"/>
                            <stop offset="100%" stop-color="#38f9d7"/>
                        </linearGradient>
                    </defs>
                </svg>
                <div class="donut-center">
                    <span id="donutPct">{{ stats.activeRate }}%</span>
                </div>
            </div>
            <div class="mini-data">
                <div class="mini-lbl" style="font-size:10px; color:rgba(255,255,255,0.5);">Active</div>
                <div class="mini-lbl" style="font-size:10px; color:rgba(255,255,255,0.5);">Rate</div>
            </div>
        </div>
    </div>

</div>

{# ══════════════════════════════════════════════════════════════
   FILTERS & SEARCH
══════════════════════════════════════════════════════════════ #}
<div class="table-card mb-4 fade-in" style="animation-delay: 0.18s;">
    <div class="table-header">
        <h5><i class="bi bi-funnel me-2"></i>Filters & Search</h5>
    </div>

    <form method="get" action="{{ path('admin_users_index') }}" class="p-3" id="searchForm">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label"><i class="bi bi-search me-1"></i>Search</label>
                <div class="search-bar voice-search-bar">
                    <i class="search-icon bi bi-search"></i>
                    <input type="text" name="search" id="voiceSearchInput" class="form-control"
                           placeholder="Name, email, username..." value="{{ search }}" autocomplete="off">
                    <button type="button" id="voiceMicBtn" class="voice-mic-btn" title="Search by voice" style="display:none;">
                        <i class="bi bi-mic-fill"></i>
                    </button>
                </div>
                <div id="voiceStatus" class="voice-status d-none">
                    <span class="voice-pulse"></span>
                    <span id="voiceStatusText">Listening… speak now</span>
                </div>
            </div>

            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-shield me-1"></i>Role</label>
                <select name="role" class="form-select">
                    <option value="">All Roles</option>
                    <option value="ROLE_USER"  {{ roleFilter == 'ROLE_USER'  ? 'selected' : '' }}>User</option>
                    <option value="ROLE_COACH" {{ roleFilter == 'ROLE_COACH' ? 'selected' : '' }}>Coach</option>
                    <option value="ROLE_ADMIN" {{ roleFilter == 'ROLE_ADMIN' ? 'selected' : '' }}>Admin</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-toggle-on me-1"></i>Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    {% for status in accountStatuses %}
                        <option value="{{ status.value }}" {{ statusFilter == status.value ? 'selected' : '' }}>
                            {{ status.label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                {% if search or roleFilter or statusFilter %}
                    <a href="{{ path('admin_users_index') }}" class="btn btn-outline-secondary" title="Clear filters">
                        <i class="bi bi-x-lg"></i>
                    </a>
                {% endif %}
            </div>
        </div>
    </form>
</div>

{# Results Summary #}
<div class="mb-3 fade-in" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h6 class="text-muted mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Found <strong>{{ pagination.getTotalItemCount }}</strong> user{{ pagination.getTotalItemCount != 1 ? 's' : '' }}
        </h6>
        <a href="{{ path('admin_users_create') }}" class="btn"
           style="background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; box-shadow: 0 6px 20px rgba(102,126,234,0.3);">
            <i class="bi bi-plus-circle me-2"></i>New User
        </a>
    </div>
</div>

{# Users Table #}
<div class="table-card fade-in" style="animation-delay: 0.22s;">
    <div class="table-header">
        <h5><i class="bi bi-people me-2"></i>Users List ({{ pagination.getTotalItemCount }})</h5>
    </div>

    <div class="table-responsive">
        <table class="custom-table table">
            <thead>
                <tr>
                    <th style="width:70px; text-align:center;">Photo</th>
                    <th style="width:180px;">Full Name</th>
                    <th style="width:220px;">Email</th>
                    <th style="width:150px;">Username</th>
                    <th style="width:110px;">Role</th>
                    <th style="width:110px;">Status</th>
                    <th style="width:130px;">Joined</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in pagination %}
                    {% set isCurrentUser  = user.id == app.user.id %}
                    {% set isTargetAdmin  = 'ROLE_ADMIN' in user.roles %}
                    {% set canModify      = not isCurrentUser and (not isTargetAdmin or is_granted('ROLE_SUPER_ADMIN')) %}

                    <tr class="fade-in" style="animation-delay: {{ loop.index * 0.05 }}s;">
                        <td style="width:70px; text-align:center;">
                            {% if user.profilePicture %}
                                <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}"
                                     alt="{{ user.username }}" class="user-avatar-table" loading="lazy">
                            {% else %}
                                <div class="user-avatar-placeholder mx-auto">
                                    {{ user.username|slice(0, 2)|upper }}
                                </div>
                            {% endif %}
                        </td>
                        <td style="width:180px;">
                            <strong>{{ user.fullName ?? 'N/A' }}</strong>
                            {% if isCurrentUser %}
                                <span class="badge badge-sm bg-info ms-1">You</span>
                            {% endif %}
                        </td>
                        <td style="width:220px;">
                            <a href="mailto:{{ user.email }}" class="text-decoration-none" style="color:#4facfe;">
                                <i class="bi bi-envelope me-1"></i>
                                <span style="display:inline-block; max-width:190px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;">{{ user.email }}</span>
                            </a>
                        </td>
                        <td style="width:150px;">
                            <a href="{{ path('admin_users_show', {id: user.id}) }}" class="text-decoration-none" style="color:#43e97b;">
                                <i class="bi bi-at me-1"></i>
                                <strong>{{ user.username }}</strong>
                            </a>
                        </td>
                        <td style="width:110px;">
                            {% if 'ROLE_SUPER_ADMIN' in user.roles %}
                                <span class="badge bg-dark"><i class="bi bi-shield-shaded me-1"></i>Super Admin</span>
                            {% elseif 'ROLE_ADMIN' in user.roles %}
                                <span class="badge bg-danger"><i class="bi bi-shield-fill me-1"></i>Admin</span>
                            {% elseif 'ROLE_COACH' in user.roles %}
                                <span class="badge bg-warning"><i class="bi bi-award-fill me-1"></i>Coach</span>
                            {% else %}
                                <span class="badge bg-info"><i class="bi bi-person-fill me-1"></i>User</span>
                            {% endif %}
                        </td>
                        <td style="width:110px;">
                            <span class="badge bg-{{ user.accountStatus.badgeClass }}"
                                  data-bs-toggle="tooltip"
                                  title="{{ user.accountStatus.description }}">
                                {{ user.accountStatus.label }}
                            </span>
                        </td>
                        <td style="width:130px;">
                            <small class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>
                                {{ user.createdAt|date('M d, Y') }}
                            </small>
                        </td>
                        <td style="width:180px;">
                            <div class="btn-group" role="group">
                                <a href="{{ path('admin_users_show', {id: user.id}) }}"
                                   class="btn btn-sm btn-info" title="View Details" data-bs-toggle="tooltip">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if user.accountStatus.value == 'ACTIVE' %}
                                    <button type="button" class="btn btn-sm btn-warning"
                                            onclick="confirmAction('{{ path('admin_users_suspend', {id: user.id}) }}', '{{ csrf_token('suspend-' ~ user.id) }}', 'Suspend this user?')"
                                            title="{% if not canModify %}Cannot suspend{% else %}Suspend User{% endif %}"
                                            data-bs-toggle="tooltip"
                                            {% if not canModify %}disabled{% endif %}>
                                        <i class="bi bi-exclamation-triangle"></i>
                                    </button>
                                {% else %}
                                    <button type="button" class="btn btn-sm btn-success"
                                            onclick="confirmAction('{{ path('admin_users_activate', {id: user.id}) }}', '{{ csrf_token('activate-' ~ user.id) }}', 'Reactivate this user?')"
                                            title="Reactivate User" data-bs-toggle="tooltip"
                                            {% if not canModify and user.accountStatus.value == 'BANNED' and isTargetAdmin %}disabled{% endif %}>
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                {% endif %}
                                <button type="button" class="btn btn-sm btn-danger"
                                        onclick="confirmAction('{{ path('admin_users_delete', {id: user.id}) }}', '{{ csrf_token('delete-' ~ user.id) }}', 'Permanently delete this user?')"
                                        title="{% if not canModify %}Cannot delete{% else %}Delete User{% endif %}"
                                        data-bs-toggle="tooltip"
                                        {% if not canModify %}disabled{% endif %}>
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <div class="empty-state">
                                <i class="bi bi-inbox" style="font-size:64px; opacity:0.2;"></i>
                                <h4 class="mt-3 mb-2">No Users Found</h4>
                                <p class="text-muted">Try adjusting your search criteria or create a new user</p>
                                <a href="{{ path('admin_users_create') }}" class="btn btn-primary mt-3">
                                    <i class="bi bi-plus-circle me-2"></i>Create First User
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Pagination #}
{% if pagination.getTotalItemCount > 20 %}
<div class="d-flex justify-content-between align-items-center mt-4 fade-in" style="animation-delay: 0.3s;">
    <div class="text-muted">
        Showing {{ ((pagination.currentPageNumber - 1) * 20) + 1 }}
        to {{ min(pagination.currentPageNumber * 20, pagination.getTotalItemCount) }}
        of {{ pagination.getTotalItemCount }} entries
    </div>
    <div class="pagination-wrapper">
        {{ knp_pagination_render(pagination, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig', {}, {
            'search': search, 'role': roleFilter, 'status': statusFilter
        }) }}
    </div>
</div>
{% endif %}

{% if not is_granted('ROLE_SUPER_ADMIN') %}
<div class="alert alert-info mt-4 fade-in" style="animation-delay: 0.4s;">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Permission Notice:</strong> You have ROLE_ADMIN access. Only Super Administrators can suspend, ban, or delete other Administrators.
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════
   STYLES
══════════════════════════════════════════════════════════════ #}
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&display=swap');

/* ── Command center header ── */
.cmd-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 20px; padding: 8px 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    font-family: 'Share Tech Mono', monospace; font-size: 11px;
}
.cmd-status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #43e97b; box-shadow: 0 0 8px #43e97b;
    animation: cmdPulse 2s ease-in-out infinite; display: inline-block;
}
@keyframes cmdPulse { 0%,100%{opacity:1; box-shadow:0 0 8px #43e97b;} 50%{opacity:.6; box-shadow:0 0 16px #43e97b;} }
.cmd-status-text { color: #43e97b; margin-left: 8px; }
.cmd-divider { color: rgba(255,255,255,0.2); margin: 0 10px; }
.cmd-timestamp { color: rgba(255,255,255,0.5); }
.cmd-header-right { display: flex; gap: 8px; align-items: center; }
.cmd-badge {
    padding: 3px 10px; border-radius: 4px; font-size: 10px;
    font-weight: 700; letter-spacing: 1px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
}
.cmd-badge-alert {
    background: rgba(102,126,234,0.15);
    border-color: rgba(102,126,234,0.4);
    color: #a0aef8;
    animation: cmdPulse 2s ease-in-out infinite;
}
.cmd-badge-refresh {
    cursor: pointer;
    transition: background .2s, color .2s, border-color .2s;
}
.cmd-badge-refresh:hover {
    background: rgba(67,233,123,0.15);
    border-color: rgba(67,233,123,0.4);
    color: #43e97b;
}
.cmd-badge-refreshing {
    background: rgba(255,193,7,0.15) !important;
    border-color: rgba(255,193,7,0.4) !important;
    color: #ffc107 !important;
    animation: cmdPulse 0.6s ease-in-out infinite !important;
}

/* ══ XP GRID ══ */
.xp-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-bottom: 16px;
}
@media (max-width:1200px) { .xp-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width:600px)  { .xp-grid { grid-template-columns: 1fr; } }

.xp-card {
    position: relative; border-radius: 12px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(10,5,20,0.9); min-height: 155px; cursor: pointer;
