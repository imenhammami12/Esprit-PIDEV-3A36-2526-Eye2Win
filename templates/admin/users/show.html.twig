{% extends 'admin_layout.html.twig' %}

{% block title %}{{ user.username }} - User Details{% endblock %}
{% block page_title %}User Details{% endblock %}

{% block body %}
{% set isCurrentUser = user.id == app.user.id %}
{% set isTargetAdmin = 'ROLE_ADMIN' in user.roles %}
{% set canModifyRole = not isCurrentUser and (not isTargetAdmin or is_granted('ROLE_SUPER_ADMIN')) %}
{% set canSuspendBan = not isCurrentUser and (not isTargetAdmin or is_granted('ROLE_SUPER_ADMIN')) %}
{% set canDelete = not isCurrentUser and (not isTargetAdmin or is_granted('ROLE_SUPER_ADMIN')) %}

<div class="mb-3 fade-in">
    <a href="{{ path('admin_users_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

{# Permission Warnings #}
{% if not canModifyRole and not isCurrentUser %}
<div class="alert alert-warning fade-in mb-3">
    <i class="bi bi-shield-exclamation me-2"></i>
    <strong>Limited Permissions:</strong> Only Super Administrators can modify other Administrators.
</div>
{% elseif isCurrentUser %}
<div class="alert alert-info fade-in mb-3">
    <i class="bi bi-person-badge me-2"></i>
    <strong>Viewing Your Own Profile:</strong> You cannot modify your own role or account status for security reasons.
</div>
{% endif %}

<div class="row g-4">
    {# ── Left column: Profile Card ── #}
    <div class="col-lg-4">
        <div class="table-card text-center fade-in" style="animation-delay:0.1s; padding: 2rem 1.5rem;">

            {# Avatar #}
            <div class="mb-4 position-relative d-inline-block">
                {% if user.profilePicture %}
                    <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}"
                         alt="{{ user.username }}"
                         style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:4px solid rgba(102,126,234,0.4);box-shadow:0 8px 24px rgba(0,0,0,0.25);"
                         loading="lazy">
                {% else %}
                    <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:#fff;font-size:38px;font-weight:700;box-shadow:0 8px 24px rgba(102,126,234,0.3);margin:0 auto;">
                        {{ user.username|slice(0,2)|upper }}
                    </div>
                {% endif %}
                {# Status dot #}
                <span style="
                    position:absolute;bottom:4px;right:4px;
                    width:18px;height:18px;border-radius:50%;
                    border:3px solid var(--dark-bg, #1a1a2e);
                    background:{{ user.accountStatus.value == 'ACTIVE' ? '#43e97b' : (user.accountStatus.value == 'SUSPENDED' ? '#ffa500' : '#ff4444') }};
                    box-shadow:0 0 10px {{ user.accountStatus.value == 'ACTIVE' ? 'rgba(67,233,123,.6)' : 'rgba(255,68,68,.6)' }};
                "></span>
            </div>

            <h4 class="mb-1 fw-bold">
                {{ user.fullName ?? user.username }}
                {% if isCurrentUser %}<span class="badge bg-info ms-2" style="font-size:0.65rem;">You</span>{% endif %}
            </h4>
            <p class="text-muted mb-3" style="font-size:0.9rem;">@{{ user.username }}</p>

            {# Role + Status badges #}
            <div class="d-flex gap-2 justify-content-center flex-wrap mb-4">
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="badge" style="background:rgba(220,53,69,0.15);color:#ff6b7a;border:1px solid rgba(220,53,69,0.3);padding:6px 12px;">
                        <i class="bi bi-shield-fill me-1"></i>Administrator
                    </span>
                {% elseif 'ROLE_COACH' in user.roles %}
                    <span class="badge" style="background:rgba(255,193,7,0.15);color:#ffd54f;border:1px solid rgba(255,193,7,0.3);padding:6px 12px;">
                        <i class="bi bi-award-fill me-1"></i>Coach
                    </span>
                {% else %}
                    <span class="badge" style="background:rgba(79,172,254,0.15);color:#4facfe;border:1px solid rgba(79,172,254,0.3);padding:6px 12px;">
                        <i class="bi bi-person-fill me-1"></i>User
                    </span>
                {% endif %}

                <span class="badge bg-{{ user.accountStatus.badgeClass }}" style="padding:6px 12px;" data-bs-toggle="tooltip" title="{{ user.accountStatus.description }}">
                    <i class="bi bi-{{ user.accountStatus.value == 'ACTIVE' ? 'check-circle' : (user.accountStatus.value == 'SUSPENDED' ? 'exclamation-triangle' : 'x-circle') }} me-1"></i>
                    {{ user.accountStatus.label }}
                </span>
            </div>

            {% if user.bio %}
            <div class="text-start p-3 mb-4" style="background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.06);">
                <h6 class="mb-2 text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;"><i class="bi bi-chat-quote me-2"></i>Biography</h6>
                <p class="mb-0" style="font-size:0.875rem;color:rgba(255,255,255,0.7);">{{ user.bio }}</p>
            </div>
            {% endif %}

            <hr style="border-color:rgba(255,255,255,0.08);">

            {# Change Role #}
            <div class="mb-3 text-start">
                <form method="post" action="{{ path('admin_users_edit_role', {id: user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('edit-role-' ~ user.id) }}">
                    <label class="form-label fw-bold mb-2" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:.05em;color:rgba(255,255,255,0.5);">
                        <i class="bi bi-shield-check me-1"></i>Change Role
                    </label>
                    <select name="role" class="form-select mb-3" {% if not canModifyRole %}disabled{% endif %}>
                        <option value="ROLE_USER"  {% if 'ROLE_ADMIN' not in user.roles and 'ROLE_COACH' not in user.roles %}selected{% endif %}>User</option>
                        <option value="ROLE_COACH" {% if 'ROLE_COACH' in user.roles and 'ROLE_ADMIN' not in user.roles %}selected{% endif %}>Coach</option>
                        <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in user.roles %}selected{% endif %} {% if not is_granted('ROLE_SUPER_ADMIN') %}disabled{% endif %}>
                            Administrator {% if not is_granted('ROLE_SUPER_ADMIN') %}(Super Admin only){% endif %}
                        </option>
                    </select>
                    <button type="submit" class="btn w-100" style="
                        background:linear-gradient(135deg,#667eea,#764ba2);
                        color:#fff;border:none;
                        box-shadow:0 4px 15px rgba(102,126,234,0.3);
                        font-weight:600;padding:10px;
                        transition:all .3s;
                    " {% if not canModifyRole %}disabled{% endif %}>
                        <i class="bi bi-save me-2"></i>Update Role
                    </button>
                    {% if not canModifyRole %}
                    <small class="text-muted d-block mt-2 text-center">
                        <i class="bi bi-info-circle me-1"></i>
                        {{ isCurrentUser ? 'Cannot modify your own role' : 'Only Super Admins can modify Admins' }}
                    </small>
                    {% endif %}
                </form>
            </div>

            <hr style="border-color:rgba(255,255,255,0.08);">

            {# Status alert if not active #}
            {% if user.accountStatus.value != 'ACTIVE' %}
            <div class="alert alert-{{ user.accountStatus.value == 'SUSPENDED' ? 'warning' : 'danger' }} text-start mb-3" style="border-radius:10px;">
                <h6 class="alert-heading mb-1" style="font-size:0.85rem;">
                    <i class="bi bi-{{ user.accountStatus.value == 'SUSPENDED' ? 'exclamation-triangle' : 'x-octagon' }} me-2"></i>
                    Account {{ user.accountStatus.label }}
                </h6>
                <p class="mb-0 small">{{ user.accountStatus.description }}</p>
            </div>
            {% endif %}

            {# Action Buttons — subtle, readable #}
            <div class="d-grid gap-2">
                {% if user.accountStatus.value == 'ACTIVE' %}
                    {# Suspend — amber outline #}
                    <button type="button"
                            class="btn"
                            style="background:rgba(255,171,0,0.08);border:1px solid rgba(255,171,0,0.35);color:#ffb700;font-weight:600;padding:10px;transition:all .25s;"
                            onmouseenter="this.style.background='rgba(255,171,0,0.16)'"
                            onmouseleave="this.style.background='rgba(255,171,0,0.08)'"
                            onclick="confirmAction('{{ path('admin_users_suspend', {id: user.id}) }}', '{{ csrf_token('suspend-' ~ user.id) }}', 'Suspend this user? They will not be able to log in until reactivated.')"
                            data-bs-toggle="tooltip" title="Temporarily suspend user access"
                            {% if not canSuspendBan %}disabled{% endif %}>
                        <i class="bi bi-exclamation-triangle me-2"></i>Suspend User
                    </button>

                    {# Ban — red outline #}
                    <button type="button"
                            class="btn"
                            style="background:rgba(255,60,100,0.08);border:1px solid rgba(255,60,100,0.35);color:#ff6b7a;font-weight:600;padding:10px;transition:all .25s;"
                            onmouseenter="this.style.background='rgba(255,60,100,0.16)'"
                            onmouseleave="this.style.background='rgba(255,60,100,0.08)'"
                            onclick="confirmAction('{{ path('admin_users_ban', {id: user.id}) }}', '{{ csrf_token('ban-' ~ user.id) }}', 'Ban this user permanently? This is a serious action.')"
                            data-bs-toggle="tooltip" title="Permanently ban user"
                            {% if not canSuspendBan %}disabled{% endif %}>
                        <i class="bi bi-x-circle me-2"></i>Ban User
                    </button>
                {% else %}
                    {# Reactivate — green outline #}
                    <button type="button"
                            class="btn"
                            style="background:rgba(67,233,123,0.08);border:1px solid rgba(67,233,123,0.35);color:#43e97b;font-weight:600;padding:10px;transition:all .25s;"
                            onmouseenter="this.style.background='rgba(67,233,123,0.16)'"
                            onmouseleave="this.style.background='rgba(67,233,123,0.08)'"
                            onclick="confirmAction('{{ path('admin_users_activate', {id: user.id}) }}', '{{ csrf_token('activate-' ~ user.id) }}', 'Reactivate this user?')"
                            data-bs-toggle="tooltip" title="Reactivate user account"
                            {% if not canSuspendBan and user.accountStatus.value == 'BANNED' and isTargetAdmin %}disabled{% endif %}>
                        <i class="bi bi-check-circle me-2"></i>Reactivate User
                    </button>
                {% endif %}

                {# Delete — muted red, always last #}
                <button type="button"
                        class="btn"
                        style="background:rgba(180,40,60,0.08);border:1px solid rgba(180,40,60,0.3);color:rgba(255,107,122,0.7);font-weight:600;padding:10px;transition:all .25s;"
                        onmouseenter="this.style.background='rgba(180,40,60,0.18)';this.style.color='#ff6b7a'"
                        onmouseleave="this.style.background='rgba(180,40,60,0.08)';this.style.color='rgba(255,107,122,0.7)'"
                        onclick="confirmAction('{{ path('admin_users_delete', {id: user.id}) }}', '{{ csrf_token('delete-' ~ user.id) }}', 'Permanently delete this user and all their data? This cannot be undone!')"
                        data-bs-toggle="tooltip" title="Permanently delete user"
                        {% if not canDelete %}disabled{% endif %}>
                    <i class="bi bi-trash me-2"></i>Delete User
                </button>

                {% if not canSuspendBan or not canDelete %}
                <small class="text-muted text-center">
                    <i class="bi bi-shield-lock me-1"></i>
                    {{ isCurrentUser ? 'Self-modification restricted' : 'Super Admin permission required' }}
                </small>
                {% endif %}
            </div>

        </div>
    </div>

    {# ── Right column ── #}
    <div class="col-lg-8">

        {# Personal Information #}
        <div class="table-card mb-4 fade-in" style="animation-delay:0.3s;">
            <div class="table-header">
                <h5><i class="bi bi-info-circle me-2"></i>Personal Information</h5>
            </div>
            <div class="p-4">
                <div class="row g-4">

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(79,172,254,0.12);display:flex;align-items:center;justify-content:center;color:#4facfe;flex-shrink:0;">
                                <i class="bi bi-envelope"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Email</small>
                                <div class="fw-semibold mt-1">
                                    <a href="mailto:{{ user.email }}" class="text-decoration-none" style="color:#4facfe;">{{ user.email }}</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(102,126,234,0.12);display:flex;align-items:center;justify-content:center;color:#667eea;flex-shrink:0;">
                                <i class="bi bi-at"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Username</small>
                                <div class="fw-semibold mt-1">@{{ user.username }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(67,233,123,0.12);display:flex;align-items:center;justify-content:center;color:#43e97b;flex-shrink:0;">
                                <i class="bi bi-person"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Full Name</small>
                                <div class="fw-semibold mt-1">{{ user.fullName ?? 'Not provided' }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,193,7,0.12);display:flex;align-items:center;justify-content:center;color:#ffd54f;flex-shrink:0;">
                                <i class="bi bi-calendar-plus"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Registered</small>
                                <div class="fw-semibold mt-1">
                                    {{ user.createdAt|date('M d, Y · h:i A') }}
                                    <span class="text-muted ms-1" style="font-size:0.8rem;">({{ (('now'|date('U') - user.createdAt|date('U')) / 86400)|round }}d ago)</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.4);flex-shrink:0;">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Last Login</small>
                                <div class="fw-semibold mt-1">
                                    {% if user.lastLogin %}
                                        {{ user.lastLogin|date('M d, Y · h:i A') }}
                                    {% else %}
                                        <span class="text-muted">Never</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-3">
                            <div style="width:36px;height:36px;border-radius:10px;background:rgba(102,126,234,0.12);display:flex;align-items:center;justify-content:center;color:#667eea;flex-shrink:0;">
                                <i class="bi bi-toggle-on"></i>
                            </div>
                            <div>
                                <small class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">Account Status</small>
                                <div class="mt-1">
                                    <span class="badge bg-{{ user.accountStatus.badgeClass }}" data-bs-toggle="tooltip" title="{{ user.accountStatus.description }}" style="padding:5px 10px;">
                                        <i class="bi bi-{{ user.accountStatus.value == 'ACTIVE' ? 'check-circle' : (user.accountStatus.value == 'SUSPENDED' ? 'exclamation-triangle' : 'x-circle') }} me-1"></i>
                                        {{ user.accountStatus.label }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        {# Teams #}
        <div class="table-card mb-4 fade-in" style="animation-delay:0.4s;">
            <div class="table-header">
                <h5>
                    <i class="bi bi-grid-3x3 me-2"></i>Teams
                    <span class="badge bg-primary ms-2">{{ user.teamMemberships|length }}</span>
                </h5>
            </div>
            {% if user.teamMemberships|length > 0 %}
                <div class="table-responsive">
                    <table class="custom-table table">
                        <thead>
                            <tr>
                                <th>Team</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Joined On</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for membership in user.teamMemberships %}
                            <tr>
                                <td><strong><i class="bi bi-trophy me-2"></i>{{ membership.team.name }}</strong></td>
                                <td><span class="badge bg-primary">{{ membership.role.label }}</span></td>
                                <td><span class="badge bg-{{ membership.status.value == 'ACTIVE' ? 'success' : 'secondary' }}">{{ membership.status.label }}</span></td>
                                <td><small><i class="bi bi-calendar me-1"></i>{{ membership.joinedAt ? membership.joinedAt|date('M d, Y') : 'N/A' }}</small></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-grid-3x3" style="font-size:48px;opacity:.15;"></i>
                    <p class="text-muted mt-3 mb-1">No teams yet</p>
                    <small class="text-muted">This user hasn't joined any teams</small>
                </div>
            {% endif %}
        </div>

        {# Coach Applications #}
        {% if user.coachApplications|length > 0 %}
        <div class="table-card fade-in" style="animation-delay:0.5s;">
            <div class="table-header">
                <h5>
                    <i class="bi bi-clipboard-check me-2"></i>Coach Applications
                    <span class="badge bg-warning ms-2">{{ user.coachApplications|length }}</span>
                </h5>
            </div>
            <div class="table-responsive">
                <table class="custom-table table">
                    <thead>
                        <tr>
                            <th>Submission Date</th>
                            <th>Status</th>
                            <th>Reviewed On</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for application in user.coachApplications %}
                        <tr>
                            <td><small><i class="bi bi-calendar-check me-1"></i>{{ application.submittedAt|date('M d, Y h:i A') }}</small></td>
                            <td><span class="badge bg-{{ application.status.badgeClass }}">{{ application.status.label }}</span></td>
                            <td>
                                <small>
                                    {% if application.reviewedAt %}
                                        <i class="bi bi-clock-history me-1"></i>{{ application.reviewedAt|date('M d, Y h:i A') }}
                                    {% else %}
                                        <span class="text-muted">Not reviewed</span>
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <a href="{{ path('admin_coach_applications_show', {id: application.id}) }}" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el =>
        new bootstrap.Tooltip(el, { delay: { show: 300, hide: 100 } })
    );
});
</script>
{% endblock %}
