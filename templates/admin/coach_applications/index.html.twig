{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Tooltips ── */
    [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        .forEach(el => new bootstrap.Tooltip(el, { delay:{show:300,hide:100} }));

    /* ── Live clock ── */
    function updateTime() {
        const el = document.getElementById('liveTime');
        if (!el) return;
        el.textContent = new Date().toLocaleTimeString('en-US', { hour12:false });
    }
    updateTime(); setInterval(updateTime, 1000);

    /* ── Row hover ── */
    document.querySelectorAll('.custom-table tbody tr').forEach(row => {
        row.addEventListener('mouseenter', () => row.style.transform = 'translateX(2px)');
        row.addEventListener('mouseleave', () => row.style.transform = 'translateX(0)');
    });

    /* ════════════════════════════════════════════
       COUNT-UP — animation initiale
    ════════════════════════════════════════════ */
    function animateTo(el, target, duration) {
        if (!el) return;
        const isPercent = typeof el.textContent === 'string' && el.id === 'statApprovalRate';
        target = parseInt(target, 10);
        if (isNaN(target)) return;
        const steps = 60, delay = (duration || 1200) / steps;
        let i = 0;
        const timer = setInterval(() => {
            i++;
            el.textContent = isPercent
                ? Math.round(target * i / steps) + '%'
                : Math.round(target * i / steps);
            if (i >= steps) { el.textContent = isPercent ? target + '%' : target; clearInterval(timer); }
        }, delay);
    }

    function animateUpdate(el, newTarget, duration) {
        if (!el) return;
        const isPercent = el.id === 'statApprovalRate' || el.id === 'donutPct';
        newTarget = parseInt(newTarget, 10);
        if (isNaN(newTarget)) return;
        const start = parseInt(el.textContent, 10) || 0;
        if (start === newTarget) return;
        const diff = newTarget - start, steps = 40, delay = (duration || 800) / steps;
        let i = 0;
        const timer = setInterval(() => {
            i++;
            const val = Math.round(start + (diff * i / steps));
            el.textContent = isPercent ? val + '%' : val;
            if (i >= steps) { el.textContent = isPercent ? newTarget + '%' : newTarget; clearInterval(timer); }
        }, delay);
    }

    // Lecture des valeurs initiales Twig, remise à 0, puis count-up
    const statIds = {
        statTotal:       'total',
        statPending:     'pending',
        statApproved:    'approved',
        statRejected:    'rejected',
        statPendingMini: 'pending',
        statRejectedMini:'rejected',
    };
    const initVals = {};
    Object.keys(statIds).forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        initVals[id] = parseInt(el.textContent, 10) || 0;
        el.textContent = '0';
    });
    Object.keys(statIds).forEach((id, idx) => {
        setTimeout(() => animateTo(document.getElementById(id), initVals[id], 1000), idx * 100);
    });

    // Taux approval
    const rateEl = document.getElementById('statApprovalRate');
    const donutEl = document.getElementById('donutPct');
    const initRate = rateEl ? parseInt(rateEl.textContent, 10) || 0 : 0;
    if (rateEl)  { rateEl.textContent  = '0%'; setTimeout(() => animateTo(rateEl,  initRate, 1000), 0); }
    if (donutEl) { donutEl.textContent = '0%'; setTimeout(() => animateTo(donutEl, initRate, 1000), 0); }

    /* ════════════════════════════════════════════
       PARTICLE SYSTEM
    ════════════════════════════════════════════ */
    document.querySelectorAll('.xp-card').forEach(card => {
        const canvas = card.querySelector('.xp-particles');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let color = 'rgba(255,255,255,0.4)';
        if (card.classList.contains('xp-total'))         color = 'rgba(102,126,234,0.6)';
        else if (card.classList.contains('xp-pending-card'))  color = 'rgba(255,167,81,0.6)';
        else if (card.classList.contains('xp-resolved'))      color = 'rgba(67,233,123,0.6)';
        else if (card.classList.contains('xp-rejected-card')) color = 'rgba(255,107,107,0.6)';

        const particles = Array.from({length:18}, () => ({
            x:Math.random()*canvas.width, y:Math.random()*canvas.height,
            r:Math.random()*1.5+0.3,
            vx:(Math.random()-.5)*.4, vy:-Math.random()*.5-.2,
            alpha:Math.random()
        }));
        let rafId = null;
        function draw() {
            ctx.clearRect(0,0,canvas.width,canvas.height);
            particles.forEach(p => {
                p.x+=p.vx; p.y+=p.vy; p.alpha-=0.004;
                if(p.alpha<=0||p.y<0){p.x=Math.random()*canvas.width;p.y=canvas.height+2;p.alpha=Math.random()*.7+.3;p.vy=-Math.random()*.5-.2;p.vx=(Math.random()-.5)*.4;}
                ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                ctx.fillStyle=color.replace('0.6',p.alpha.toFixed(2)); ctx.fill();
            });
            rafId=requestAnimationFrame(draw);
        }
        card.addEventListener('mouseenter',()=>draw());
        card.addEventListener('mouseleave',()=>{if(rafId){cancelAnimationFrame(rafId);rafId=null;}ctx.clearRect(0,0,canvas.width,canvas.height);});
    });

    /* ════════════════════════════════════════════
       STATS AJAX POLLING (30s)
    ════════════════════════════════════════════ */
    const STATS_URL    = '{{ path("admin_coach_applications_stats") }}';
    const refreshBadge = document.getElementById('lastRefreshBadge');

    function updateDonut(pct) {
        const circle = document.getElementById('donutCircle');
        if (circle) circle.setAttribute('stroke-dasharray', Math.round(pct * 150.8 / 100) + ' 150.8');
        animateUpdate(document.getElementById('donutPct'), pct);
    }

    async function refreshStats() {
        if (refreshBadge) { refreshBadge.classList.add('cmd-badge-refreshing'); refreshBadge.textContent = 'REFRESHING…'; }
        try {
            const res  = await fetch(STATS_URL, { headers:{'X-Requested-With':'XMLHttpRequest'} });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();

            animateUpdate(document.getElementById('statTotal'),        data.total);
            animateUpdate(document.getElementById('statPending'),      data.pending);
            animateUpdate(document.getElementById('statApproved'),     data.approved);
            animateUpdate(document.getElementById('statRejected'),     data.rejected);
            animateUpdate(document.getElementById('statPendingMini'),  data.pending);
            animateUpdate(document.getElementById('statRejectedMini'), data.rejected);

            const approvalRate = data.total > 0 ? Math.round((data.approved / data.total) * 100) : 0;
            animateUpdate(document.getElementById('statApprovalRate'), approvalRate);
            updateDonut(approvalRate);

            // Progress bars
            const pPending  = data.total > 0 ? Math.round((data.pending  / data.total) * 100) : 0;
            const pApproved = data.total > 0 ? Math.round((data.approved / data.total) * 100) : 0;
            const pRejected = data.total > 0 ? Math.round((data.rejected / data.total) * 100) : 0;
            const pp = document.getElementById('progressPending');
            const pa = document.getElementById('progressApproved');
            const pr = document.getElementById('progressRejected');
            if (pp) pp.style.width = pPending  + '%';
            if (pa) pa.style.width = pApproved + '%';
            if (pr) pr.style.width = pRejected + '%';

            // Header badge
            const hb = document.getElementById('headerTotalBadge');
            if (hb) hb.textContent = data.total + ' APPLICATIONS';

            if (refreshBadge) {
                refreshBadge.classList.remove('cmd-badge-refreshing');
                refreshBadge.textContent = 'UPDATED ' + new Date().toLocaleTimeString('en-US',{hour12:false});
            }
        } catch(e) {
            console.warn('[CoachStats] Refresh failed:', e);
            if (refreshBadge) { refreshBadge.classList.remove('cmd-badge-refreshing'); refreshBadge.textContent = 'RETRY'; }
        }
    }

    if (refreshBadge) refreshBadge.addEventListener('click', refreshStats);
    setTimeout(() => { refreshStats(); setInterval(refreshStats, 30000); }, 5000);

    /* ════════════════════════════════════════════
       VOICE SEARCH
    ════════════════════════════════════════════ */
    const micBtn     = document.getElementById('voiceMicBtn');
    const statusDiv  = document.getElementById('voiceStatus');
    const statusText = document.getElementById('voiceStatusText');
    const searchInp  = document.getElementById('voiceSearchInput');
    const filterForm = document.getElementById('filterForm');
    if (!micBtn) return;

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const hasNativeSTT      = !!SpeechRecognition;
    const hasMediaRecorder  = !!(navigator.mediaDevices && window.MediaRecorder);
    if (hasNativeSTT || hasMediaRecorder) micBtn.style.display = 'flex';

    let isListening=false, recognition=null, mediaRecorder=null, audioChunks=[], micStream=null;

    function setListening(on) {
        isListening=on;
        if(on){micBtn.classList.add('is-listening');micBtn.innerHTML='<i class="bi bi-stop-fill"></i>';statusDiv.classList.remove('d-none');statusText.textContent='Listening… speak now';}
        else{micBtn.classList.remove('is-listening');micBtn.innerHTML='<i class="bi bi-mic-fill"></i>';statusDiv.classList.add('d-none');}
    }
    function applyAndSubmit(text){const c=text.trim();if(!c)return;searchInp.value=c;setTimeout(()=>filterForm.submit(),600);}

    function startNativeSTT(){
        recognition=new SpeechRecognition();recognition.lang='en-US';recognition.continuous=false;recognition.interimResults=true;
        recognition.onstart=()=>setListening(true);
        recognition.onresult=(e)=>{let i2='',f='';for(let i=e.resultIndex;i<e.results.length;i++){const t=e.results[i][0].transcript;e.results[i].isFinal?(f+=t):(i2+=t);}searchInp.value=f||i2;if(f)recognition.stop();};
        recognition.onerror=(e)=>{setListening(false);if(e.error==='not-allowed')alert('Microphone access denied.');};
        recognition.onend=()=>{const v=searchInp.value.trim();setListening(false);if(v)setTimeout(()=>filterForm.submit(),500);};
        recognition.start();
    }
    const TRANSCRIBE_URL='{{ path("app_speech_transcribe") }}';
    async function startMediaSTT(){
        try{micStream=await navigator.mediaDevices.getUserMedia({audio:true});}catch{alert('Microphone access denied.');return;}
        audioChunks=[];
        const mime=['audio/webm;codecs=opus','audio/webm','audio/ogg',''].find(t=>t===''||MediaRecorder.isTypeSupported(t));
        mediaRecorder=new MediaRecorder(micStream,mime?{mimeType:mime}:{});
        mediaRecorder.ondataavailable=e=>{if(e.data?.size>0)audioChunks.push(e.data);};
        mediaRecorder.onstop=async()=>{
            micStream.getTracks().forEach(t=>t.stop());micStream=null;setListening(false);
            statusDiv.classList.remove('d-none');statusDiv.querySelector('.voice-pulse').style.background='#ffc107';statusText.textContent='Transcribing…';
            const blob=new Blob(audioChunks,{type:mediaRecorder.mimeType||'audio/webm'});audioChunks=[];mediaRecorder=null;
            const fd=new FormData();fd.append('audio',blob,'search.webm');
            try{
                const res=await fetch(TRANSCRIBE_URL,{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'XMLHttpRequest'}});
                statusDiv.classList.add('d-none');
                const ct=res.headers.get('content-type')||'';
                if(!ct.includes('application/json')){alert('Session expired. Please refresh.');return;}
                const data=await res.json();
                if(res.ok&&data.text){applyAndSubmit(data.text);}else{alert('Could not transcribe. Please try again.');}
            }catch(err){statusDiv.classList.add('d-none');console.error(err);alert('Server error.');}
        };
        mediaRecorder.start(250);setListening(true);
    }
    micBtn.addEventListener('click',()=>{
        if(isListening){if(recognition)recognition.stop();if(mediaRecorder&&mediaRecorder.state!=='inactive')mediaRecorder.stop();setListening(false);return;}
        hasNativeSTT?startNativeSTT():startMediaSTT();
    });
});
</script>
{% endblock %}