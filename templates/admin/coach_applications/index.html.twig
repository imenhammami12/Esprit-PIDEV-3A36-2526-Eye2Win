{% extends 'admin_layout.html.twig' %}

{% block title %}Coach Applications{% endblock %}
{% block page_title %}Coach Applications Management{% endblock %}

{% block body %}


{# ══════════════════════════════════════════════════════════════
   MAIN STAT CARDS — PRIMARY ROW
══════════════════════════════════════════════════════════════ #}
<div class="xp-grid fade-in" style="animation-delay:0.05s;">

    {# TOTAL #}
    <div class="xp-card xp-total">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(102,126,234,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(102,126,234,0.12)" stroke="rgba(102,126,234,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-clipboard-check xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">◈ ALL REQUESTS</div>
                <div class="xp-num" id="statTotal">{{ stats.total }}</div>
                <div class="xp-title">Total</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressTotal" style="width:100%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# PENDING #}
    <div class="xp-card xp-pending-card">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(255,167,81,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(255,167,81,0.12)" stroke="rgba(255,167,81,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-clock-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">⏳ AWAITING REVIEW</div>
                <div class="xp-num" id="statPending">{{ stats.pending }}</div>
                <div class="xp-title">Pending</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressPending"
                         style="width:{{ stats.total > 0 ? ((stats.pending / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# APPROVED #}
    <div class="xp-card xp-resolved">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(67,233,123,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(67,233,123,0.12)" stroke="rgba(67,233,123,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-check-circle-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow xp-eyebrow-success">✓ VALIDATED</div>
                <div class="xp-num" id="statApproved">{{ stats.approved }}</div>
                <div class="xp-title">Approved</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressApproved"
                         style="width:{{ stats.total > 0 ? ((stats.approved / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

    {# REJECTED #}
    <div class="xp-card xp-rejected-card">
        <canvas class="xp-particles" width="300" height="160"></canvas>
        <div class="xp-noise"></div>
        <div class="xp-top-bar"></div>
        <div class="xp-side-accent"></div>
        <div class="xp-body">
            <div class="xp-icon-zone">
                <svg class="xp-hexsvg" viewBox="0 0 60 60">
                    <polygon points="30,2 56,16 56,44 30,58 4,44 4,16" fill="none" stroke="rgba(255,107,107,0.4)" stroke-width="1"/>
                    <polygon points="30,8 50,20 50,40 30,52 10,40 10,20" fill="rgba(255,107,107,0.12)" stroke="rgba(255,107,107,0.6)" stroke-width="1"/>
                </svg>
                <i class="bi bi-x-circle-fill xp-icon-glyph"></i>
            </div>
            <div class="xp-content">
                <div class="xp-eyebrow">✕ DECLINED</div>
                <div class="xp-num" id="statRejected">{{ stats.rejected }}</div>
                <div class="xp-title">Rejected</div>
                <div class="xp-progress-track">
                    <div class="xp-progress-fill" id="progressRejected"
                         style="width:{{ stats.total > 0 ? ((stats.rejected / stats.total) * 100)|round : 0 }}%"></div>
                    <div class="xp-progress-glow"></div>
                </div>
            </div>
        </div>
        <div class="xp-corner-tl"></div>
        <div class="xp-corner-br"></div>
        <div class="xp-scan-line"></div>
    </div>

</div>

{# ══════════════════════════════════════════════════════════════
   SECONDARY STATS — MINI ROW
══════════════════════════════════════════════════════════════ #}
<div class="mini-stat-row fade-in" style="animation-delay:0.12s;">

    {# Approval rate #}
    <div class="mini-card mini-teal">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="mini-data">
                <div class="mini-val mini-val-text" id="statApprovalRate">
                    {{ stats.total > 0 ? ((stats.approved / stats.total) * 100)|round : 0 }}%
                </div>
                <div class="mini-lbl">Approval Rate</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,25 10,20 20,15 30,10 40,8 50,5 60,3" fill="none" stroke="rgba(56,249,215,0.6)" stroke-width="1.5"/>
                    <polyline points="0,25 10,20 20,15 30,10 40,8 50,5 60,3 60,30 0,30" fill="rgba(56,249,215,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    {# Pending mini #}
    <div class="mini-card mini-orange">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="mini-data">
                <div class="mini-val" id="statPendingMini">{{ stats.pending }}</div>
                <div class="mini-lbl">Pending</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,15 10,18 20,12 30,16 40,10 50,14 60,8" fill="none" stroke="rgba(255,167,81,0.6)" stroke-width="1.5"/>
                    <polyline points="0,15 10,18 20,12 30,16 40,10 50,14 60,8 60,30 0,30" fill="rgba(255,167,81,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    {# Rejected mini #}
    <div class="mini-card mini-red">
        <div class="mini-card-inner">
            <div class="mini-icon"><i class="bi bi-slash-circle"></i></div>
            <div class="mini-data">
                <div class="mini-val" id="statRejectedMini">{{ stats.rejected }}</div>
                <div class="mini-lbl">Rejected</div>
            </div>
            <div class="mini-graph">
                <svg viewBox="0 0 60 30" preserveAspectRatio="none">
                    <polyline points="0,10 10,14 20,12 30,18 40,15 50,20 60,17" fill="none" stroke="rgba(255,107,107,0.6)" stroke-width="1.5"/>
                    <polyline points="0,10 10,14 20,12 30,18 40,15 50,20 60,17 60,30 0,30" fill="rgba(255,107,107,0.08)"/>
                </svg>
            </div>
        </div>
    </div>

    {# Approval rate donut #}
    <div class="mini-card mini-donut-card">
        <div class="mini-card-inner">
            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 60 60">
                    <circle cx="30" cy="30" r="24" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6"/>
                    <circle id="donutCircle" cx="30" cy="30" r="24" fill="none"
                            stroke="url(#donutGradCoach)" stroke-width="6"
                            stroke-dasharray="{{ stats.total > 0 ? (((stats.approved / stats.total) * 150.8))|round : 0 }} 150.8"
                            stroke-dashoffset="37.7" stroke-linecap="round"/>
                    <defs>
                        <linearGradient id="donutGradCoach" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#43e97b"/>
                            <stop offset="100%" stop-color="#38f9d7"/>
                        </linearGradient>
                    </defs>
                </svg>
                <div class="donut-center">
                    <span id="donutPct">{{ stats.total > 0 ? ((stats.approved / stats.total) * 100)|round : 0 }}%</span>
                </div>
            </div>
            <div class="mini-data">
                <div class="mini-lbl" style="font-size:10px; color:rgba(255,255,255,0.5);">Approval</div>
                <div class="mini-lbl" style="font-size:10px; color:rgba(255,255,255,0.5);">Rate</div>
            </div>
        </div>
    </div>

</div>

{# ══════════════════════════════════════════════════════════════
   FILTERS & SEARCH
══════════════════════════════════════════════════════════════ #}
<div class="table-card mb-4 fade-in" style="animation-delay: 0.18s;">
    <div class="table-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filters & Search</h5>
        <button class="btn btn-sm btn-outline-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="true">
            <i class="bi bi-chevron-down"></i>
        </button>
    </div>

    <div class="collapse show" id="filterCollapse">
        <form method="get" class="p-3" id="filterForm">
            <div class="row g-3">

                {# Search #}
                <div class="col-md-6">
                    <label class="form-label"><i class="bi bi-search me-1"></i>Search</label>
                    <div class="search-bar voice-search-bar">
                        <i class="search-icon bi bi-search"></i>
                        <input type="text" name="search" id="voiceSearchInput" class="form-control"
                               placeholder="Name, username, email, certifications..."
                               value="{{ search }}" autocomplete="off">
                        <button type="button" id="voiceMicBtn" class="voice-mic-btn"
                                title="Search by voice" style="display:none;">
                            <i class="bi bi-mic-fill"></i>
                        </button>
                    </div>
                    <div id="voiceStatus" class="voice-status d-none">
                        <span class="voice-pulse"></span>
                        <span id="voiceStatusText">Listening… speak now</span>
                    </div>
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>Search in name, username, email, certifications, and experience
                    </small>
                </div>

                {# Status #}
                <div class="col-md-2">
                    <label class="form-label"><i class="bi bi-filter me-1"></i>Status</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        {% for status in applicationStatuses %}
                            <option value="{{ status.value }}" {{ statusFilter == status.value ? 'selected' : '' }}>
                                {{ status.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                {# Sort #}
                <div class="col-md-4">
                    <label class="form-label"><i class="bi bi-sort-down me-1"></i>Sort By</label>
                    <div class="input-group">
                        <select name="sort_by" class="form-select" onchange="this.form.submit()">
                            <option value="submittedAt" {{ sortBy == 'submittedAt' ? 'selected' : '' }}>Submitted Date</option>
                            <option value="reviewedAt"  {{ sortBy == 'reviewedAt'  ? 'selected' : '' }}>Reviewed Date</option>
                            <option value="status"      {{ sortBy == 'status'      ? 'selected' : '' }}>Status</option>
                        </select>
                        <select name="sort_order" class="form-select" style="max-width:100px;" onchange="this.form.submit()">
                            <option value="DESC" {{ sortOrder == 'DESC' ? 'selected' : '' }}>↓ DESC</option>
                            <option value="ASC"  {{ sortOrder == 'ASC'  ? 'selected' : '' }}>↑ ASC</option>
                        </select>
                    </div>
                </div>

                {# Date Range #}
                <div class="col-md-6">
                    <label class="form-label"><i class="bi bi-calendar-range me-1"></i>Submission Date Range</label>
                    <div class="input-group">
                        <span class="input-group-text">From</span>
                        <input type="date" name="date_from" class="form-control" value="{{ dateFrom }}" onchange="this.form.submit()">
                        <span class="input-group-text">To</span>
                        <input type="date" name="date_to"   class="form-control" value="{{ dateTo }}"   onchange="this.form.submit()">
                    </div>
                </div>

                {# Buttons #}
                <div class="col-md-6 d-flex align-items-end gap-2">
                    {% if statusFilter or search or dateFrom or dateTo %}
                        <a href="{{ path('admin_coach_applications_index') }}" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-x-lg me-1"></i>Clear All
                        </a>
                    {% endif %}
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-funnel me-2"></i>Apply Filters
                    </button>
                    <a href="{{ path('admin_coaches_list') }}" class="btn flex-fill"
                       style="background: linear-gradient(135deg, #4a2d8f, #6a3fbf); color:#fff; border:none; box-shadow:0 4px 15px rgba(74,45,143,0.35);">
                        <i class="bi bi-award me-2"></i>View Coaches
                    </a>
                </div>

            </div>
        </form>
    </div>
</div>

{# Results Summary #}
<div class="mb-3 fade-in" style="animation-delay: 0.2s;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h6 class="text-muted mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Found <strong>{{ pagination.getTotalItemCount }}</strong>
            application{{ pagination.getTotalItemCount != 1 ? 's' : '' }}
            {% if statusFilter or search or dateFrom or dateTo %}
                <span class="badge bg-primary ms-1">Filtered</span>
            {% endif %}
        </h6>
    </div>
</div>

{# Applications Table #}
<div class="table-card fade-in" style="animation-delay: 0.22s;">
    <div class="table-header">
        <h5><i class="bi bi-clipboard-check me-2"></i>Applications List ({{ pagination.getTotalItemCount }})</h5>
    </div>

    <div class="table-responsive">
        <table class="custom-table table">
            <thead>
                <tr>
                    <th style="width:70px; text-align:center;">Photo</th>
                    <th style="width:200px;">Applicant</th>
                    <th style="width:220px;">Email</th>
                    <th style="width:130px;">Submitted</th>
                    <th style="width:110px;">Status</th>
                    <th style="width:130px;">Reviewed</th>
                    <th style="width:150px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for application in pagination %}
                    <tr class="fade-in" style="animation-delay: {{ loop.index * 0.05 }}s;">
                        <td style="width:70px; text-align:center;">
                            {% if application.user.profilePicture %}
                                <img src="{{ asset('uploads/profiles/' ~ application.user.profilePicture) }}"
                                     alt="{{ application.user.username }}"
                                     class="user-avatar-table" loading="lazy">
                            {% else %}
                                <div class="user-avatar-placeholder mx-auto">
                                    {{ application.user.username|slice(0, 2)|upper }}
                                </div>
                            {% endif %}
                        </td>
                        <td style="width:200px;">
                            <a href="{{ path('admin_users_show', {id: application.user.id}) }}"
                               class="text-decoration-none" style="color:#ffffff;">
                                <strong>{{ application.user.fullName ?? application.user.username }}</strong>
                            </a><br>
                            <small class="text-muted">
                                <i class="bi bi-at"></i>{{ application.user.username }}
                            </small>
                        </td>
                        <td style="width:220px;">
                            <a href="mailto:{{ application.user.email }}" class="text-decoration-none" style="color:#4facfe;">
                                <i class="bi bi-envelope me-1"></i>
                                <span style="display:inline-block; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;">
                                    {{ application.user.email }}
                                </span>
                            </a>
                        </td>
                        <td style="width:130px;">
                            <small class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>{{ application.submittedAt|date('M d, Y') }}<br>
                                <i class="bi bi-clock me-1"></i>{{ application.submittedAt|date('h:i A') }}
                            </small>
                        </td>
                        <td style="width:110px;">
                            <span class="badge bg-{{ application.status.badgeClass }}">
                                {{ application.status.label }}
                            </span>
                        </td>
                        <td style="width:130px;">
                            {% if application.reviewedAt %}
                                <small class="text-muted">
                                    <i class="bi bi-check2 me-1"></i>{{ application.reviewedAt|date('M d, Y') }}<br>
                                    <i class="bi bi-clock me-1"></i>{{ application.reviewedAt|date('h:i A') }}
                                </small>
                            {% else %}
                                <small class="text-muted">
                                    <i class="bi bi-dash-circle me-1"></i>Not reviewed
                                </small>
                            {% endif %}
                        </td>
                        <td style="width:150px;">
                            <div class="btn-group" role="group">
                                <a href="{{ path('admin_coach_applications_show', {id: application.id}) }}"
                                   class="btn btn-sm btn-info" title="View Details" data-bs-toggle="tooltip">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if application.status.value != 'APPROVED' %}
                                    <button type="button" class="btn btn-sm btn-success"
                                            onclick="window.location.href='{{ path('admin_coach_applications_show', {id: application.id}) }}#approve-section'"
                                            title="Approve" data-bs-toggle="tooltip">
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                {% endif %}
                                {% if application.status.value != 'REJECTED' %}
                                    <button type="button" class="btn btn-sm btn-danger"
                                            onclick="window.location.href='{{ path('admin_coach_applications_show', {id: application.id}) }}#reject-section'"
                                            title="Reject" data-bs-toggle="tooltip">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <div class="empty-state">
                                <i class="bi bi-inbox" style="font-size:64px; opacity:0.2;"></i>
                                <h4 class="mt-3 mb-2">No Applications Found</h4>
                                {% if statusFilter or search or dateFrom or dateTo %}
                                    <p class="text-muted">Try adjusting your filters</p>
                                    <a href="{{ path('admin_coach_applications_index') }}" class="btn btn-sm btn-outline-primary mt-2">
                                        <i class="bi bi-x-lg me-1"></i>Clear Filters
                                    </a>
                                {% else %}
                                    <p class="text-muted">Coach applications will appear here</p>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Pagination #}
{% if pagination.getTotalItemCount > 20 %}
<div class="d-flex justify-content-between align-items-center mt-4 fade-in" style="animation-delay: 0.3s;">
    <div class="text-muted">
        Showing {{ ((pagination.currentPageNumber - 1) * 20) + 1 }}
        to {{ min(pagination.currentPageNumber * 20, pagination.getTotalItemCount) }}
        of {{ pagination.getTotalItemCount }} entries
    </div>
    <div class="pagination-wrapper">
        {{ knp_pagination_render(pagination, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig', {}, {
            'status': statusFilter, 'search': search,
            'date_from': dateFrom, 'date_to': dateTo,
            'sort_by': sortBy, 'sort_order': sortOrder
        }) }}
    </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════
   STYLES
══════════════════════════════════════════════════════════════ #}
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&display=swap');

/* ── Command center header ── */
.cmd-header {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:20px; padding:8px 16px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
    border-radius:8px;
    font-family:'Share Tech Mono',monospace; font-size:11px;
}
.cmd-status-dot {
    width:7px; height:7px; border-radius:50%;
    background:#43e97b; box-shadow:0 0 8px #43e97b;
    animation:cmdPulse 2s ease-in-out infinite; display:inline-block;
}
@keyframes cmdPulse { 0%,100%{opacity:1;box-shadow:0 0 8px #43e97b;}50%{opacity:.6;box-shadow:0 0 16px #43e97b;} }
.cmd-status-text { color:#43e97b; margin-left:8px; }
.cmd-divider { color:rgba(255,255,255,0.2); margin:0 10px; }
.cmd-timestamp { color:rgba(255,255,255,0.5); }
.cmd-header-right { display:flex; gap:8px; align-items:center; }
.cmd-badge {
    padding:3px 10px; border-radius:4px; font-size:10px;
    font-weight:700; letter-spacing:1px;
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.1);
    color:rgba(255,255,255,0.6);
}
.cmd-badge-alert {
    background:rgba(102,126,234,0.15); border-color:rgba(102,126,234,0.4); color:#a0aef8;
    animation:cmdPulse 2s ease-in-out infinite;
}
.cmd-badge-refresh { cursor:pointer; transition:background .2s,color .2s,border-color .2s; }
.cmd-badge-refresh:hover { background:rgba(67,233,123,0.15); border-color:rgba(67,233,123,0.4); color:#43e97b; }
.cmd-badge-refreshing {
    background:rgba(255,193,7,0.15)!important; border-color:rgba(255,193,7,0.4)!important;
