{% extends 'admin_layout.html.twig' %}

{% block title %}Create Tournoi{% endblock %}
{% block page_title %}Create New Tournoi{% endblock %}

{% block body %}
<div class="mb-3 fade-in">
    <a href="{{ path('admin_tournoi_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center fade-in" style="animation-delay: 0.1s;">
    <div class="col-lg-8">
        <div class="table-card">
            <div class="card-header-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1.5rem; border-radius: 16px 16px 0 0;">
                <h5 class="mb-0 text-white"><i class="bi bi-trophy me-2"></i>Tournoi Information</h5>
            </div>
            
            {{ form_start(form, {'attr': {'class': 'p-4', 'id': 'createTournoiForm', 'novalidate': 'novalidate'}}) }}
                
                <div class="row g-4">
                    {# Nom #}
                    <div class="col-md-12 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-tag me-1"></i>
                            Nom du Tournoi
                            <span class="required-indicator" style="color: #fa709a;">*</span>
                        </label>
                        {{ form_widget(form.nom) }}
                        <div class="custom-error-message">{{ form_errors(form.nom) }}</div>
                        <small class="form-help-text text-muted">
                            <i class="bi bi-info-circle me-1"></i>Enter the tournament name
                        </small>
                    </div>

                    {# Dates #}
                    <div class="col-md-6 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-calendar-event me-1"></i>
                            Date de Début
                            <span class="required-indicator" style="color: #fa709a;">*</span>
                        </label>
                        {{ form_widget(form.dateDebut) }}
                        <div class="custom-error-message">{{ form_errors(form.dateDebut) }}</div>
                    </div>

                    <div class="col-md-6 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-calendar-check me-1"></i>
                            Date de Fin
                            <span class="required-indicator" style="color: #fa709a;">*</span>
                        </label>
                        {{ form_widget(form.dateFin) }}
                        <div class="custom-error-message">{{ form_errors(form.dateFin) }}</div>
                    </div>
                    
                    {# Type & Prix #}
                    <div class="col-md-6 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-list-task me-1"></i>
                            Type
                        </label>
                        {{ form_widget(form.typeTournoi) }}
                        <div class="custom-error-message">{{ form_errors(form.typeTournoi) }}</div>
                    </div>

                    <div class="col-md-6 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-currency-dollar me-1"></i>
                            Prix de participation (TND)
                        </label>
                        {{ form_widget(form.prix) }}
                        <div class="custom-error-message">{{ form_errors(form.prix) }}</div>
                    </div>

                    {# Description #}
                    <div class="col-md-12 form-group-enhanced">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-bold mb-0">
                                <i class="bi bi-file-text me-1"></i>
                                Description
                            </label>
                            <button type="button" id="generateDescBtn" class="btn btn-sm" style="background: linear-gradient(135deg, #4f46e5, #7c3aed); color:white; border:none;">
                                <span id="generateBtnText"><i class="bi bi-stars me-1"></i> Générer avec IA</span>
                                <span id="generateBtnSpinner" class="d-none">
                                    <span class="spinner-border spinner-border-sm me-1"></span> Génération...
                                </span>
                            </button>
                        </div>
                        {{ form_widget(form.description, {'attr': {'id': 'descriptionField', 'rows': 5}}) }}
                        <div id="aiError" class="text-danger small mt-1" style="display:none;"></div>
                        <div class="custom-error-message">{{ form_errors(form.description) }}</div>
                    </div>

                    {# Image #}
                    <div class="col-md-12 form-group-enhanced">
                        <label class="form-label fw-bold">
                            <i class="bi bi-image me-1"></i>
                            Logo (Image)
                        </label>
                        {{ form_widget(form.image) }}
                        <div class="custom-error-message">{{ form_errors(form.image) }}</div>
                        <small class="form-help-text text-muted">
                            <i class="bi bi-info-circle me-1"></i>Upload a logo for the tournament (JPEG, PNG, WEBP)
                        </small>
                    </div>
                </div>
                
                {# Action Buttons #}
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success" id="submitBtn">
                        <i class="bi bi-save me-2"></i>Create Tournoi
                    </button>
                    <a href="{{ path('admin_tournoi_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Form validation with enhanced feedback
    const form = document.getElementById('createTournoiForm');
    const submitBtn = document.getElementById('submitBtn');
    
    if (form) {
        form.addEventListener('submit', function(e) {
            // Allow form submission to handle server-side validation
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creating...';
            submitBtn.style.opacity = '0.8';
        });
        
                // Real-time validation feedback
        form.querySelectorAll('input, select').forEach(input => {
            input.addEventListener('blur', function() {
                if (this.checkValidity()) {
                    this.classList.add('is-valid');
                    this.classList.remove('is-invalid');
                } else {
                    this.classList.add('is-invalid');
                    this.classList.remove('is-valid');
                }
            });
            
            input.addEventListener('input', function() {
                if (this.classList.contains('is-invalid') && this.checkValidity()) {
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                }
            });
        });
    }
});

// AI Description generator
document.getElementById('generateDescBtn').addEventListener('click', function() {
    const nomField = document.querySelector('[name*="[nom]"]');
    const typeField = document.querySelector('[name*="[typeTournoi]"]');
    const descField = document.querySelector('[name*="[description]"]');
    const btnText = document.getElementById('generateBtnText');
    const btnSpinner = document.getElementById('generateBtnSpinner');
    const aiError = document.getElementById('aiError');

    const name = nomField ? nomField.value.trim() : '';
    const type = typeField ? typeField.options[typeField.selectedIndex]?.text ?? '' : '';

    if (!name) {
        aiError.textContent = 'Veuillez d\'abord saisir le nom du tournoi.';
        aiError.style.display = 'block';
        return;
    }
    aiError.style.display = 'none';

    btnText.classList.add('d-none');
    btnSpinner.classList.remove('d-none');
    this.disabled = true;

    fetch('{{ path('admin_tournoi_generate_description') }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, type: type })
    })
    .then(async res => {
        const data = await res.json();
        if (!res.ok) {
            throw new Error(data.error || `Erreur serveur (${res.status})`);
        }
        return data;
    })
    .then(data => {
        descField.value = data.description;
    })
    .catch((err) => {
        aiError.textContent = err.message || 'Erreur de connexion à l\'IA.';
        aiError.style.display = 'block';
    })
    .finally(() => {
        btnText.classList.remove('d-none');
        btnSpinner.classList.add('d-none');
        this.disabled = false;
    });
});

// Shake animation style
const style = document.createElement('style');
style.textContent = `
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        75% { transform: translateX(10px); }
    }
    .form-control.is-valid { border-color: #43e97b; box-shadow: 0 0 0 0.15rem rgba(67, 233, 123, 0.25); }
    .form-control.is-invalid { border-color: #dc3545; box-shadow: 0 0 0 0.15rem rgba(220, 53, 69, 0.25); }
    .custom-error-message, .custom-error-message ul, .custom-error-message li, .custom-error-message span {
        color: #ff0000 !important; font-weight: bold; list-style-type: none; padding-left: 0; margin-top: 5px; display: block;
    }
`;
document.head.appendChild(style);
</script>
{% endblock %}
