{% extends 'base.html.twig' %}

{% block title %}My Teams{% endblock %}

{% block body %}

{# ── HERO ── #}
<div class="teams-hero">
    <canvas id="heroCanvas"></canvas>
    <div class="hero-grid-overlay"></div>
    <div class="hero-scanline"></div>
    <div class="hero-vignette"></div>
    <div class="container position-relative">
        <div class="hero-inner">
            <span class="hero-tag">
                <span class="hero-tag-dot"></span>
                <i class="fas fa-users"></i> Team Command Center
            </span>
            <h1 class="hero-title">
                <span class="title-row1">Team</span>
                <span class="title-row2">Management</span>
            </h1>
            <p class="hero-sub">Forge alliances, lead your squad, dominate the leaderboard.</p>
            <a href="{{ path('app_teams_create') }}" class="hero-cta">
                <span class="hero-cta-bg"></span>
                <i class="fas fa-plus"></i>
                <span>Create Team</span>
            </a>
        </div>
    </div>
    {# Stat pills #}
    <div class="hero-stats">
        <div class="container">
            <div class="hstat-row">
                <div class="hstat">
                    <span class="hstat-val">{{ ownedTeams|length }}</span>
                    <span class="hstat-lbl">Owned</span>
                </div>
                <div class="hstat-divider"></div>
                <div class="hstat">
                    <span class="hstat-val">{{ memberTeams|length }}</span>
                    <span class="hstat-lbl">Member Of</span>
                </div>
                <div class="hstat-divider"></div>
                <div class="hstat">
                    <span class="hstat-val">{{ pendingInvitations|length }}</span>
                    <span class="hstat-lbl">Invitations</span>
                </div>
                <div class="hstat-divider"></div>
                <div class="hstat">
                    <span class="hstat-val">{{ pendingRequests|length }}</span>
                    <span class="hstat-lbl">Requests</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="teams-section">
    <div class="container">

        {# ══ PENDING INVITATIONS ══ #}
        {% if pendingInvitations|length > 0 %}
        <div class="t-block" style="--bi:1">
            <div class="t-block-header">
                <div class="t-block-icon inv">
                    <i class="fas fa-envelope-open-text"></i>
                    <div class="tbi-ping"></div>
                </div>
                <div>
                    <div class="t-block-title">Pending Invitations</div>
                    <div class="t-block-sub">You have {{ pendingInvitations|length }} team invite{{ pendingInvitations|length > 1 ? 's' : '' }} waiting</div>
                </div>
                <span class="t-count t-count-inv">{{ pendingInvitations|length }}</span>
            </div>
            <div class="tcard-grid mt-4">
                {% for invitation in pendingInvitations %}
                <div class="tcard tcard-inv">
                    <div class="tcard-glow"></div>
                    <div class="tcard-corner tl"></div><div class="tcard-corner tr"></div>
                    <div class="tcard-corner bl"></div><div class="tcard-corner br"></div>
                    <div class="tcard-top">
                        <div class="tcard-avatar">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="tcard-info">
                            <div class="tcard-name">{{ invitation.team.name }}</div>
                            <div class="tcard-meta">
                                <i class="fas fa-user"></i> {{ invitation.team.owner.username }}
                            </div>
                            <div class="tcard-meta">
                                <i class="fas fa-clock"></i> {{ invitation.invitedAt|date('M d, Y') }}
                            </div>
                        </div>
                        <span class="tcard-badge inv-badge">INVITED</span>
                    </div>
                    <div class="tcard-actions">
                        <form method="post" action="{{ path('app_teams_invitation_accept', {id: invitation.id}) }}" class="flex-1">
                            <button type="submit" class="tact-btn tact-accept">
                                <i class="fas fa-check"></i> Accept
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_teams_invitation_decline', {id: invitation.id}) }}" class="flex-1">
                            <button type="submit" class="tact-btn tact-decline">
                                <i class="fas fa-times"></i> Decline
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ══ PENDING REQUESTS ══ #}
        {% if pendingRequests|length > 0 %}
        <div class="t-block" style="--bi:2">
            <div class="t-block-header">
                <div class="t-block-icon req">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <div>
                    <div class="t-block-title">My Pending Requests</div>
                    <div class="t-block-sub">{{ pendingRequests|length }} request{{ pendingRequests|length > 1 ? 's' : '' }} awaiting response</div>
                </div>
                <span class="t-count t-count-req">{{ pendingRequests|length }}</span>
            </div>
            <div class="tcard-grid mt-4">
                {% for request in pendingRequests %}
                <div class="tcard tcard-req">
                    <div class="tcard-glow"></div>
                    <div class="tcard-corner tl"></div><div class="tcard-corner tr"></div>
                    <div class="tcard-corner bl"></div><div class="tcard-corner br"></div>
                    <div class="tcard-top">
                        <div class="tcard-avatar">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="tcard-info">
                            <div class="tcard-name">{{ request.team.name }}</div>
                            <div class="tcard-meta">
                                <i class="fas fa-user"></i> {{ request.team.owner.username }}
                            </div>
                            <div class="tcard-meta">
                                <i class="fas fa-clock"></i> {{ request.invitedAt|date('M d, Y') }}
                            </div>
                        </div>
                        <span class="tcard-badge req-badge">PENDING</span>
                    </div>
                    <div class="tcard-actions">
                        <form method="post" action="{{ path('app_teams_request_cancel', {id: request.id}) }}" class="flex-1"
                              onsubmit="return confirm('Cancel this request?')">
                            <button type="submit" class="tact-btn tact-cancel">
                                <i class="fas fa-times"></i> Cancel Request
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ══ OWNED TEAMS ══ #}
        {% if ownedTeams|length > 0 %}
        <div class="t-block" style="--bi:3">
            <div class="t-block-header">
                <div class="t-block-icon own">
                    <i class="fas fa-crown"></i>
                </div>
                <div>
                    <div class="t-block-title">Teams I Own</div>
                    <div class="t-block-sub">You are the commander of {{ ownedTeams|length }} team{{ ownedTeams|length > 1 ? 's' : '' }}</div>
                </div>
                <span class="t-count t-count-own">{{ ownedTeams|length }}</span>
            </div>
            <div class="tcard-grid mt-4">
                {% for team in ownedTeams %}
                <div class="tcard tcard-own">
                    <div class="tcard-glow"></div>
                    <div class="tcard-corner tl"></div><div class="tcard-corner tr"></div>
                    <div class="tcard-corner bl"></div><div class="tcard-corner br"></div>
                    {% include 'team/_team_card.html.twig' with {'team': team, 'isOwner': true} %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ══ MEMBER TEAMS ══ #}
        {% if memberTeams|length > 0 %}
        <div class="t-block" style="--bi:4">
            <div class="t-block-header">
                <div class="t-block-icon mbr">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <div>
                    <div class="t-block-title">Teams I'm In</div>
                    <div class="t-block-sub">Active member in {{ memberTeams|length }} team{{ memberTeams|length > 1 ? 's' : '' }}</div>
                </div>
                <span class="t-count t-count-mbr">{{ memberTeams|length }}</span>
            </div>
            <div class="tcard-grid mt-4">
                {% for team in memberTeams %}
                <div class="tcard tcard-mbr">
                    <div class="tcard-glow"></div>
                    <div class="tcard-corner tl"></div><div class="tcard-corner tr"></div>
                    <div class="tcard-corner bl"></div><div class="tcard-corner br"></div>
                    {% include 'team/_team_card.html.twig' with {'team': team, 'isOwner': false} %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ══ ALL TEAMS ══ #}
        <div class="t-block" style="--bi:5">
            <div class="t-block-header">
                <div class="t-block-icon all">
                    <i class="fas fa-globe"></i>
                </div>
                <div>
                    <div class="t-block-title">Discover Teams</div>
                    <div class="t-block-sub">Browse all active squads and request to join</div>
                </div>
            </div>
            <div class="tcard-grid mt-4">
                {% set anyFound = false %}
                {% for team in allTeams %}
                    {% set userIsMember = false %}
                    {% for membership in team.teamMemberships %}
                        {% if membership.user == app.user and membership.status.value in ['ACTIVE', 'INVITED'] %}
                            {% set userIsMember = true %}
                        {% endif %}
                    {% endfor %}
                    {% if not userIsMember %}
                        {% set anyFound = true %}
                        <div class="tcard tcard-all">
                            <div class="tcard-glow"></div>
                            <div class="tcard-corner tl"></div><div class="tcard-corner tr"></div>
                            <div class="tcard-corner bl"></div><div class="tcard-corner br"></div>
                            {% include 'team/_team_card.html.twig' with {'team': team, 'isOwner': false} %}
                        </div>
                    {% endif %}
                {% endfor %}
                {% if not anyFound %}
                <div class="t-empty">
                    <i class="fas fa-satellite-dish"></i>
                    <span>No other teams found</span>
                </div>
                {% endif %}
            </div>
        </div>

        {# ══ EMPTY STATE ══ #}
        {% if ownedTeams|length == 0 and memberTeams|length == 0 %}
        <div class="t-empty-hero">
            <div class="t-empty-hero-glow"></div>
            <div class="t-empty-hero-icon">
                <i class="fas fa-users-slash"></i>
            </div>
            <h3>You're Not Part of Any Squad</h3>
            <p>Create your first team or wait for an invitation from another commander.</p>
            <a href="{{ path('app_teams_create') }}" class="btn-fire">
                <span class="btn-fire-bg"></span>
                <i class="fas fa-plus"></i>
                <span>Create My First Team</span>
            </a>
        </div>
        {% endif %}

    </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

/* ═══════════════════════════════════════════
   EYE2WIN — TEAM MANAGEMENT [FULL RED]
═══════════════════════════════════════════ */
:root {
    --red:       #e8372a;
    --red-hot:   #ff4d3d;
    --red-deep:  #b02b20;
    --red-glow:  rgba(232,55,42,0.4);
    --red-dim:   rgba(232,55,42,0.12);
    --red-mid:   rgba(232,55,42,0.22);
    --orange:    #ff6b2b;
    --pink:      #ff2060;
    --cyan:      #00e5ff;
    --cyan-dim:  rgba(0,229,255,0.1);
    --green:     #00e676;
    --green-dim: rgba(0,230,118,0.1);
    --dark:      #080810;
    --border:    rgba(255,255,255,0.07);
    --border-r:  rgba(232,55,42,0.3);
    --text:      rgba(255,255,255,0.93);
    --muted:     rgba(255,255,255,0.38);
    --r:         10px;
    --font-hud:  'Orbitron', sans-serif;
    --font-body: 'Rajdhani', sans-serif;
    --font-mono: 'Share Tech Mono', monospace;
}

* { box-sizing: border-box; }
body { background: var(--dark); font-family: var(--font-body); }

/* ══ HERO ══ */
.teams-hero {
    position: relative;
    background: linear-gradient(165deg, #1a0308 0%, #0c0b18 50%, #080810 100%);
    padding: 4rem 0 0;
    overflow: hidden;
}
.teams-hero::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
    background-size: 300% 100%;
    animation: border-shimmer 4s linear infinite;
}
@keyframes border-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

#heroCanvas {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    width: 100%; height: 100%;
}
.hero-grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(232,55,42,0.055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,55,42,0.055) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: grid-pulse 6s ease-in-out infinite;
}
@keyframes grid-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

.hero-scanline {
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.055) 2px, rgba(0,0,0,0.055) 4px);
    animation: scanline-move 8s linear infinite;
}
@keyframes scanline-move { from{background-position:0 0} to{background-position:0 100px} }

.hero-vignette {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.7) 100%);
}

.hero-inner { position: relative; z-index: 3; padding-bottom: 2rem; }

.hero-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(232,55,42,0.09); border: 1px solid rgba(232,55,42,0.28);
    color: var(--red-hot); font-family: var(--font-hud);
    font-size: .62rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
    padding: .32rem .9rem; border-radius: 3px; margin-bottom: 1.4rem;
    animation: badge-in .5s .1s both;
}
@keyframes badge-in { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:none} }

.hero-tag-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #3dff8a; box-shadow: 0 0 8px #3dff8a;
    animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.hero-title {
    font-family: var(--font-hud); font-weight: 900;
    font-size: clamp(2.6rem, 5.5vw, 4.5rem);
    line-height: .95; letter-spacing: .05em; margin-bottom: 1rem;
    animation: title-in .6s .2s both cubic-bezier(.22,1,.36,1);
}
@keyframes title-in { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }

.title-row1 { display: block; color: var(--text); }
.title-row2 {
    display: block;
    background: linear-gradient(90deg, var(--red) 0%, var(--orange) 50%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    background-size: 200% 100%;
    animation: gradient-pan 5s ease-in-out infinite alternate, title-in .6s .2s both cubic-bezier(.22,1,.36,1);
    filter: drop-shadow(0 0 30px rgba(232,55,42,0.4));
}
@keyframes gradient-pan { from{background-position:0%} to{background-position:100%} }

.hero-sub {
    color: var(--muted); font-size: 1rem; max-width: 480px; line-height: 1.65; margin-bottom: 1.5rem;
    animation: sub-in .5s .4s both;
}
@keyframes sub-in { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }

.hero-cta {
    position: relative; overflow: hidden; display: inline-flex; align-items: center; gap: .6rem;
    padding: .72rem 2rem;
    background: linear-gradient(135deg, var(--red-deep), var(--red), var(--red-hot));
    border: none; border-radius: 9px; color: #fff;
    font-family: var(--font-hud); font-size: .8rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; text-decoration: none; cursor: pointer;
    box-shadow: 0 4px 24px rgba(232,55,42,0.5);
    transition: transform .18s, box-shadow .18s;
    animation: sub-in .5s .5s both;
}
.hero-cta:hover {
    transform: translateY(-3px); color: #fff;
    box-shadow: 0 10px 36px rgba(232,55,42,0.65), 0 0 0 3px rgba(232,55,42,0.2);
}
.hero-cta-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.18), transparent);
    pointer-events: none;
}

/* ── STAT ROW ── */
.hero-stats {
    position: relative; z-index: 3;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(232,55,42,0.12);
    padding: 1rem 0;
    backdrop-filter: blur(8px);
}
.hstat-row {
    display: flex; align-items: center; justify-content: flex-start;
    gap: 0; flex-wrap: wrap;
}
.hstat {
    display: flex; flex-direction: column; align-items: center;
    padding: .5rem 2rem;
}
.hstat-val {
    font-family: var(--font-hud); font-size: 1.5rem; font-weight: 900;
    color: var(--red-hot); line-height: 1;
    text-shadow: 0 0 20px rgba(232,55,42,0.6);
}
.hstat-lbl {
    font-family: var(--font-mono); font-size: .62rem; color: var(--muted);
    letter-spacing: .1em; text-transform: uppercase; margin-top: .2rem;
}
.hstat-divider {
    width: 1px; height: 36px;
    background: linear-gradient(180deg, transparent, rgba(232,55,42,0.2), transparent);
}

/* ══ SECTION ══ */
.teams-section { background: var(--dark); padding: 2.5rem 0 4rem; }

/* ══ BLOCK ══ */
.t-block {
    background: rgba(6,5,16,0.85);
    border: 1px solid rgba(255,255,255,0.065);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
    position: relative; overflow: hidden;
    backdrop-filter: blur(10px);
    opacity: 0; transform: translateY(20px);
    animation: block-enter .55s calc(var(--bi,1) * 110ms) forwards cubic-bezier(.22,1,.36,1);
}
@keyframes block-enter { to { opacity:1; transform:none; } }

.t-block::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--red), var(--orange), var(--pink), transparent);
    background-size: 200% 100%;
    animation: topline-race 3s linear infinite;
}
@keyframes topline-race { from{background-position:200% 0} to{background-position:-200% 0} }

.t-block-header {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
}

.t-block-icon {
    flex-shrink: 0; width: 46px; height: 46px;
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; position: relative;
}
/* All icons use red tones — each with a slightly different shade */
.t-block-icon.inv  { background: rgba(232,55,42,0.1);  border: 1px solid rgba(232,55,42,0.3);  color: var(--red-hot); }
.t-block-icon.req  { background: rgba(255,107,43,0.1);  border: 1px solid rgba(255,107,43,0.3);  color: var(--orange); }
.t-block-icon.own  { background: rgba(232,55,42,0.18); border: 1px solid rgba(232,55,42,0.45);  color: #ff7055; }
.t-block-icon.mbr  { background: rgba(255,32,96,0.1);  border: 1px solid rgba(255,32,96,0.3);   color: var(--pink); }
.t-block-icon.all  { background: rgba(232,55,42,0.08); border: 1px solid rgba(232,55,42,0.2);   color: var(--red); }

.tbi-ping {
    position: absolute; top: -2px; right: -2px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--red-hot); box-shadow: 0 0 0 0 rgba(232,55,42,0.6);
    animation: ping 1.5s ease-out infinite;
}
@keyframes ping {
    0%  { transform: scale(1); box-shadow: 0 0 0 0 rgba(232,55,42,0.6); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(232,55,42,0); }
    100%{ transform: scale(1); box-shadow: 0 0 0 0 rgba(232,55,42,0); }
}

.t-block-title {
    font-family: var(--font-hud); font-size: .9rem; font-weight: 700;
    color: var(--text); letter-spacing: .04em;
}
.t-block-sub {
    font-family: var(--font-mono); font-size: .7rem; color: var(--muted); margin-top: .15rem;
}

.t-count {
    margin-left: auto; flex-shrink: 0;
    font-family: var(--font-hud); font-size: .7rem; font-weight: 800;
    padding: .25rem .7rem; border-radius: 20px;
}
.t-count-inv { background: rgba(232,55,42,0.12); color: var(--red-hot); border: 1px solid rgba(232,55,42,0.3); }
.t-count-req { background: rgba(255,107,43,0.12); color: var(--orange);  border: 1px solid rgba(255,107,43,0.3); }
.t-count-own { background: rgba(232,55,42,0.18); color: #ff7055;         border: 1px solid rgba(232,55,42,0.4); }
.t-count-mbr { background: rgba(255,32,96,0.1);  color: var(--pink);     border: 1px solid rgba(255,32,96,0.3); }

/* ══ TEAM CARD GRID ══ */
.tcard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
    align-items: stretch;
}

/* ══ TEAM CARD ══ */
.tcard {
    border-radius: 12px;
    padding: 1.1rem 1.2rem;
    position: relative; overflow: hidden;
    cursor: pointer;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    display: flex; flex-direction: column; gap: .8rem;
}
.tcard:hover { transform: translateY(-3px); }

/* All cards use red family — each with subtle variation */
.tcard-inv {
    background: rgba(232,55,42,0.04);
    border: 1px solid rgba(232,55,42,0.15);
}
.tcard-inv:hover { border-color: var(--red-hot); box-shadow: 0 8px 28px rgba(232,55,42,0.15); }
.tcard-inv .tcard-glow { background: radial-gradient(circle, rgba(232,55,42,0.25), transparent 65%); }

.tcard-req {
    background: rgba(255,107,43,0.04);
    border: 1px solid rgba(255,107,43,0.15);
}
.tcard-req:hover { border-color: var(--orange); box-shadow: 0 8px 28px rgba(255,107,43,0.15); }
.tcard-req .tcard-glow { background: radial-gradient(circle, rgba(255,107,43,0.2), transparent 65%); }

.tcard-own {
    background: rgba(232,55,42,0.06);
    border: 1px solid rgba(232,55,42,0.22);
}
.tcard-own:hover { border-color: var(--red); box-shadow: 0 8px 28px rgba(232,55,42,0.2); }
.tcard-own .tcard-glow { background: radial-gradient(circle, rgba(232,55,42,0.3), transparent 65%); }

.tcard-mbr {
    background: rgba(255,32,96,0.04);
    border: 1px solid rgba(255,32,96,0.15);
}
.tcard-mbr:hover { border-color: var(--pink); box-shadow: 0 8px 28px rgba(255,32,96,0.15); }
.tcard-mbr .tcard-glow { background: radial-gradient(circle, rgba(255,32,96,0.2), transparent 65%); }

.tcard-all {
    background: rgba(232,55,42,0.03);
    border: 1px solid rgba(232,55,42,0.1);
}
.tcard-all:hover { border-color: rgba(232,55,42,0.4); box-shadow: 0 8px 28px rgba(232,55,42,0.12); }
.tcard-all .tcard-glow { background: radial-gradient(circle, rgba(232,55,42,0.18), transparent 65%); }

/* Shared card parts */
.tcard-glow {
    position: absolute; width: 100px; height: 100px; border-radius: 50%;
    top: -30px; right: -20px; pointer-events: none;
    opacity: 0; transition: opacity .3s;
}
.tcard:hover .tcard-glow { opacity: 1; }

.tcard-corner {
    position: absolute; width: 8px; height: 8px;
    border-color: var(--red); border-style: solid;
    opacity: 0; transform: scale(1.4); transition: opacity .2s, transform .25s;
}
.tcard-corner.tl { top:5px;    left:5px;  border-width:1.5px 0 0 1.5px; }
.tcard-corner.tr { top:5px;    right:5px; border-width:1.5px 1.5px 0 0; }
.tcard-corner.bl { bottom:5px; left:5px;  border-width:0 0 1.5px 1.5px; }
.tcard-corner.br { bottom:5px; right:5px; border-width:0 1.5px 1.5px 0; }
.tcard:hover .tcard-corner { opacity: 1; transform: scale(1); }

.tcard-top { display: flex; align-items: flex-start; gap: .8rem; }

.tcard-avatar {
    flex-shrink: 0; width: 42px; height: 42px; border-radius: 10px;
    background: rgba(232,55,42,0.06); border: 1px solid rgba(232,55,42,0.2);
