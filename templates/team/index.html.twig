    font-size: 1rem; color: rgba(232,55,42,0.5);
}

.tcard-info { flex: 1; min-width: 0; }
.tcard-name {
    font-family: var(--font-hud); font-size: .85rem; font-weight: 700;
    color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.tcard-meta {
    font-family: var(--font-mono); font-size: .67rem; color: var(--muted);
    margin-top: .18rem; display: flex; align-items: center; gap: .3rem;
}

.tcard-badge {
    flex-shrink: 0;
    font-family: var(--font-hud); font-size: .55rem; font-weight: 800;
    letter-spacing: .1em; padding: .2rem .5rem; border-radius: 4px;
}
.inv-badge { background: rgba(232,55,42,0.12); color: var(--red-hot); border: 1px solid rgba(232,55,42,0.3); }
.req-badge { background: rgba(255,107,43,0.12); color: var(--orange);  border: 1px solid rgba(255,107,43,0.3); }

/* ══ ACTIONS ══ */
.tcard-actions { display: flex; gap: .5rem; }
.flex-1 { flex: 1; }

.tact-btn {
    width: 100%; padding: .45rem .5rem;
    border: none; border-radius: 7px;
    font-family: var(--font-hud); font-size: .65rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: .4rem;
    transition: all .18s;
}
.tact-accept {
    background: rgba(0,230,118,0.12); border: 1px solid rgba(0,230,118,0.3); color: var(--green);
}
.tact-accept:hover { background: rgba(0,230,118,0.22); border-color: var(--green); box-shadow: 0 4px 16px rgba(0,230,118,0.15); }

.tact-decline {
    background: rgba(232,55,42,0.1); border: 1px solid rgba(232,55,42,0.3); color: var(--red-hot);
}
.tact-decline:hover { background: rgba(232,55,42,0.22); border-color: var(--red); box-shadow: 0 4px 16px rgba(232,55,42,0.2); }

.tact-cancel {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--muted);
}
.tact-cancel:hover { background: rgba(255,255,255,0.1); color: var(--text); }

/* ══ EMPTY ══ */
.t-empty {
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: center; gap: .7rem;
    padding: 2rem; color: var(--muted);
    font-family: var(--font-mono); font-size: .78rem; letter-spacing: .08em;
    border: 1px dashed rgba(255,255,255,0.07); border-radius: 10px;
}
.t-empty i { font-size: 1.1rem; }

.t-empty-hero {
    text-align: center; padding: 4rem 2rem; position: relative;
    background: rgba(6,5,16,0.6); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px; overflow: hidden; margin-top: 1rem;
}
.t-empty-hero-glow {
    position: absolute; width: 300px; height: 300px; border-radius: 50%;
    background: radial-gradient(circle, rgba(232,55,42,0.1), transparent 65%);
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    pointer-events: none;
}
.t-empty-hero-icon {
    width: 70px; height: 70px; border-radius: 18px; margin: 0 auto 1.5rem;
    background: rgba(232,55,42,0.1); border: 1px solid rgba(232,55,42,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: var(--red-hot);
}
.t-empty-hero h3 {
    font-family: var(--font-hud); color: var(--text); margin-bottom: .5rem;
}
.t-empty-hero p { font-family: var(--font-body); color: var(--muted); margin-bottom: 1.5rem; }

/* ══ BTN FIRE ══ */
.btn-fire {
    position: relative; overflow: hidden; display: inline-flex; align-items: center; gap: .6rem;
    padding: .72rem 2rem;
    background: linear-gradient(135deg, #b02b20, #e8372a, #ff5533);
    border: none; border-radius: 9px; color: #fff;
    font-family: var(--font-hud); font-size: .8rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 24px rgba(232,55,42,0.45);
    transition: transform .18s, box-shadow .18s;
}
.btn-fire:hover { transform: translateY(-3px); box-shadow: 0 10px 36px rgba(232,55,42,0.6); color:#fff; }
.btn-fire-bg { position: absolute; inset: 0; background: linear-gradient(135deg,rgba(255,255,255,.15),transparent); pointer-events:none; }

/* ══ RESPONSIVE ══ */
@media (max-width: 640px) {
    .teams-hero { padding: 2.5rem 0 0; }
    .hero-title { font-size: 2.4rem; }
    .t-block { padding: 1.25rem 1rem; }
    .tcard-grid { grid-template-columns: 1fr; }
    .hstat { padding: .5rem 1.2rem; }
    .hstat-val { font-size: 1.2rem; }
}
</style>

<script>
(function () {
    'use strict';

    /* ── PARTICLE CANVAS ── */
    const canvas = document.getElementById('heroCanvas');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        let W, H, particles = [];

        function resize() {
            const hero = canvas.parentElement;
            W = canvas.width  = hero.offsetWidth;
            H = canvas.height = hero.offsetHeight;
        }
        resize();
        window.addEventListener('resize', () => { resize(); spawnAll(); });

        const COLORS = [
            'rgba(232,55,42,',
            'rgba(255,77,61,',
            'rgba(255,107,43,',
            'rgba(255,32,96,',
        ];

        function mkParticle() {
            const c = COLORS[Math.floor(Math.random() * COLORS.length)];
            return {
                x: Math.random() * W, y: H + Math.random() * 60,
                vx: (Math.random() - .5) * .5, vy: -(0.3 + Math.random() * 0.9),
                r: 0.8 + Math.random() * 1.6, alpha: 0,
                maxAlpha: 0.2 + Math.random() * 0.4,
                phase: Math.random() * Math.PI * 2, color: c,
                life: 0, maxLife: 140 + Math.random() * 160,
            };
        }
        function spawnAll() { particles = Array.from({ length: 42 }, mkParticle); }
        spawnAll();

        function tick() {
            ctx.clearRect(0, 0, W, H);
            particles.forEach((p, i) => {
                p.life++;
                p.x += p.vx + Math.sin(p.phase + p.life * 0.02) * 0.22;
                p.y += p.vy;
                const t = p.life / p.maxLife;
                p.alpha = t < 0.15 ? (t/0.15)*p.maxAlpha : t > 0.75 ? ((1-t)/0.25)*p.maxAlpha : p.maxAlpha;
                if (p.life >= p.maxLife || p.y < -10) particles[i] = mkParticle();
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = p.color + p.alpha + ')';
                ctx.shadowColor = p.color + '0.5)';
                ctx.shadowBlur = 6;
                ctx.fill();
            });
            requestAnimationFrame(tick);
        }
        tick();

        /* Title glitch */
        const accent = document.querySelector('.title-row2');
        if (accent) {
            setInterval(() => {
                if (Math.random() > 0.82) {
                    accent.animate([
                        { transform: 'none', filter: 'none' },
                        { transform: 'skewX(-3deg) translateX(-2px)', filter: 'hue-rotate(20deg) brightness(1.4)' },
                        { transform: 'skewX(2deg) translateX(3px)', filter: 'hue-rotate(-15deg)' },
                        { transform: 'none', filter: 'none' },
                    ], { duration: 160, easing: 'steps(3)' });
                }
            }, 3200);
        }
    }

    /* ── SCROLL REVEAL ── */
    if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.style.animationPlayState = 'running';
                    io.unobserve(e.target);
                }
            });
        }, { threshold: 0.05 });

        document.querySelectorAll('.t-block').forEach(b => {
            b.style.animationPlayState = 'paused';
            io.observe(b);
        });
    }

    /* ── HSTAT COUNTER ANIMATION ── */
    document.querySelectorAll('.hstat-val').forEach(el => {
        const target = parseInt(el.textContent, 10);
        if (isNaN(target) || target === 0) return;
        let current = 0;
        const step = Math.ceil(target / 20);
        const timer = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = current;
            if (current >= target) clearInterval(timer);
        }, 40);
    });

})();
</script>

