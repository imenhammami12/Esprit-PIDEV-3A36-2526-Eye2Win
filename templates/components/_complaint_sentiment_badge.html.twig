{#
    templates/components/_complaint_sentiment_badge.html.twig
    ──────────────────────────────────────────────────────────
    Composant réutilisable — affiche le résultat de SentimentServiceComplaints.

    Usage front-office (widget complet) :
        {{ include('components/_complaint_sentiment_badge.html.twig', { complaint: complaint }) }}

    Usage back-office (pill compacte pour tableaux) :
        {{ include('components/_complaint_sentiment_badge.html.twig', { complaint: complaint, compact: true }) }}

    Paramètres optionnels :
        compact    (bool, défaut false) — pill courte pour les listes/tableaux
        show_score (bool, défaut true)  — affiche la barre de confiance
#}

{% set show_score = show_score ?? true %}
{% set compact    = compact    ?? false %}

{% if complaint.hasSentiment() %}

    {% set label     = complaint.sentimentLabel %}
    {% set score_pct = (complaint.sentimentScore * 100)|round %}
    {% set emoji     = complaint.sentimentEmoji %}
    {% set badge     = complaint.sentimentBadgeClass %}
    {% set text_lbl  = complaint.sentimentTextLabel %}

    {% if compact %}

        {# ── Mode compact : pill pour tableaux / index ── #}
        <span class="csb-pill csb-{{ label|lower }}"
              title="Sentiment : {{ text_lbl }} — Confiance {{ score_pct }}%">
            <span class="csb-emoji">{{ emoji }}</span>
            {{ text_lbl }}
        </span>

    {% else %}

        {# ── Mode complet : widget pour pages de détail ── #}
        <div class="csb-widget csb-widget-{{ label|lower }}">

            {# En-tête #}
            <div class="csb-header">
                <span class="csb-big-emoji">{{ emoji }}</span>
                <div class="csb-header-text">
                    <div class="csb-title">Sentiment Analysis</div>
                    <div class="csb-source">
                        {% if complaint.sentimentSource == 'api' %}
                            <i class="bi bi-cloud-check-fill me-1 text-success"></i>AI model (HuggingFace)
                        {% else %}
                            <i class="bi bi-cpu-fill me-1 text-warning"></i>Keyword analysis
                        {% endif %}
                    </div>
                </div>
                <span class="badge bg-{{ badge }} ms-auto csb-label-badge">
                    {{ text_lbl }}
                </span>
            </div>

            {# Barre de confiance #}
            {% if show_score %}
            <div class="csb-bar-section">
                <div class="csb-bar-labels">
                    <span>Confidence</span>
                    <span>{{ score_pct }}%</span>
                </div>
                <div class="csb-bar-track">
                    <div class="csb-bar-fill csb-fill-{{ label|lower }}"
                         style="width: {{ score_pct }}%"></div>
                </div>
            </div>
            {% endif %}

            {# Alerte priorité suggérée #}
            {% if complaint.sentimentPrioritySuggestion %}
            <div class="csb-priority-alert">
                <i class="bi bi-lightning-charge-fill me-1"></i>
                High negativity detected — priority auto-raised to
                <strong>{{ complaint.sentimentPrioritySuggestion }}</strong>
            </div>
            {% endif %}

        </div>

    {% endif %}

{% endif %}

<style>
/* ═══════════════════════════════════════════════════════
   _complaint_sentiment_badge  (csb = complaint sentiment badge)
   Préfixe csb- pour éviter tout conflit avec ta collègue
═══════════════════════════════════════════════════════ */

/* ── Pill compacte ── */
.csb-pill {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    font-size: .7rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 20px;
    border: 1px solid transparent;
    white-space: nowrap;
    cursor: default;
    transition: transform .15s;
}
.csb-pill:hover { transform: translateY(-1px); }

.csb-negative { background: rgba(220,53,69,.12);  border-color: rgba(220,53,69,.3);  color: #f87171; }
.csb-positive { background: rgba(25,135,84,.12);   border-color: rgba(25,135,84,.3);  color: #4ade80; }
.csb-neutral  { background: rgba(255,193,7,.12);   border-color: rgba(255,193,7,.3);  color: #fbbf24; }

.csb-emoji { font-size: .85rem; }

/* ── Widget complet ── */
.csb-widget {
    border-radius: 10px;
    padding: .9rem 1rem;
    border: 1px solid;
    transition: box-shadow .25s, transform .2s;
}
.csb-widget:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.25);
    transform: translateY(-2px);
}

.csb-widget-negative { background: rgba(220,53,69,.07);  border-color: rgba(220,53,69,.25); }
.csb-widget-positive { background: rgba(25,135,84,.07);   border-color: rgba(25,135,84,.25); }
.csb-widget-neutral  { background: rgba(255,193,7,.07);   border-color: rgba(255,193,7,.25); }

/* En-tête */
.csb-header {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: .6rem;
}
.csb-big-emoji  { font-size: 1.8rem; flex-shrink: 0; }
.csb-header-text { flex: 1; }
.csb-title {
    font-size: .82rem;
    font-weight: 700;
    color: rgba(255,255,255,.88);
    letter-spacing: .02em;
}
.csb-source {
    font-size: .68rem;
    color: rgba(255,255,255,.4);
    margin-top: .1rem;
}
.csb-label-badge { font-size: .65rem; }

/* Barre de confiance */
.csb-bar-section { margin-bottom: .5rem; }
.csb-bar-labels {
    display: flex;
    justify-content: space-between;
    font-size: .65rem;
    color: rgba(255,255,255,.38);
    margin-bottom: .3rem;
}
.csb-bar-track {
    height: 5px;
    background: rgba(255,255,255,.07);
    border-radius: 3px;
    overflow: hidden;
}
.csb-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 1.1s cubic-bezier(.4,0,.2,1);
}
.csb-fill-negative { background: linear-gradient(90deg, #dc3545, #ff6b6b); }
.csb-fill-positive { background: linear-gradient(90deg, #198754, #4ade80); }
.csb-fill-neutral  { background: linear-gradient(90deg, #e0a800, #fde68a); }

/* Alerte priorité */
.csb-priority-alert {
    margin-top: .6rem;
    padding: .35rem .75rem;
    background: rgba(255,193,7,.09);
    border: 1px solid rgba(255,193,7,.25);
    border-radius: 6px;
    font-size: .73rem;
    color: #fbbf24;
    display: flex;
    align-items: center;
    gap: .3rem;
}
</style>
