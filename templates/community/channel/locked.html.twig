{% extends 'base.html.twig' %}

{% block body %}
    <div class="container py-4">
        <h2>{{ channel.name }} <span class="badge bg-dark ms-2">Private</span></h2>
        <p class="text-muted">{{ channel.description }}</p>

        {% if app.user %}
            {% if pendingRequest %}
                <div class="alert alert-info">
                    Your request is pending approval from the creator.
                </div>
            {% else %}
                <form method="post" action="{{ path('community_channel_request_access', {id: channel.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('request_access_' ~ channel.id) }}">
                    <button class="btn btn-primary">
                        Request access
                    </button>
                </form>
            {% endif %}
        {% else %}
            <div class="alert alert-warning">
                Login to request access.
            </div>
        {% endif %}

        <a href="{{ path('community_channels_index') }}" class="btn btn-link mt-3">Back</a>
    </div>
{% endblock %}