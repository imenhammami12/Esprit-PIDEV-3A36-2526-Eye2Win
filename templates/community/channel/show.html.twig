{% extends 'base.html.twig' %}

{% block body %}
    <style>
        /* ======= eSport Chat UI (scoped) ======= */
        .chat-wrap{
            margin-top: 28px;
            margin-bottom: 50px;
        }
        .chat-hero{
            background: rgba(0,0,0,0.35);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px;
            padding: 22px 22px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.35);
            position: relative;
            overflow: hidden;
        }
        .chat-hero:before{
            content:"";
            position:absolute;
            inset:-2px;
            background: radial-gradient(circle at 20% 20%, rgba(255,0,80,0.20), transparent 40%),
            radial-gradient(circle at 80% 30%, rgba(0,220,255,0.18), transparent 45%),
            radial-gradient(circle at 40% 90%, rgba(120,0,255,0.12), transparent 55%);
            filter: blur(10px);
            z-index:0;
        }
        .chat-hero:before{
            pointer-events: none;
        }

        .hero-content{
            position: relative;
            z-index: 5;
        }

        .invite-form{
            position: relative;
            z-index: 6;
        }

        .invite-form select{
            cursor: pointer;
            pointer-events: auto;
        }
        .chat-hero > *{ position:relative; z-index:1; }

        .chat-title{
            font-size: 34px;
            font-weight: 800;
            color: #fff;
            margin: 0;
            letter-spacing: .3px;
            text-shadow: 0 8px 18px rgba(0,0,0,0.45);
        }
        .chat-sub{
            margin-top: 6px;
            color: rgba(255,255,255,0.70);
            font-size: 14px;
            line-height: 1.4;
        }
        .chat-pill{
            display:inline-flex;
            align-items:center;
            gap:8px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.10);
            background: rgba(255,255,255,0.06);
            color: rgba(255,255,255,0.85);
            font-size: 12px;
            margin-top: 10px;
        }

        .chat-panel{
            margin-top: 18px;
            background: rgba(0,0,0,0.28);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        }

        .chat-stream{
            height: min(62vh, 560px);
            overflow-y: auto;
            padding: 18px 16px;
        }
        .chat-stream::-webkit-scrollbar{ width: 10px; }
        .chat-stream::-webkit-scrollbar-thumb{
            background: rgba(255,255,255,0.12);
            border-radius: 999px;
        }

        .msg-row{
            display:flex;
            margin-bottom: 14px;
            gap: 10px;
        }
        .msg-row.me{ justify-content: flex-end; }
        .msg-row.other{ justify-content: flex-start; }

        .avatar{
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display:flex;
            align-items:center;
            justify-content:center;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.10);
            color: rgba(255,255,255,0.85);
            font-weight: 700;
            font-size: 13px;
            flex: 0 0 auto;
            user-select:none;
        }

        .bubble{
            max-width: 78%;
            border-radius: 16px;
            padding: 12px 12px 10px 12px;
            border: 1px solid rgba(255,255,255,0.10);
            background: rgba(255,255,255,0.06);
            position: relative;
        }
        .me .bubble{
            background: linear-gradient(135deg, rgba(255,0,80,0.18), rgba(0,220,255,0.12));
            border-color: rgba(255,0,80,0.20);
        }

        .msg-top{
            display:flex;
            align-items:center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 6px;
        }
        .msg-name{
            color: rgba(255,255,255,0.92);
            font-weight: 700;
            font-size: 13px;
        }
        .msg-time{
            color: rgba(255,255,255,0.55);
            font-size: 11px;
            white-space: nowrap;
        }
        .msg-text{
            color: rgba(255,255,255,0.86);
            font-size: 14px;
            line-height: 1.35;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .msg-deleted{
            color: rgba(255,255,255,0.55);
            font-style: italic;
            font-size: 13px;
        }

        .msg-actions{
            position: relative;
            margin-left: auto;
        }
        .dots-btn{
            border: 0;
            background: transparent;
            color: rgba(255,255,255,0.70);
            width: 30px;
            height: 30px;
            border-radius: 10px;
            display:flex;
            align-items:center;
            justify-content:center;
            cursor: pointer;
        }
        .dots-btn:hover{
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.95);
        }
        .dots-menu{
            min-width: 150px;
            background: rgba(15,18,25,0.98);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 14px;
            padding: 6px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.45);
        }
        .dots-item{
            display:flex;
            align-items:center;
            gap:10px;
            width:100%;
            padding: 9px 10px;
            border-radius: 10px;
            color: rgba(255,255,255,0.85);
            text-decoration:none;
            font-size: 13px;
            border:0;
            background: transparent;
            text-align:left;
        }
        .dots-item:hover{ background: rgba(255,255,255,0.08); }
        .dots-danger{ color: #ff5a7a; }

        .chat-compose{
            padding: 14px 16px;
            border-top: 1px solid rgba(255,255,255,0.08);
            background: rgba(0,0,0,0.18);
        }
        .compose-row{
            display:flex;
            gap: 10px;
            align-items: flex-end;
        }
        .compose-row textarea{
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.10);
            color: rgba(255,255,255,0.90);
            border-radius: 14px;
            padding: 12px 12px;
            width: 100%;
            min-height: 54px;
            resize: vertical;
        }
        .compose-row textarea:focus{
            outline: none;
            border-color: rgba(0,220,255,0.35);
            box-shadow: 0 0 0 3px rgba(0,220,255,0.12);
        }
        .btn-send{
            border: 0;
            border-radius: 14px;
            padding: 12px 14px;
            background: #ff2d55;
            color: #fff;
            font-weight: 700;
            display:inline-flex;
            align-items:center;
            gap: 8px;
            box-shadow: 0 10px 25px rgba(255,45,85,0.25);
            white-space: nowrap;
        }
        .btn-send:hover{ filter: brightness(1.05); }

        .edit-panel{
            background: rgba(0,0,0,0.22);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            padding: 10px;
        }
        .edit-panel textarea{
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.10);
            color: rgba(255,255,255,0.90);
            border-radius: 12px;
            padding: 10px;
            width:100%;
            min-height: 70px;
        }
        .edit-actions{
            display:flex;
            gap: 10px;
            margin-top: 10px;
        }
        #files-preview{
            display:flex;
            flex-wrap:wrap;
            gap:8px;
            margin-top:8px;
        }

        .file-chip{
            display:inline-flex;
            align-items:center;
            gap:8px;
            padding:6px 10px;
            border-radius:14px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.10);
            color: rgba(255,255,255,0.90);
            font-size: 12px;
        }

        .file-chip .file-size{
            opacity:.7;
        }

        .file-chip .file-remove{
            border:0;
            background: transparent;
            color: rgba(255,255,255,0.75);
            cursor:pointer;
            font-size: 14px;
            line-height: 1;
        }

        .file-chip .file-remove:hover{
            color:#ff5a7a;
        }
    </style>

    <div class="container chat-wrap">

        <div class="chat-hero">
            <div class="d-flex justify-content-between align-items-start flex-wrap hero-content" style="gap:12px;">
                <div>
                    <h2 class="chat-title">{{ channel.name }}</h2>
                    <div class="chat-sub">{{ channel.description }}</div>
                    <div class="chat-pill">
                        <i class="fas fa-hashtag"></i> Channel • Chat Room
                    </div>
                    {% if app.user and channel.createdBy == app.user.userIdentifier and channel.type == 'private' %}
                        <div class="mt-3">
                            <form method="post"
                                  class="invite-form"
                                  action="{{ path('community_invite_create', {id: channel.id}) }}"
                                  style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">

                                <input type="hidden" name="_token" value="{{ csrf_token('create_invite_' ~ channel.id) }}">

                                <label for="invite_mode_{{ channel.id }}" style="font-size:13px; color: rgba(255,255,255,.75);">
                                    Invite mode:
                                </label>

                                <select id="invite_mode_{{ channel.id }}"
                                        name="mode"
                                        style="
                                            background: rgba(0,0,0,0.55);
                                            color: #fff;
                                            border: 1px solid rgba(255,255,255,0.18);
                                            border-radius: 10px;
                                            padding: 8px 10px;
                                            min-width: 230px;
                                            outline: none;
                                        ">
                                    <option value="request_only">Request only (approval)</option>
                                    <option value="auto_join">Auto join (instant)</option>
                                </select>

                                <button class="btn btn-primary btn-sm" type="submit">
                                    <i class="fas fa-qrcode me-1"></i> Generate QR Invite
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>

                <a class="btn btn-soft" href="{{ path('community_channels_index') }}" style="align-self:center;">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </div>

        <div class="chat-panel">
            <div class="chat-stream" id="chatStream">

                {% for m in messages %}
                    {% set isMe = app.user and (m.senderEmail == app.user.userIdentifier) %}
                    {% include 'community/message/_row.html.twig' with {
                        m: m,
                        channel: channel,
                        isMe: isMe,
                        showActions: isMe and not m.isDeleted and not (editId is defined and editId == m.id and editForm is not null),
                        editId: editId,
                        editForm: editForm
                    } %}
                {% else %}
                    <div class="text-center" style="color: rgba(255,255,255,0.75); padding: 30px 10px;">
                        No message at the moment. Start a conversation 🔥
                    </div>
                {% endfor %}

            </div>

            <div class="chat-compose">
                {% if is_granted('ROLE_USER') %}

                    {{ form_start(messageForm, { attr: { id: 'message-form' } }) }}
                    <div class="compose-row">

                        {{ form_widget(messageForm.content, {'attr': {'placeholder': 'Type here...', 'rows': 2}}) }}

                        {{ form_widget(messageForm.files, { attr: { class: 'file-input-hidden' } }) }}

                        <label for="{{ messageForm.files.vars.id }}" class="btn-send" style="cursor:pointer;" title="Attach file">
                            <i class="fas fa-paperclip"></i>
                        </label>

                        <button class="btn-send" type="submit">
                            <i class="fas fa-paper-plane"></i> Send
                        </button>
                    </div>

                    <div id="compose-error" style="margin-top:6px; font-size:12px; color: #ff6b81;"></div>
                    <div id="files-preview" style="margin-top:6px; font-size:12px; color: rgba(255,255,255,0.7);"></div>
                    {{ form_end(messageForm) }}

                {% else %}
                    <div class="text-muted">Login to send a message.</div>
                {% endif %}
            </div>
        </div>

    </div>

    <script>
        (function () {
            const chatStream = document.getElementById('chatStream');
            const form = document.querySelector('.chat-compose form');
            const textarea = form ? form.querySelector('textarea') : null;

            if (chatStream) {
                chatStream.addEventListener('submit', async (e) => {
                    const form = e.target;
                    if (!(form instanceof HTMLFormElement)) return;
                    if (!form.action.includes('/messages/') || !form.action.endsWith('/delete')) return;
                    e.preventDefault();
                    const res = await fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form),
                        headers: {'X-Requested-With': 'XMLHttpRequest'}
                    });
                    const errorBox = document.getElementById('compose-error');
                    if (!res.ok) {
                        let payload = null;
                        try { payload = await res.json(); } catch (e) {}
                        const msg = payload?.error
                            || (Array.isArray(payload?.errors) && payload.errors.length ? payload.errors[0] : null)
                            || 'Unable to send message.';
                        if (errorBox) errorBox.textContent = msg;
                        return;
                    }
                    if (errorBox) errorBox.textContent = '';
                });
            }

            function scrollToBottom() {
                if (chatStream) chatStream.scrollTop = chatStream.scrollHeight;
            }

            scrollToBottom();

            const currentUserEmail = "{{ app.user ? app.user.userIdentifier : '' }}";
            const channelId = {{ channel.id }};

            // ✅ Polling instead of Mercure (works on Render free tier)
            let lastMessageId = {{ messages|length > 0 ? messages|last.id : 0 }};

            function pollMessages() {
                fetch(`/channels/${channelId}/poll?after=${lastMessageId}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(r => {
                    if (!r.ok) return null;
                    return r.json();
                })
                .then(data => {
                    if (!data || !Array.isArray(data.messages)) return;
                    data.messages.forEach(m => {
                        if (document.querySelector(`[data-msg-id="${m.id}"]`)) return;
                        const isMe = (currentUserEmail && m.senderEmail === currentUserEmail);
                        chatStream.insertAdjacentHTML('beforeend', buildMessageHtml(m, isMe));
                        lastMessageId = Math.max(lastMessageId, m.id);
                        scrollToBottom();
                    });
                })
                .catch(() => {});
            }

            // Poll every 3 seconds
            setInterval(pollMessages, 3000);

            const fileInput = document.getElementById('msg-files');
            const preview = document.getElementById('files-preview');

            if (fileInput && preview) {
                const renderFiles = () => {
                    preview.innerHTML = '';
                    const files = Array.from(fileInput.files || []);
                    if (!files.length) return;

                    files.forEach((f, idx) => {
                        const chip = document.createElement('span');
                        chip.className = 'file-chip';

                        const name = document.createElement('span');
                        name.textContent = f.name;

                        const size = document.createElement('span');
                        size.className = 'file-size';
                        size.textContent = `(${Math.round(f.size/1024)} KB)`;

                        const remove = document.createElement('button');
                        remove.type = 'button';
                        remove.className = 'file-remove';
                        remove.textContent = '×';
                        remove.title = 'Remove';

                        remove.addEventListener('click', () => {
                            const dt = new DataTransfer();
                            files.forEach((file, i) => { if (i !== idx) dt.items.add(file); });
                            fileInput.files = dt.files;
                            renderFiles();
                        });

                        chip.appendChild(name);
                        chip.appendChild(size);
                        chip.appendChild(remove);
                        preview.appendChild(chip);
                    });
                };

                fileInput.addEventListener('change', renderFiles);
            }

            function escapeHtml(str) {
                return String(str ?? '')
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#039;");
            }

            function buildMessageHtml(m, isMe) {
                const senderName = escapeHtml(m.senderName);
                const sentAt = escapeHtml(m.sentAt);

                const avatarLeft = `
                    <div class="avatar" title="${senderName}">
                        ${senderName.slice(0, 1).toUpperCase()}
                    </div>
                `;

                const avatarRight = `
                    <div class="avatar" title="You" style="background: rgba(255,45,85,0.18); border-color: rgba(255,45,85,0.20);">
                        <i class="fas fa-user"></i>
                    </div>
                `;

                const bodyHtml = m.isDeleted
                    ? `<div class="msg-deleted">this message is deleted.</div>`
                    : (m.content && m.content.trim() !== '')
                        ? `<div class="msg-text">${escapeHtml(m.content)}</div>`
                        : '';

                let filesHtml = '';
                if (!m.isDeleted && Array.isArray(m.attachments) && m.attachments.length > 0) {
                    filesHtml = `<div class="msg-files mt-2">` + m.attachments.map(a => {
                        const mime = (a.mime || '').toLowerCase();
                        if (mime.startsWith('image/')) {
                            return `
                                <div class="msg-attach-preview">
                                    <a href="${escapeHtml(a.url)}" target="_blank" rel="noopener">
                                        <img src="${escapeHtml(a.url)}" alt="${escapeHtml(a.name)}" class="chat-image">
                                    </a>
                                    <div class="file-caption">${escapeHtml(a.name)}
                                        <span style="opacity:.7;">(${Math.round((a.size||0)/1024)} KB)</span>
                                    </div>
                                </div>
                            `;
                        }
                        return `
                            <a class="file-pill" href="${escapeHtml(a.url)}" target="_blank" rel="noopener">
                                <i class="fas fa-paperclip"></i>
                                ${escapeHtml(a.name)}
                                <span style="opacity:.7;">(${Math.round((a.size||0)/1024)} KB)</span>
                            </a>
                        `;
                    }).join('') + `</div>`;
                }

                return `
                    <div class="msg-row ${isMe ? 'me' : 'other'}" data-msg-id="${m.id}">
                        ${isMe ? '' : avatarLeft}
                        <div class="bubble">
                            <div class="msg-top">
                                <div class="d-flex align-items-center gap-2" style="gap:10px;">
                                    <div class="msg-name">${senderName}</div>
                                    <div class="msg-time">${sentAt}</div>
                                </div>
                            </div>
                            ${bodyHtml}
                            ${filesHtml}
                        </div>
                        ${isMe ? avatarRight : ''}
                    </div>
                `;
            }

            if (form && textarea) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const errorBox = document.getElementById('compose-error');
                    if (errorBox) errorBox.textContent = '';

                    const fd = new FormData(form);

                    let res;
                    try {
                        res = await fetch(form.action, {
                            method: 'POST',
                            body: fd,
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                    } catch (err) {
                        if (errorBox) errorBox.textContent = 'Network error. Try again.';
                        return;
                    }

                    let json = null;
                    try { json = await res.json(); } catch (e) {}

                    if (!res.ok || json?.ok === false) {
                        const msg =
                            json?.error ||
                            (Array.isArray(json?.errors) && json.errors.length ? json.errors[0] : null) ||
                            'Unable to send message.';
                        if (errorBox) errorBox.textContent = msg;
                        return;
                    }

                    if (json.ok && json.html) {
                        const existing = document.querySelector(`[data-msg-id="${json.id}"]`);
                        if (existing) {
                            existing.outerHTML = json.html;
                        } else {
                            chatStream.insertAdjacentHTML('beforeend', json.html);
                        }

                        textarea.value = '';
                        const fileInput = document.getElementById('msg-files');
                        const preview = document.getElementById('files-preview');
                        if (fileInput) fileInput.value = '';
                        if (preview) preview.textContent = '';

                        scrollToBottom();
                    }
                });

                textarea.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        form.requestSubmit();
                    }
                });
            }

        })();
    </script>

{% endblock %}
